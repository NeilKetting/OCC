<UserControl x:Class="OCC.WpfClient.Features.ProjectHub.Views.GanttMenuBarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OCC.WpfClient.Features.ProjectHub.Views"
             xmlns:vm="clr-namespace:OCC.WpfClient.Features.ProjectHub.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="50" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance Type=vm:ProjectGanttViewModel}">

    <Border Background="{StaticResource BackgroundDark}" BorderBrush="{StaticResource GlassBorderUltraLight}" BorderThickness="0,0,0,1" Padding="10,5">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            
            <!-- Left Controls: Filter / View Options -->
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Button Style="{StaticResource ToolbarIconButton}" Padding="8,5">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource IconSearch}" Fill="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" Width="14" Height="14" Stretch="Uniform" Margin="0,0,5,0"/>
                        <TextBlock Text="Filter" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource ToolbarIconButton}" Padding="8,5" Margin="10,0,0,0">
                     <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource IconLiveView}" Fill="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" Width="14" Height="14" Stretch="Uniform" Margin="0,0,5,0"/>
                        <TextBlock Text="View" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- Right Controls: Zoom and Date Navigation -->
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button Command="{Binding GoToTodayCommand}" Content="Today" Style="{StaticResource SecondaryButton}" VerticalAlignment="Center" Height="30" Padding="15,0"/>
                
                <Border Width="1" Background="{StaticResource GlassBorderUltraLight}" Margin="15,5" Height="20" VerticalAlignment="Center"/>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Zoom" VerticalAlignment="Center" Foreground="{StaticResource TextSub}" Margin="0,0,10,0"/>
                    <Button Style="{StaticResource ToolbarIconButton}" Command="{Binding ZoomOutCommand}" Width="24" Height="24" Padding="0">
                        <Path Data="{StaticResource IconChevronLeft}" Fill="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" Width="10" Height="10" Stretch="Uniform"/>
                    </Button>
                    <Slider Value="{Binding ZoomLevel}" Minimum="0.4" Maximum="3.0" Width="100" VerticalAlignment="Center" Margin="5,0"/>
                    <Button Style="{StaticResource ToolbarIconButton}" Command="{Binding ZoomInCommand}" Width="24" Height="24" Padding="0">
                        <Path Data="{StaticResource IconChevronRight}" Fill="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" Width="10" Height="10" Stretch="Uniform"/>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
