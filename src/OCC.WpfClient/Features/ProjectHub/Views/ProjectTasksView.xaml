<UserControl x:Class="OCC.WpfClient.Features.ProjectHub.Views.ProjectTasksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:OCC.WpfClient.Features.ProjectHub.ViewModels"
             xmlns:local="clr-namespace:OCC.WpfClient.Features.ProjectHub.Views"
             xmlns:infra="clr-namespace:OCC.WpfClient.Infrastructure"
             xmlns:conv="clr-namespace:OCC.WpfClient.Infrastructure.Converters"
             xmlns:ap="clr-namespace:OCC.WpfClient.Infrastructure.AttachedProperties"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000"
             d:DataContext="{d:DesignInstance vm:ProjectTasksViewModel}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/Common.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <infra:BindingProxy x:Key="Proxy" Data="{Binding}" />
            <conv:VisibilityConverter x:Key="VisibilityConverter" />
            <conv:LevelToIndentConverter x:Key="LevelToIndentConverter" IndentStep="30" />
            <conv:RotationConverter x:Key="RotationConverter" />

            <Style x:Key="ExpanderButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="Transparent" CornerRadius="4" Width="20" Height="20">
                                <ContentPresenter x:Name="content" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#15FFFFFF"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#25FFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid Margin="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Tool Bar -->
            <Border Grid.Row="0" Margin="10">
                <Grid>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Project Tasks" FontSize="20" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                        <Border Background="{StaticResource AccentBlue}" CornerRadius="12" Padding="10,2" Margin="15,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Tasks.Count}" Foreground="White" FontSize="12" FontWeight="Bold"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Command="{Binding NewTaskCommand}" Style="{StaticResource ActionButtonPrimary}" Padding="20,10">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconPlus}" Fill="White" Width="12" Height="12" Stretch="Uniform" Margin="0,0,10,0"/>
                                <TextBlock Text="Create Task"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Stats & Search Line -->
            <Border Grid.Row="1" Style="{StaticResource GlassCard}" Padding="15,10" Margin="10,0,10,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" /> <!-- Search Icon -->
                        <ColumnDefinition Width="250" />  <!-- Search Box -->
                        <ColumnDefinition Width="Auto" /> <!-- Stage Filter -->
                        <ColumnDefinition Width="Auto" /> <!-- Divider -->
                        <ColumnDefinition Width="Auto" /> <!-- Columns -->
                        <ColumnDefinition Width="*" />    <!-- Spacer -->
                    </Grid.ColumnDefinitions>

                    <!-- Search -->
                    <Path Grid.Column="0" Data="{StaticResource IconSearch}" Fill="{StaticResource TextSub}" Width="14" Height="14" Margin="5,0,10,0" VerticalAlignment="Center" Stretch="Uniform"/>
                    <TextBox Grid.Column="1" Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource ModernInput}" Height="34" Padding="8,0" BorderThickness="0" Background="Transparent"
                             ap:WatermarkProperties.Watermark="Search tasks..."/>

                    <!-- Stage Filter -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                        <TextBlock Text="Filter Stage:" VerticalAlignment="Center" Foreground="{StaticResource TextSub}" Margin="0,0,10,0" FontSize="11" FontWeight="Bold"/>
                        <ComboBox ItemsSource="{Binding AvailableStages}" SelectedItem="{Binding SelectedStageFilter}" Style="{StaticResource ModernComboBox}" Width="150" Height="34"/>
                    </StackPanel>

                     <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                        <Border Width="1" Height="20" Background="{StaticResource GlassBorder}" Margin="0,0,15,0" VerticalAlignment="Center"/>
                        
                        <!-- Columns Selection -->
                        <Grid>
                            <ToggleButton x:Name="ColumnsToggle" Style="{StaticResource ToolbarToggleButton}" Width="100" Height="34">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconList}" Fill="White" Width="14" Height="14" Stretch="Uniform" Margin="0,0,8,0" Opacity="0.8"/>
                                    <TextBlock Text="COLUMNS" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                </StackPanel>
                            </ToggleButton>
                            <Popup IsOpen="{Binding IsChecked, ElementName=ColumnsToggle}" StaysOpen="False" PlacementTarget="{Binding ElementName=ColumnsToggle}" Placement="Bottom" AllowsTransparency="True" PopupAnimation="Fade">
                                <Border Background="{StaticResource BackgroundDark}" BorderBrush="{StaticResource GlassBorder}" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,5,0,0" Width="200">
                                    <StackPanel>
                                        <TextBlock Text="DISPLAY COLUMNS" FontSize="10" FontWeight="Bold" Foreground="{StaticResource AccentBlue}" Margin="0,0,0,8"/>
                                        <CheckBox Content="Start Date" IsChecked="{Binding IsStartVisible, Mode=TwoWay}" Style="{StaticResource ModernCheckBox}" Margin="0,2"/>
                                        <CheckBox Content="End Date" IsChecked="{Binding IsEndVisible, Mode=TwoWay}" Style="{StaticResource ModernCheckBox}" Margin="0,2"/>
                                        <CheckBox Content="Progress" IsChecked="{Binding IsProgressVisible, Mode=TwoWay}" Style="{StaticResource ModernCheckBox}" Margin="0,2"/>
                                        <CheckBox Content="Stage" IsChecked="{Binding IsStageVisible, Mode=TwoWay}" Style="{StaticResource ModernCheckBox}" Margin="0,2"/>
                                        <CheckBox Content="Duration" IsChecked="{Binding IsDurationVisible, Mode=TwoWay}" Style="{StaticResource ModernCheckBox}" Margin="0,2"/>
                                        <CheckBox Content="Assigned To" IsChecked="{Binding IsAssignedVisible, Mode=TwoWay}" Style="{StaticResource ModernCheckBox}" Margin="0,2"/>
                                    </StackPanel>
                                </Border>
                            </Popup>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Tasks Grid -->
            <Border Grid.Row="2"  Style="{StaticResource GlassCard}" Padding="0" CornerRadius="0" Margin="10,0,10,10">
                <Grid>
                    <!-- Empty State -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="{Binding HasTasks, Converter={StaticResource VisibilityConverter}, ConverterParameter='Invert'}">
                        <Path Data="{StaticResource IconCheckCircle}" Fill="{StaticResource TextSub}" Width="48" Height="48" Stretch="Uniform" Opacity="0.5"/>
                        <TextBlock Text="No tasks found for this project" Foreground="{StaticResource TextSub}" FontSize="16" Margin="0,20,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <DataGrid ItemsSource="{Binding Tasks}"
                              SelectedItem="{Binding SelectedTask}"
                              Visibility="{Binding HasTasks, Converter={StaticResource VisibilityConverter}}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              Background="Transparent"
                              BorderThickness="0"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#0DFFFFFF"
                              RowBackground="Transparent"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              ScrollViewer.CanContentScroll="False"
                              CanUserAddRows="False">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                                <Setter Property="ap:CommandProperties.DoubleClickCommand" Value="{Binding Data.EditTaskCommand, Source={StaticResource Proxy}}"/>
                                <Setter Property="ContextMenu">
                                    <Setter.Value>
                                         <ContextMenu x:Name="TaskContextMenu">
                                            <MenuItem Header="Create Sub-task" 
                                                      Command="{Binding Data.CreateSubtaskCommand, Source={StaticResource Proxy}}" 
                                                      CommandParameter="{Binding}">
                                                <MenuItem.Icon>
                                                    <Path Data="{StaticResource IconPlus}" Fill="White" Width="12" Height="12" Stretch="Uniform" Opacity="0.7"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <Separator />
                                            <MenuItem Header="Edit Task" 
                                                      Command="{Binding Data.EditTaskCommand, Source={StaticResource Proxy}}" 
                                                      CommandParameter="{Binding}">
                                                <MenuItem.Icon>
                                                    <Path Data="{StaticResource IconEdit}" Fill="White" Width="12" Height="12" Stretch="Uniform" Opacity="0.7"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="Delete Task" 
                                                      Command="{Binding Data.DeleteTaskCommand, Source={StaticResource Proxy}}" 
                                                      CommandParameter="{Binding}"
                                                      Foreground="{StaticResource ErrorRed}">
                                                <MenuItem.Icon>
                                                    <Path Data="{StaticResource IconTrash}" Fill="{StaticResource ErrorRed}" Width="12" Height="12" Stretch="Uniform" Opacity="0.7"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <Separator />
                                            <MenuItem Header="Assign To..." 
                                                      Command="{Binding Data.ShowAssignToCommand, Source={StaticResource Proxy}}" 
                                                      CommandParameter="{Binding}">
                                                <MenuItem.Icon>
                                                    <Path Data="{StaticResource IconTeam}" Fill="White" Width="12" Height="12" Stretch="Uniform" Opacity="0.7"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                        </ContextMenu>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <!-- Status Indicator -->
                            <DataGridTemplateColumn Header="STATUS" Width="Auto">
                                 <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Ellipse Width="8" Height="8" Grid.Column="0" VerticalAlignment="Center"
                                                 Fill="{Binding StatusColor}">
                                            <Ellipse.ToolTip>
                                                <ToolTip Visibility="{Binding IsOnHold, Converter={StaticResource VisibilityConverter}}"
                                                         Background="{StaticResource BackgroundDark}"
                                                         BorderBrush="{StaticResource SecondaryGold}"
                                                         BorderThickness="1"
                                                         Padding="10">
                                                    <StackPanel>
                                                        <TextBlock Text="ON HOLD" FontWeight="Bold" Foreground="{StaticResource SecondaryGold}" FontSize="12" Margin="0,0,0,4"/>
                                                        <TextBlock Text="{Binding HoldReason}" Foreground="White" MaxWidth="300" TextWrapping="Wrap" FontSize="11" Opacity="0.9"/>
                                                    </StackPanel>
                                                </ToolTip>
                                            </Ellipse.ToolTip>
                                        </Ellipse>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Task Name -->
                            <DataGridTemplateColumn Header="TASK NAME" Width="Auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="{Binding IndentLevel, Converter={StaticResource LevelToIndentConverter}}">
                                            <!-- Expander Button -->
                                            <Button Style="{StaticResource ExpanderButtonStyle}"
                                                    Command="{Binding Data.ToggleExpandCommand, Source={StaticResource Proxy}}"
                                                    CommandParameter="{Binding}"
                                                    Margin="0,0,8,0"
                                                    Visibility="{Binding HasChildren, Converter={StaticResource VisibilityConverter}}">
                                                <Path Data="{StaticResource IconChevronRight}" 
                                                      Fill="White" Opacity="0.5" 
                                                      Width="10" Height="10" Stretch="Uniform"
                                                      RenderTransformOrigin="0.5,0.5">
                                                    <Path.RenderTransform>
                                                        <RotateTransform Angle="{Binding IsExpanded, Converter={StaticResource RotationConverter}}"/>
                                                    </Path.RenderTransform>
                                                </Path>
                                            </Button>

                                            <TextBlock Text="{Binding Name}" Foreground="White" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="START DATE" Binding="{Binding StartDate, StringFormat=\{0:dd MMM yyyy\}}" Width="Auto" Visibility="{Binding Data.IsStartVisible, Source={StaticResource Proxy}, Converter={StaticResource VisibilityConverter}}"/>
                            <DataGridTextColumn Header="END DATE" Binding="{Binding FinishDate, StringFormat=\{0:dd MMM yyyy\}}" Width="Auto" Visibility="{Binding Data.IsEndVisible, Source={StaticResource Proxy}, Converter={StaticResource VisibilityConverter}}"/>
                            
                            <!-- Status -->
                            <DataGridTemplateColumn Header="STAGE" Width="Auto" Visibility="{Binding Data.IsStageVisible, Source={StaticResource Proxy}, Converter={StaticResource VisibilityConverter}}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding StatusColor}" Opacity="0.8" CornerRadius="4" Padding="8,2" HorizontalAlignment="Left">
                                            <Border.ToolTip>
                                                <ToolTip Visibility="{Binding IsOnHold, Converter={StaticResource VisibilityConverter}}">
                                                    <StackPanel>
                                                        <TextBlock Text="ON HOLD" FontWeight="Bold" Foreground="{StaticResource SecondaryGold}"/>
                                                        <TextBlock Text="{Binding HoldReason}" MaxWidth="300" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </ToolTip>
                                            </Border.ToolTip>
                                            <TextBlock Text="{Binding Status, Converter={StaticResource FriendlyEnumConverter}}" Foreground="Black" FontSize="11" FontWeight="SemiBold"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Progress -->
                            <DataGridTemplateColumn Header="PROGRESS" Width="Auto" MinWidth="150" Visibility="{Binding Data.IsProgressVisible, Source={StaticResource Proxy}, Converter={StaticResource VisibilityConverter}}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel VerticalAlignment="Center" Margin="0,0,20,0">
                                            <ProgressBar Value="{Binding PercentComplete}" Height="4" BorderThickness="0" Background="#15FFFFFF" Foreground="{StaticResource SuccessGreen}"/>
                                            <TextBlock Text="{Binding PercentComplete, StringFormat='{}{0}%'}" Foreground="{StaticResource TextSub}" FontSize="10" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="DURATION" Binding="{Binding Duration}" Width="Auto" Visibility="{Binding Data.IsDurationVisible, Source={StaticResource Proxy}, Converter={StaticResource VisibilityConverter}}"/>
                            <DataGridTemplateColumn Header="ASSIGNED TO" Width="Auto" Visibility="{Binding Data.IsAssignedVisible, Source={StaticResource Proxy}, Converter={StaticResource VisibilityConverter}}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource ListActionButtonStyle}" 
                                                Command="{Binding Data.ShowAssignToCommand, Source={StaticResource Proxy}}" 
                                                CommandParameter="{Binding}"
                                                HorizontalContentAlignment="Left">
                                            <Grid>
                                                <TextBlock Text="{Binding AssignedTo}" Foreground="White" Opacity="0.8" TextTrimming="CharacterEllipsis" MaxWidth="200"
                                                           Visibility="{Binding AssignedTo, Converter={StaticResource StringToVisibilityConverter}}"/>
                                                <TextBlock Text="Unassigned" Foreground="{StaticResource TextSub}" FontStyle="Italic" 
                                                           Visibility="{Binding AssignedTo, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter='Invert'}"/>
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>



                            <!-- Actions -->
                            <DataGridTemplateColumn Header="ACTIONS" Width="Auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,10,0">
                                            <Button Style="{StaticResource IconButtonSmall}" 
                                                    Command="{Binding Data.CreateSubtaskCommand, Source={StaticResource Proxy}}" 
                                                    CommandParameter="{Binding}"
                                                    ToolTip="Create Sub-task"
                                                    Margin="0,0,6,0">
                                                <Path Data="{StaticResource IconPlus}" Fill="White" Width="14" Height="14" Stretch="Uniform" Opacity="0.6"/>
                                            </Button>

                                            <Button Style="{StaticResource IconButtonSmall}" 
                                                    Command="{Binding Data.ShowAssignToCommand, Source={StaticResource Proxy}}" 
                                                    CommandParameter="{Binding}"
                                                    ToolTip="Assign Resources"
                                                    Margin="0,0,6,0">
                                                <Path Data="{StaticResource IconTeam}" Fill="White" Width="14" Height="14" Stretch="Uniform" Opacity="0.6"/>
                                            </Button>

                                            <Button Style="{StaticResource IconButtonSmall}" 
                                                    Command="{Binding Data.EditTaskCommand, Source={StaticResource Proxy}}" 
                                                    CommandParameter="{Binding}"
                                                    ToolTip="Edit Task"
                                                    Margin="0,0,6,0">
                                                <Path Data="{StaticResource IconEdit}" Fill="White" Width="14" Height="14" Stretch="Uniform" Opacity="0.6"/>
                                            </Button>

                                            <Button Style="{StaticResource IconButtonSmall}" 
                                                    Command="{Binding Data.DeleteTaskCommand, Source={StaticResource Proxy}}" 
                                                    CommandParameter="{Binding}"
                                                    ToolTip="Delete Task"
                                                    Margin="0">
                                                <Path Data="{StaticResource IconTrash}" Fill="{StaticResource ErrorRed}" Width="14" Height="14" Stretch="Uniform" Opacity="0.6"/>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <!-- Drawer Overlay -->
        <ContentControl Content="{Binding CurrentTaskDetail}" Visibility="{Binding CurrentTaskDetail, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter='Invert'}">
            <ContentControl.Resources>
                <DataTemplate DataType="{x:Type vm:TaskDetailViewModel}">
                    <local:TaskDetailView />
                </DataTemplate>
            </ContentControl.Resources>
        </ContentControl>

        <!-- Assignment Popup Overlay -->
        <Grid Panel.ZIndex="1100" Visibility="{Binding IsAssignPopupOpen, Converter={StaticResource VisibilityConverter}}">
            <Border Background="Black" Opacity="0.5">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding CloseAssignPopupCommand}"/>
                </Border.InputBindings>
            </Border>
            
            <Border Style="{StaticResource GlassCard}" Width="480" MaxHeight="600" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="25">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <Path Data="{StaticResource IconTeam}" Fill="{StaticResource AccentBlue}" Width="20" Height="20" Stretch="Uniform" Margin="0,0,12,0"/>
                        <TextBlock Text="ASSIGN TASK" FontSize="18" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Grid.Row="0" Text="{Binding TaskToAssign.Name}" FontSize="12" Foreground="{StaticResource TextSub}" 
                               Margin="0,0,0,20" VerticalAlignment="Top" HorizontalAlignment="Right" FontWeight="SemiBold"/>

                    <!-- Search & Filters -->
                    <Grid Grid.Row="1" Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="160"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding SubContractorSearchQuery, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource ModernInput}" Height="36" Margin="0,0,10,0"
                                 ap:WatermarkProperties.Watermark="Search contractors..."/>
                        <ComboBox Grid.Column="1" ItemsSource="{Binding AvailableSpecialties}" SelectedItem="{Binding SelectedSpecialtyFilter}"
                                  Style="{StaticResource ModernComboBox}" Height="36"/>
                    </Grid>

                    <!-- List -->
                    <ListBox Grid.Row="2" ItemsSource="{Binding AvailableSubContractors}" 
                             Background="Transparent" BorderThickness="0" 
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             MaxHeight="350">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Focusable" Value="False"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border Background="{TemplateBinding Background}" Visibility="{Binding IsVisible, Converter={StaticResource VisibilityConverter}}">
                                                <ContentPresenter/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#0DFFFFFF" Margin="0,0,0,5" Padding="12,10" CornerRadius="8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox IsChecked="{Binding IsSelected}" Style="{StaticResource ModernCheckBox}" VerticalAlignment="Center" Margin="0,0,15,0"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" Foreground="White" FontWeight="SemiBold" FontSize="14"/>
                                            <TextBlock Text="{Binding Specialty}" Foreground="{StaticResource TextSub}" FontSize="11" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <Border Grid.Column="2" Width="10" Height="10" CornerRadius="5" Background="{Binding Color}" VerticalAlignment="Center"
                                                Visibility="{Binding Color, Converter={StaticResource StringToVisibilityConverter}}">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="White" Opacity="0.3"/>
                                            </Border.Effect>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Footer -->
                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                        <Button Content="Cancel" Command="{Binding CloseAssignPopupCommand}" Style="{StaticResource ActionButtonSecondary}" Width="100" Margin="0,0,12,0"/>
                        <Button Content="Save Assignments" Command="{Binding SaveAssignmentsCommand}" Style="{StaticResource ActionButtonPrimary}" Width="160"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>



