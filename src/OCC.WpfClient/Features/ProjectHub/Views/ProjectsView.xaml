<UserControl x:Class="OCC.WpfClient.Features.ProjectHub.Views.ProjectsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:OCC.WpfClient.Features.ProjectHub.ViewModels"
             xmlns:views="clr-namespace:OCC.WpfClient.Features.ProjectHub.Views"
             xmlns:ap="clr-namespace:OCC.WpfClient.Infrastructure.AttachedProperties"
             xmlns:infra="clr-namespace:OCC.WpfClient.Infrastructure"
             xmlns:conv="clr-namespace:OCC.WpfClient.Infrastructure.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200"
             d:DataContext="{d:DesignInstance Type=vm:ProjectsViewModel}">
    <UserControl.Resources>
        <DataTemplate DataType="{x:Type vm:CreateProjectViewModel}">
            <views:CreateProjectView/>
        </DataTemplate>
        <infra:BindingProxy x:Key="Proxy" Data="{Binding}" />
        <conv:VisibilityConverter x:Key="VisibilityConverter" />
    </UserControl.Resources>

    <Grid Background="{StaticResource AppBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="Auto"/> <!-- Filters -->
            <RowDefinition Height="*"/>    <!-- Grid -->
        </Grid.RowDefinitions>

         <!-- Header Section -->
        <Grid Grid.Row="0" Margin="20,20,20,0">
            <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center">
                <TextBlock Text="Projects" FontSize="26" FontWeight="Bold" Foreground="White" />
                <TextBlock Text="Monitor and manage all active design and construction projects." Style="{StaticResource FormLabelText}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Command="{Binding AddProjectCommand}" Style="{StaticResource PrimaryButton}" Height="36" Padding="20,0">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource IconPlus}" Fill="White" Width="12" Height="12" Stretch="Uniform" Margin="0,0,10,0"/>
                        <TextBlock Text="Create New Project" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Filters & Stats Line -->
        <Border Grid.Row="1" Style="{StaticResource GlassCard}" Padding="15,10" Margin="20,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" /> <!-- Search Icon -->
                    <ColumnDefinition Width="250" />  <!-- Search Box -->
                    <ColumnDefinition Width="Auto" /> <!-- Divider -->
                    <ColumnDefinition Width="Auto" /> <!-- Refresh -->
                    <ColumnDefinition Width="Auto" /> <!-- Columns -->
                    <ColumnDefinition Width="*" />    <!-- Spacer -->
                </Grid.ColumnDefinitions>

                <!-- Search -->
                <Path Grid.Column="0" Data="{StaticResource IconSearch}" Fill="{StaticResource TextSub}" Width="14" Height="14" Margin="5,0,10,0" VerticalAlignment="Center" Stretch="Uniform"/>
                <TextBox Grid.Column="1" Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource ModernInput}" Height="32" Padding="8,0" BorderThickness="0" Background="Transparent"
                         ap:WatermarkProperties.Watermark="Search projects..."/>

                <Border Grid.Column="2" Width="1" Height="20" Background="{StaticResource GlassBorder}" Margin="15,0" VerticalAlignment="Center"/>

                <Button Grid.Column="3" Command="{Binding LoadDataAsyncCommand}" Style="{StaticResource ToolbarIconButton}" ToolTip="Refresh Data" Margin="0,0,15,0">
                    <Path Data="{StaticResource IconRefresh}" Fill="White" Width="18" Height="18" Stretch="Uniform" Opacity="0.6"/>
                </Button>

                <!-- Columns Selection -->
                <Grid Grid.Column="4">
                    <ToggleButton x:Name="ColumnsToggle" Style="{StaticResource ToolbarToggleButton}" Width="100" Height="32">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconList}" Fill="White" Width="14" Height="14" Stretch="Uniform" Margin="0,0,8,0" Opacity="0.8"/>
                            <TextBlock Text="COLUMNS" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                        </StackPanel>
                    </ToggleButton>
                    <Popup IsOpen="{Binding IsChecked, ElementName=ColumnsToggle}" StaysOpen="False" PlacementTarget="{Binding ElementName=ColumnsToggle}" Placement="Bottom" AllowsTransparency="True" PopupAnimation="Fade">
                        <Border Background="{StaticResource BackgroundDark}" BorderBrush="{StaticResource GlassBorder}" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,5,0,0" Width="200">
                            <StackPanel>
                                <TextBlock Text="DISPLAY COLUMNS" FontSize="10" FontWeight="Bold" Foreground="{StaticResource AccentBlue}" Margin="0,0,0,8"/>
                                <CheckBox Content="Progress" IsChecked="{Binding IsProgressVisible, Mode=TwoWay}" Style="{StaticResource ModernCheckBox}" Margin="0,2"/>
                                <CheckBox Content="Site Manager" IsChecked="{Binding IsManagerVisible, Mode=TwoWay}" Style="{StaticResource ModernCheckBox}" Margin="0,2"/>
                                <CheckBox Content="Latest Update" IsChecked="{Binding IsUpdateVisible, Mode=TwoWay}" Style="{StaticResource ModernCheckBox}" Margin="0,2"/>
                                <CheckBox Content="Status" IsChecked="{Binding IsStatusVisible, Mode=TwoWay}" Style="{StaticResource ModernCheckBox}" Margin="0,2"/>
                            </StackPanel>
                        </Border>
                    </Popup>
                </Grid>
                
                <Button Command="{Binding PrintCommand}" Style="{StaticResource ToolbarButton}" Margin="10,0" Grid.Column="5">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource IconPrint}" Fill="White" Width="14" Height="14" Stretch="Uniform" Margin="0,0,8,0" Opacity="0.8"/>
                        <TextBlock Text="PRINT" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Data Grid -->
        <Border Grid.Row="2" Margin="20,0,20,20" Background="{StaticResource CardBackground}" CornerRadius="0" Padding="1">
            <Grid>
                <!-- Empty State -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" 
                            Visibility="{Binding Items.Count, Converter={StaticResource VisibilityConverter}, ConverterParameter=Invert}">
                    <Path Data="{StaticResource IconDatabase}" Fill="{StaticResource TextSub}" Opacity="0.1" Width="80" Height="80" Stretch="Uniform" Margin="0,0,0,20"/>
                    <TextBlock Text="No Projects Found" FontSize="18" Foreground="{StaticResource TextSub}" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Grid -->
                <DataGrid ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedItem}" 
                          AutoGenerateColumns="False" IsReadOnly="True" 
                          Style="{StaticResource ModernDataGrid}" 
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.CanContentScroll="False"
                          Visibility="{Binding Items.Count, Converter={StaticResource VisibilityConverter}}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="NAME" Binding="{Binding Name}" Width="Auto" />
                        
                        <DataGridTemplateColumn Header="PROGRESS" Width="Auto" MinWidth="150" Visibility="{Binding Data.IsProgressVisible, Source={StaticResource Proxy}, Converter={StaticResource VisibilityConverter}}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid VerticalAlignment="Center" Margin="10,0">
                                        <ProgressBar Value="{Binding Progress}" Maximum="100" Height="6" 
                                                     Background="#1AFFFFFF" BorderThickness="0" 
                                                     Foreground="{StaticResource AccentBlue}"/>
                                        <TextBlock Text="{Binding Progress, StringFormat='{}{0}%'}" 
                                                   FontSize="10" Foreground="White" 
                                                   HorizontalAlignment="Right" VerticalAlignment="Top" 
                                                   Margin="0,-12,0,0"/>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="SITE MANAGER" Width="Auto" Visibility="{Binding Data.IsManagerVisible, Source={StaticResource Proxy}, Converter={StaticResource VisibilityConverter}}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Width="30" Height="30" CornerRadius="15" Margin="20,0"
                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Background="{Binding SiteManagerName, Converter={StaticResource UserColorConverter}}"
                                            ToolTip="{Binding SiteManagerName}">
                                        <TextBlock Text="{Binding SiteManagerName, Converter={StaticResource UserInitialsConverter}}" 
                                                   VerticalAlignment="Center" HorizontalAlignment="Center" 
                                                   Foreground="White" FontSize="11" FontWeight="Bold"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="LATEST UPDATE" Binding="{Binding LatestFinish, StringFormat='{}{0:d}'}" Width="Auto" Visibility="{Binding Data.IsUpdateVisible, Source={StaticResource Proxy}, Converter={StaticResource VisibilityConverter}}"/>
                        
                        <DataGridTemplateColumn Header="STATUS" Width="Auto" Visibility="{Binding Data.IsStatusVisible, Source={StaticResource Proxy}, Converter={StaticResource VisibilityConverter}}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="#1AFFFFFF" Padding="8,4" CornerRadius="4" HorizontalAlignment="Left" Margin="10,0">
                                        <TextBlock Text="{Binding Status, Converter={StaticResource FriendlyEnumConverter}}" Foreground="White" FontSize="12"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="ACTIONS" Width="Auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button Command="{Binding DataContext.OpenProjectCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                    CommandParameter="{Binding}" Style="{StaticResource ToolbarIconButton}" Margin="5" ToolTip="Open Project Dashboard">
                                                <Path Data="{StaticResource IconExternalLink}" Fill="White" Width="14" Height="14" Stretch="Uniform" Opacity="0.8"/>
                                            </Button>
                                            <Button Command="{Binding DataContext.EditProjectCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                    CommandParameter="{Binding}" Style="{StaticResource ToolbarIconButton}" Margin="5" ToolTip="Edit">
                                                <Path Data="{StaticResource IconEdit}" Fill="{StaticResource AccentBlue}" Width="14" Height="14" Stretch="Uniform"/>
                                            </Button>
                                            <Button Command="{Binding DataContext.DeleteProjectCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                    CommandParameter="{Binding}" Style="{StaticResource ToolbarIconButton}" Margin="5" ToolTip="Delete">
                                                <Path Data="{StaticResource IconTrash}" Fill="{StaticResource ErrorRed}" Width="14" Height="14" Stretch="Uniform"/>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                                <!-- Use Tag to bridge the ViewModel to the ContextMenu -->
                                <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                                <Setter Property="ap:CommandProperties.DoubleClickCommand" 
                                        Value="{Binding DataContext.OpenProjectCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                                <Setter Property="ap:CommandProperties.CommandParameter" Value="{Binding}"/>
                                <Setter Property="ContextMenu">
                                    <Setter.Value>
                                        <ContextMenu Style="{StaticResource ModernContextMenu}">
                                            <MenuItem Header="Open Dashboard" 
                                                      Command="{Binding Path=PlacementTarget.Tag.OpenProjectCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding}">
                                                <MenuItem.Icon>
                                                    <Path Data="{StaticResource IconExternalLink}" Fill="White" Width="12" Height="12" Stretch="Uniform"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="Edit Project" 
                                                      Command="{Binding Path=PlacementTarget.Tag.EditProjectCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding}">
                                                <MenuItem.Icon>
                                                    <Path Data="{StaticResource IconEdit}" Fill="{StaticResource AccentBlue}" Width="12" Height="12" Stretch="Uniform"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <Separator Style="{x:Null}" Visibility="Collapsed"/> <!-- Invisible separator placeholder -->
                                            <MenuItem Header="Delete Project" 
                                                      Tag="HasSeparator"
                                                      Command="{Binding Path=PlacementTarget.Tag.DeleteProjectCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding}"
                                                      Foreground="{StaticResource ErrorRed}">
                                                <MenuItem.Icon>
                                                    <Path Data="{StaticResource IconTrash}" Fill="{StaticResource ErrorRed}" Width="12" Height="12" Stretch="Uniform"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                        </ContextMenu>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGrid.RowStyle>
                    </DataGrid>

                <!-- Loading Overlay -->
                <Border Background="#40000000" Visibility="{Binding IsBusy, Converter={StaticResource VisibilityConverter}}" CornerRadius="15">
                    <ProgressBar IsIndeterminate="True" Width="200" Height="4" Foreground="{StaticResource AccentBlue}"/>
                </Border>

                <!-- Create Project Overlay -->
                <Border Background="#99000000" Visibility="{Binding IsOverlayVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ContentControl Content="{Binding OverlayViewModel}" VerticalAlignment="Center" HorizontalAlignment="Stretch" Margin="20"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>





