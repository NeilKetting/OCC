<UserControl x:Class="OCC.WpfClient.Features.ProjectHub.Views.ProjectHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OCC.WpfClient.Features.ProjectHub.Views"
             xmlns:vm="clr-namespace:OCC.WpfClient.Features.ProjectHub.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="480" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance vm:ProjectHistoryViewModel}">
    
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/Common.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,25">
            <TextBlock Text="Project History" FontSize="24" FontWeight="Bold" Foreground="White"/>
            <TextBlock Text="Historical record of all personnel and contractors who have contributed to this project." 
                       Style="{StaticResource FormLabelText}"/>
        </StackPanel>

        <!-- History Table -->
        <Border Grid.Row="1" Style="{StaticResource GlassCard}" Padding="1" CornerRadius="0">
            <Grid>
                <DataGrid ItemsSource="{Binding Entries}" 
                          AutoGenerateColumns="False" 
                          IsReadOnly="True"
                          Background="Transparent"
                          BorderThickness="0"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#10FFFFFF">
                    <DataGrid.Columns>
                        <!-- Name & Role -->
                        <DataGridTemplateColumn Header="PERSONNEL" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="15,10">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="White" FontSize="14"/>
                                        <TextBlock Text="{Binding Role}" FontSize="11" Foreground="{StaticResource TextSub}" Opacity="0.8"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Type Tag -->
                        <DataGridTemplateColumn Header="TYPE" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="10" Padding="8,2" HorizontalAlignment="Left" Margin="10,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#2060A5FA"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Type}" Value="Contractor">
                                                        <Setter Property="Background" Value="#20F59E0B"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Type}" FontSize="10" FontWeight="Bold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource AccentBlue}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Type}" Value="Contractor">
                                                            <Setter Property="Foreground" Value="{StaticResource SecondaryGold}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Work Stats -->
                        <DataGridTextColumn Header="DAYS WORKED" Binding="{Binding DaysWorked}" Width="Auto">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="TASKS" Binding="{Binding TasksAssigned}" Width="Auto">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Timeline -->
                        <DataGridTextColumn Header="FIRST ACTIVE" Binding="{Binding FirstActive, StringFormat=\{0:dd MMM yyyy\}}" Width="Auto">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource TextSub}"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="LAST ACTIVE" Binding="{Binding LastActive, StringFormat=\{0:dd MMM yyyy\}}" Width="Auto">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource TextSub}"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Loading Overlay -->
                <Border Background="#80000000" Visibility="{Binding IsLoading, Converter={StaticResource VisibilityConverter}}">
                    <StackPanel VerticalAlignment="Center">
                        <ProgressBar IsIndeterminate="True" Width="200" Height="4" Background="Transparent" Foreground="{StaticResource AccentBlue}"/>
                        <TextBlock Text="Compiling project history..." Foreground="White" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="No personnel history recorded for this project yet." 
                           Foreground="{StaticResource TextSub}" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center"
                           Visibility="{Binding Entries.Count, Converter={StaticResource VisibilityConverter}, ConverterParameter=Invert}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
