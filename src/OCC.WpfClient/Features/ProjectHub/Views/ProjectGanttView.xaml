<UserControl x:Class="OCC.WpfClient.Features.ProjectHub.Views.ProjectGanttView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OCC.WpfClient.Features.ProjectHub.Views"
             xmlns:vm="clr-namespace:OCC.WpfClient.Features.ProjectHub.ViewModels"
             xmlns:conv="clr-namespace:OCC.WpfClient.Infrastructure.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000"
             d:DataContext="{d:DesignInstance Type=vm:ProjectGanttViewModel}">

    <UserControl.Resources>
        <conv:VisibilityConverter x:Key="VisibilityConverter" />
        
        <!-- Summary Task Bar Style -->
        <Style x:Key="SummaryBarStyle" TargetType="Border">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#1E80D6" Offset="0"/>
                        <GradientStop Color="#0D47A1" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Height" Value="10"/>
            <Setter Property="CornerRadius" Value="1"/>
            <Setter Property="Margin" Value="0,5,0,0"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.4"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Leaf Task Bar Style -->
        <Style x:Key="LeafBarStyle" TargetType="Border">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="{StaticResource AccentBlueHoverColor}" Offset="0"/>
                        <GradientStop Color="{StaticResource AccentBlueColor}" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Height" Value="16"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.3"/>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Menu Bar -->
        <local:GanttMenuBarView Grid.Row="0"/>

        <!-- Main Content Layout -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Date Header -->
                <RowDefinition Height="*"/>    <!-- Content -->
            </Grid.RowDefinitions>
            
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" MinWidth="200"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*" MinWidth="150"/>
            </Grid.ColumnDefinitions>

            <!-- Row 0: Headers -->
            <Border Grid.Row="0" Grid.Column="0" BorderBrush="{StaticResource GlassBorderUltraLight}" BorderThickness="0,0,1,1" Background="{StaticResource GlassBackgroundSubtle}" Height="35">
                <TextBlock Text="TASK NAME" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextSub}" VerticalAlignment="Center" Margin="15,0"/>
            </Border>
            
            <!-- Date Headers ScrollViewer -->
            <ScrollViewer Grid.Row="0" Grid.Column="2" Name="HeaderScrollViewer" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding DateHeaders}" Width="{Binding CanvasWidth}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas Height="35" Background="{StaticResource GlassBackgroundSubtle}"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="{Binding Left}"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:GanttDateHeader}">
                            <Border Width="{Binding Width}" Height="35" BorderBrush="{StaticResource GlassBorderUltraLight}" BorderThickness="0,0,1,1">
                                <TextBlock Text="{Binding Text}" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{StaticResource TextSub}"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Row 1: Content -->
            <!-- Task List (Left) -->
            <ScrollViewer Grid.Row="1" Grid.Column="0" Name="TaskListScrollViewer" HorizontalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding GanttTasks}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas Height="{Binding DataContext.CanvasHeight, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Top" Value="{Binding RowTop}"/>
                            <Setter Property="Width" Value="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ScrollViewer}}"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:GanttTaskWrapper}">
                            <Border x:Name="TaskRowBorder" Height="{Binding RowHeight}" BorderBrush="{StaticResource GlassBorderUltraLight}" BorderThickness="0,0,0,1" Background="Transparent">
                                <StackPanel Orientation="Horizontal" Margin="{Binding IndentMargin}">
                                    <!-- Expander Button -->
                                    <Button Style="{StaticResource ToolbarIconButton}" 
                                            Command="{Binding ToggleCommand}" 
                                            Width="20" Height="20" 
                                            Margin="5,0,5,0"
                                            Visibility="{Binding HasChildren, Converter={StaticResource VisibilityConverter}}">
                                        <Grid>
                                            <Path Data="{StaticResource IconChevronDown}" Width="10" Height="10" Fill="White" Stretch="Uniform" Opacity="0.5"
                                                  Visibility="{Binding Task.IsExpanded, Converter={StaticResource VisibilityConverter}}"/>
                                            <Path Data="{StaticResource IconChevronRight}" Width="10" Height="10" Fill="White" Stretch="Uniform" Opacity="0.5"
                                                  Visibility="{Binding Task.IsExpanded, Converter={StaticResource VisibilityConverter}, ConverterParameter=Invert}"/>
                                        </Grid>
                                    </Button>
                                    <!-- Spacer if no children -->
                                    <Border Width="30" Visibility="{Binding HasChildren, Converter={StaticResource VisibilityConverter}, ConverterParameter=Invert}"/>
                                    
                                    <TextBlock Text="{Binding Task.Name}" 
                                               VerticalAlignment="Center"
                                               Foreground="White"
                                               FontSize="12">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSummary}" Value="True">
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                        <Setter Property="Foreground" Value="{StaticResource AccentBlue}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                            <DataTemplate.Triggers>
                                <Trigger SourceName="TaskRowBorder" Property="IsMouseOver" Value="True">
                                    <Setter TargetName="TaskRowBorder" Property="Background" Value="{StaticResource GlassBackgroundHover}"/>
                                </Trigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
            
            <GridSplitter Grid.Row="1" Grid.Column="1" HorizontalAlignment="Stretch" Background="{StaticResource GlassBorderUltraLight}"/>

            <!-- Gantt Chart (Right) -->
            <ScrollViewer Grid.Row="1" Grid.Column="2" Name="GanttChartScrollViewer" HorizontalScrollBarVisibility="Auto">
                <Grid>
                    <!-- Layer 1: Background Canvas for Today Marker -->
                    <Canvas Width="{Binding CanvasWidth}" Height="{Binding CanvasHeight}" IsHitTestVisible="False">
                        <Line X1="{Binding TodayPosition}" Y1="0" X2="{Binding TodayPosition}" Y2="{Binding CanvasHeight}" 
                              Stroke="{StaticResource AccentBlue}" StrokeThickness="2" StrokeDashArray="2 2" Opacity="0.6"/>
                    </Canvas>

                    <!-- Layer 2: Vertical Grid Columns (Zebra Stripes) -->
                    <ItemsControl ItemsSource="{Binding DateHeaders}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas Width="{Binding CanvasWidth}" Height="{Binding CanvasHeight}" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding ColumnLeft}"/>
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:GanttDateHeader}">
                                <Border Width="{Binding Width}" 
                                        Height="{Binding DataContext.CanvasHeight, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                        BorderBrush="{StaticResource GlassBorderUltraLight}" 
                                        BorderThickness="0,0,1,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsAlternate}" Value="True">
                                                    <Setter Property="Background" Value="#05FFFFFF"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    
                    <!-- Layer 3: Dependencies -->
                    <ItemsControl ItemsSource="{Binding Dependencies}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas Width="{Binding CanvasWidth}" Height="{Binding CanvasHeight}" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:GanttDependencyLine}">
                                <Canvas>
                                    <!-- Connector Line -->
                                    <Path Data="{Binding PathGeometry}" Stroke="#999999" StrokeThickness="2" />
                                    <!-- Arrowhead -->
                                    <Path Data="{Binding ArrowGeometry}" Fill="#999999" StrokeThickness="0" />
                                </Canvas>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Layer 4: Tasks -->
                    <ItemsControl ItemsSource="{Binding GanttTasks}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas Width="{Binding CanvasWidth}" Height="{Binding CanvasHeight}" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding Left}" />
                                <Setter Property="Canvas.Top" Value="{Binding Top}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:GanttTaskWrapper}">
                                <StackPanel Orientation="Horizontal" Height="{Binding Height}">
                                    <Border Width="{Binding Width}">
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource LeafBarStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSummary}" Value="True">
                                                        <Setter Property="Background">
                                                            <Setter.Value>
                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                                    <GradientStop Color="#1E80D6" Offset="0"/>
                                                                    <GradientStop Color="#0D47A1" Offset="1"/>
                                                                </LinearGradientBrush>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Setter Property="Height" Value="10"/>
                                                        <Setter Property="CornerRadius" Value="1"/>
                                                        <Setter Property="Margin" Value="0,5,0,0"/>
                                                        <Setter Property="Effect">
                                                            <Setter.Value>
                                                                <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.4"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    
                                    <TextBlock Text="{Binding LabelText}" 
                                               Foreground="White"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               Padding="5,0,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSummary}" Value="True">
                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
