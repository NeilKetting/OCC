<UserControl x:Class="OCC.WpfClient.Features.ProjectHub.Views.CreateProjectView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:OCC.WpfClient.Features.ProjectHub.ViewModels"
             xmlns:models="clr-namespace:OCC.WpfClient.Features.ProjectHub.Models"
             xmlns:ap="clr-namespace:OCC.WpfClient.Infrastructure.AttachedProperties"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1100"
             d:DataContext="{d:DesignInstance Type=vm:CreateProjectViewModel}">

    <Border Background="{StaticResource CardBackground}" BorderBrush="{StaticResource OrangeBrush}"
            BorderThickness="1"
            CornerRadius="20" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="10" Opacity="0.5"/>
        </Border.Effect>
        <Grid>
            <!-- Main Content Container -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left Panel: Quick Create -->
                <Grid Grid.Column="0" Margin="15,10,15,15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Header -->
                        <RowDefinition Height="Auto"/>
                        <!-- Mode Switch -->
                        <RowDefinition Height="*"/>
                        <!-- Form -->
                        <RowDefinition Height="Auto"/>
                        <!-- Footer -->
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,15">
                        <TextBlock Text="Create New Project" FontSize="26" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Quickly create maintenance jobs or comprehensive projects." 
                                   FontSize="14" Foreground="{StaticResource TextSub}" Margin="0,0,0,0"/>
                    </StackPanel>

                    <!-- Mode Switcher -->
                    <Border Grid.Row="1" Background="{StaticResource InputBackground}" 
                            CornerRadius="10" Padding="4" HorizontalAlignment="Left" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <RadioButton Style="{StaticResource PremiumRadioButtonStyle}" Content="Job (Quick)" 
                                         IsChecked="{Binding CreationMode, Converter={StaticResource EqualityConverter}, ConverterParameter={x:Static models:ProjectCreationMode.Quick}}"/>
                            <RadioButton Style="{StaticResource PremiumRadioButtonStyle}" Content="Full Project" 
                                         IsChecked="{Binding CreationMode, Converter={StaticResource EqualityConverter}, ConverterParameter={x:Static models:ProjectCreationMode.Comprehensive}}"/>
                        </StackPanel>
                    </Border>

                    <!-- Form -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="0,0,15,0">
                        <StackPanel>
                            <!-- Basic Info -->
                            <StackPanel Margin="0,0,0,20">
                                <TextBlock Text="PROJECT NAME" Style="{StaticResource LabelText}"/>
                                <TextBox Text="{Binding Project.Name, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" 
                                         Style="{StaticResource ModernInput}" 
                                         ap:WatermarkProperties.Watermark="e.g. Engen Bendor"/>
                            </StackPanel>

                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                    <TextBlock Text="CUSTOMER" Style="{StaticResource LabelText}"/>
                                    <ComboBox ItemsSource="{Binding Customers}" SelectedItem="{Binding SelectedCustomer}" Style="{StaticResource ModernComboBox}" DisplayMemberPath="Name" ap:WatermarkProperties.Watermark="Select customer..."/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="10,0,1,0">
                                    <TextBlock Text="SITE MANAGER" Style="{StaticResource LabelText}"/>
                                    <ComboBox ItemsSource="{Binding SiteManagers}" SelectedItem="{Binding SelectedSiteManager}" Style="{StaticResource ModernComboBox}" DisplayMemberPath="DisplayName" ap:WatermarkProperties.Watermark="Assign manager..."/>
                                </StackPanel>
                            </Grid>

                            <!-- Job Specifics -->
                            <StackPanel Margin="0,0,0,20">
                                <TextBlock Text="SHORT DESCRIPTION" Style="{StaticResource LabelText}"/>
                                <TextBox Text="{Binding Project.Description}" Height="80" TextWrapping="Wrap" AcceptsReturn="True" Style="{StaticResource ModernInput}" ap:WatermarkProperties.Watermark="Quick overview of the scope..."/>
                            </StackPanel>

                            <!-- Site Location -->
                            <Border BorderBrush="{StaticResource GlassBorderMedium}" BorderThickness="0,0,0,1" Padding="0,5" Margin="0,10,0,10">
                                <TextBlock Text="SITE LOCATION" Style="{StaticResource LabelText}" FontWeight="SemiBold"/>
                            </Border>

                            <StackPanel Margin="0,0,0,20">
                                <TextBlock Text="STREET ADDRESS" Style="{StaticResource LabelText}"/>
                                <Grid>
                                    <TextBox x:Name="AddressBox" Text="{Binding Project.StreetLine1, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernInput}" ap:WatermarkProperties.Watermark="Search for site address..."/>
                                    <Popup IsOpen="{Binding AddressSuggestions.Count, Converter={StaticResource CollectionToBooleanConverter}, Mode=OneWay}" PlacementTarget="{Binding ElementName=AddressBox}" StaysOpen="False" AllowsTransparency="True">
                                        <Border Background="{StaticResource CardBackground}" BorderBrush="{StaticResource GlassBorderMedium}" BorderThickness="1" CornerRadius="8" Width="300" MaxHeight="200">
                                            <ListBox ItemsSource="{Binding AddressSuggestions}" SelectedItem="{Binding SelectedAddressSuggestion}" Background="Transparent" BorderThickness="0">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Description}" Foreground="White" Padding="10,5"/>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </Border>
                                    </Popup>
                                </Grid>
                            </StackPanel>

                            <!-- Import Option (WPF Visibility) -->
                            <Border Visibility="{Binding IsComprehensiveMode, Converter={StaticResource BooleanToVisibilityConverter}}" Background="#1A3B82F6" BorderBrush="#803B82F6" BorderThickness="1" CornerRadius="12" Padding="20" Margin="0,10,0,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Path Data="{StaticResource IconPortfolio}" 
                                          Fill="{StaticResource AccentBlue}" 
                                          Width="32" Height="32" Stretch="Uniform" 
                                          Margin="0,0,20,0"/>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Import from MS Project" FontWeight="Bold" Foreground="White" FontSize="15"/>
                                        <TextBlock Text="Import tasks, dates and resources from .xml" TextWrapping="Wrap" Foreground="{StaticResource TextSub}" FontSize="12" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <Button Grid.Row="1" Grid.Column="2" Margin="0,10,0,0" VerticalAlignment="Bottom" HorizontalAlignment="Right" Content="Browse..." Command="{Binding BrowseImportCommand}" Style="{StaticResource SecondaryButton}" Padding="15,8"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Footer -->
                    <Grid Grid.Row="3" Margin="0,20,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Premium Validation Summary Card -->
                        <Border Grid.Row="0" Margin="0,0,0,15"
                                Background="#1AEE4444" BorderBrush="{StaticResource ErrorRed}" 
                                BorderThickness="1" CornerRadius="12" Padding="15,10">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Setter Property="Opacity" Value="0"/>
                                    <Style.Triggers>
                                        <!-- TRIGGER: Signal received from ViewModel pulse (0 -> 1) -->
                                        <DataTrigger Binding="{Binding AnimationPulse}" Value="1">
                                            <DataTrigger.EnterActions>
                                                <StopStoryboard BeginStoryboardName="PremiumErrorAnim"/>
                                                <BeginStoryboard x:Name="PremiumErrorAnim">
                                                    <Storyboard>
                                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility">
                                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Visible}"/>
                                                        </ObjectAnimationUsingKeyFrames>
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3"/>
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0" BeginTime="0:0:2.5" Duration="0:0:0.5"/>
                                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" BeginTime="0:0:3.1">
                                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Collapsed}"/>
                                                        </ObjectAnimationUsingKeyFrames>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                        </DataTrigger>

                                        <!-- Safety: Ensure it hides immediately if form becomes valid -->
                                        <DataTrigger Binding="{Binding Project.HasValidationErrors}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Setter Property="Opacity" Value="0"/>
                                            <DataTrigger.EnterActions>
                                                <StopStoryboard BeginStoryboardName="PremiumErrorAnim"/>
                                            </DataTrigger.EnterActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="15" ShadowDepth="0" Color="{StaticResource ErrorRedColor}" Opacity="0.2"/>
                            </Border.Effect>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Path Data="M12,2C6.48,2,2,6.48,2,12s4.48,10,10,10s10-4.48,10-10S17.52,2,12,2z M13,17h-2v-2h2V17z M13,13h-2V7h2V13z"
                                          Fill="{StaticResource ErrorRed}" Width="16" Height="16" Stretch="Uniform" Margin="0,0,10,0"/>
                                    <TextBlock Text="VALIDATION ERRORS" Foreground="{StaticResource ErrorRed}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                                <ItemsControl ItemsSource="{Binding Project.Errors}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" Foreground="White" FontSize="13" Margin="26,2,0,2" Opacity="0.9"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Actions -->
                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                             <Button Command="{Binding CloseCommand}" Content="Cancel" HorizontalAlignment="Right" 
                                     Style="{StaticResource SecondaryButton}" Padding="20,10"/>
                             <Button Command="{Binding CreateProjectCommand}" Content="Create Project" 
                                     HorizontalAlignment="Right" Style="{StaticResource PrimaryButton}" 
                                     Padding="20,10" FontWeight="Bold" Margin="10,0,0,0"/>
                         </StackPanel>
                     </Grid>
                </Grid>

                <!-- Right Panel: Comprehensive Details -->
                <Border Grid.Column="1" Width="500" Background="#0AFFFFFF" 
                        BorderBrush="{StaticResource GlassBorderMedium}" 
                        BorderThickness="1,0,0,0" Padding="20"
                        Visibility="{Binding IsComprehensiveMode, Converter={StaticResource BooleanToVisibilityConverter}}"
                        >
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,25,0">
                        <StackPanel>
                            <TextBlock Text="Advanced Settings" FontSize="20" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,25"/>

                            <Grid Margin="0,0,0,25">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                    <TextBlock Text="STATUS" Style="{StaticResource LabelText}"/>
                                    <ComboBox ItemsSource="{Binding Statuses}" SelectedItem="{Binding Project.Status}" Style="{StaticResource ModernComboBox}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                    <TextBlock Text="PRIORITY" Style="{StaticResource LabelText}"/>
                                    <ComboBox ItemsSource="{Binding Priorities}" SelectedItem="{Binding Project.Priority}" Style="{StaticResource ModernComboBox}"/>
                                </StackPanel>
                            </Grid>

                            <StackPanel Margin="0,0,0,25">
                                <TextBlock Text="DATES" Style="{StaticResource LabelText}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <DatePicker Grid.Column="0" SelectedDate="{Binding Project.StartDate}" Margin="0,0,10,0"/>
                                    <DatePicker Grid.Column="1" SelectedDate="{Binding Project.EndDate}" Margin="10,0,0,0"/>
                                </Grid>
                            </StackPanel>

                            <!-- Additional Address Fields -->
                            <StackPanel Margin="0,0,0,25">
                                <TextBlock Text="DETAILED LOCATION" Style="{StaticResource LabelText}" Margin="0,0,0,15"/>
                                <TextBox Text="{Binding Project.StreetLine2}" Style="{StaticResource ModernInput}" Margin="0,0,0,15" ap:WatermarkProperties.Watermark="Building, Floor, Suite..."/>
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="{Binding Project.City}" Style="{StaticResource ModernInput}" Margin="0,0,10,0" ap:WatermarkProperties.Watermark="City"/>
                                    <TextBox Grid.Column="1" Text="{Binding Project.StateOrProvince}" Style="{StaticResource ModernInput}" Margin="10,0,0,0" ap:WatermarkProperties.Watermark="Province"/>
                                </Grid>
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="{Binding Project.PostalCode}" Style="{StaticResource ModernInput}" Margin="0,0,10,0" ap:WatermarkProperties.Watermark="Postal Code"/>
                                    <TextBox Grid.Column="1" Text="{Binding Project.Country}" Style="{StaticResource ModernInput}" Margin="10,0,0,0" ap:WatermarkProperties.Watermark="Country"/>
                                </Grid>
                            </StackPanel>

                            <!-- Coordination -->
                            <StackPanel>
                                <TextBlock Text="PROJECT ID / REF" Style="{StaticResource LabelText}"/>
                                <TextBox Text="{Binding Project.ShortName}" Style="{StaticResource ModernInput}" ap:WatermarkProperties.Watermark="PROJ-001"/>
                                <TextBlock Text="Used for automatic task routing and folder structure." FontSize="11" Foreground="{StaticResource TextSub}" Margin="0,5,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- Import Overlay -->
            <Border Background="#CC000000" Visibility="{Binding IsImporting, Converter={StaticResource BooleanToVisibilityConverter}}" CornerRadius="20">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="200" Height="4" Foreground="{StaticResource AccentBlue}"/>
                    <TextBlock Text="{Binding ImportProgressMessage}" Foreground="White" Margin="0,15,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
