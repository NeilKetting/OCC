<UserControl x:Class="OCC.WpfClient.Features.ProjectHub.Views.TaskDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:OCC.WpfClient.Features.ProjectHub.ViewModels"
             xmlns:conv="clr-namespace:OCC.WpfClient.Infrastructure.Converters"
             xmlns:ap="clr-namespace:OCC.WpfClient.Infrastructure.AttachedProperties"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000"
             d:DataContext="{d:DesignInstance vm:TaskDetailViewModel}">

    <UserControl.Resources>
        <Storyboard x:Key="OpenDrawer">
            <DoubleAnimation Storyboard.TargetName="DrawerContent"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             From="600" To="0" Duration="0:0:1">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="Dimmer"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.5"/>
        </Storyboard>
        <Storyboard x:Key="CloseDrawer">
            <DoubleAnimation Storyboard.TargetName="DrawerContent"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                             To="600" Duration="0:0:1">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="Dimmer"
                             Storyboard.TargetProperty="Opacity"
                             To="0" Duration="0:0:0.5"/>
        </Storyboard>
    </UserControl.Resources>

    <Grid x:Name="RootGrid" ClipToBounds="True">
        <!-- Dimmer Overlay -->
        <Border x:Name="Dimmer" Background="#80000000" Opacity="0" MouseLeftButtonDown="Dimmer_MouseLeftButtonDown"/>

        <!-- Drawer Content -->
        <Grid x:Name="DrawerGrid" HorizontalAlignment="Right" Width="600">
            <Border x:Name="DrawerContent" Background="{StaticResource CardBackground}" BorderBrush="{StaticResource GlassBorderMedium}" BorderThickness="1,0,0,0">
                <Border.RenderTransform>
                    <TranslateTransform X="600"/>
                </Border.RenderTransform>
                
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="60"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0" BorderBrush="{StaticResource GlassBorderLight}" BorderThickness="0,0,0,1" Padding="20,0">
                        <Grid>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding Task.DisplayId}" Foreground="{StaticResource TextSub}" FontSize="12" Visibility="{Binding IsCreateMode, Converter={StaticResource VisibilityConverter}, ConverterParameter='Invert'}"/>
                                
                                <StackPanel Visibility="{Binding IsCreateMode, Converter={StaticResource VisibilityConverter}}">
                                    <TextBlock Text="Initialize Task" Foreground="White" FontSize="18" FontWeight="Bold" 
                                               Visibility="{Binding IsSubtask, Converter={StaticResource VisibilityConverter}, ConverterParameter='Invert'}"/>
                                    <StackPanel Orientation="Horizontal" Visibility="{Binding IsSubtask, Converter={StaticResource VisibilityConverter}}">
                                        <TextBlock Text="New Sub-task for:" Foreground="{StaticResource AccentBlue}" FontSize="12" FontWeight="Bold" Margin="0,0,5,0" VerticalAlignment="Bottom"/>
                                        <TextBlock Text="{Binding ParentTaskName}" Foreground="White" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Bottom"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Visibility="{Binding IsCreateMode, Converter={StaticResource VisibilityConverter}, ConverterParameter='Invert'}">
                                    <StackPanel Orientation="Horizontal" Visibility="{Binding IsSubtask, Converter={StaticResource VisibilityConverter}}">
                                        <TextBlock Text="SUBTASK NAME: " Foreground="{StaticResource AccentBlue}" FontSize="12" FontWeight="Bold" Margin="0,0,5,0" VerticalAlignment="Bottom"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Task.Name}" Foreground="White" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Bottom"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Button Style="{StaticResource IconButtonMedium}" Command="{Binding RequestCloseCommand}" Margin="10,0,0,0">
                                    <Path Data="{StaticResource IconX}" Fill="White" Width="16" Height="16" Stretch="Uniform"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Content -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,80">
                        <Border Padding="20">
                            <StackPanel>
                            <!-- Task Name (Edit) -->
                            <StackPanel Margin="0,0,0,20">
                                <TextBlock Text="TASK NAME" Style="{StaticResource LabelText}"/>
                                <TextBox Text="{Binding Task.Name, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernInput}" FontSize="18" FontWeight="SemiBold"/>
                            </StackPanel>

                            <!-- Description -->
                            <StackPanel Margin="0,0,0,20">
                                <TextBlock Text="DESCRIPTION" Style="{StaticResource LabelText}"/>
                                <TextBox Text="{Binding Task.Description, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernInput}" AcceptsReturn="True" MinHeight="100" TextWrapping="Wrap"/>
                            </StackPanel>

                            <!-- Metadata Row -->
                            <UniformGrid Columns="2" Margin="0,0,0,20">
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="STATUS" Style="{StaticResource LabelText}"/>
                                    <ComboBox ItemsSource="{Binding AvailableStatuses}" SelectedItem="{Binding Task.Status}" Style="{StaticResource ModernComboBox}"/>
                                </StackPanel>
                                <StackPanel Margin="10,0,0,0">
                                    <TextBlock Text="PRIORITY" Style="{StaticResource LabelText}"/>
                                    <ComboBox SelectedValue="{Binding Task.Priority}" SelectedValuePath="Content" Style="{StaticResource ModernComboBox}">
                                        <ComboBoxItem Content="Low"/>
                                        <ComboBoxItem Content="Medium"/>
                                        <ComboBoxItem Content="High"/>
                                        <ComboBoxItem Content="Critical"/>
                                    </ComboBox>
                                </StackPanel>
                            </UniformGrid>

                            <StackPanel Margin="0,0,0,20">
                                <TextBlock Text="HOLD" Style="{StaticResource LabelText}"/>
                                <CheckBox Content="On Hold" IsChecked="{Binding Task.IsOnHold}" Style="{StaticResource ModernCheckBox}" Margin="0,5,0,0"/>
                                
                                <StackPanel Visibility="{Binding Task.IsOnHold, Converter={StaticResource VisibilityConverter}}" Margin="0,10,0,0">
                                    <TextBlock Text="HOLD REASON (Required)" Style="{StaticResource LabelText}" Foreground="{StaticResource SecondaryGold}"/>
                                    <TextBox Text="{Binding Task.HoldReason, UpdateSourceTrigger=PropertyChanged}" 
                                             Style="{StaticResource ModernInput}" 
                                             ap:WatermarkProperties.Watermark="Explain why this task is paused..."
                                             MinHeight="60" TextWrapping="Wrap" AcceptsReturn="True"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Progress -->
                            <StackPanel Margin="0,0,0,20">
                                <Grid>
                                    <TextBlock Text="PROGRESS" Style="{StaticResource LabelText}"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,5">
                                        <TextBlock Text="{Binding Task.PercentComplete, StringFormat='{}{0}%'}" Foreground="White" FontSize="12" FontWeight="Bold"/>
                                        <TextBlock Text=" complete" Foreground="{StaticResource TextSub}" FontSize="12"/>
                                    </StackPanel>
                                </Grid>
                                <ProgressBar Value="{Binding Task.PercentComplete}" Height="12" BorderThickness="0" Background="#15FFFFFF">
                                    <ProgressBar.Foreground>
                                        <SolidColorBrush Color="{Binding Task.StatusColor}"/>
                                    </ProgressBar.Foreground>
                                </ProgressBar>
                            </StackPanel>

                            <!-- Dates -->
                            <UniformGrid Columns="2" Margin="0,0,0,20">
                                <StackPanel Margin="0,0,10,0">
                                    <TextBlock Text="START DATE" Style="{StaticResource LabelText}"/>
                                    <DatePicker SelectedDate="{Binding Task.StartDate}" Style="{StaticResource ModernDatePicker}"/>
                                </StackPanel>
                                <StackPanel Margin="10,0,0,0">
                                    <TextBlock Text="DUE DATE" Style="{StaticResource LabelText}"/>
                                    <DatePicker SelectedDate="{Binding Task.FinishDate}" Style="{StaticResource ModernDatePicker}"/>
                                </StackPanel>
                            </UniformGrid>

                            <!-- Subtasks Section -->
                            <Border BorderBrush="{StaticResource GlassBorderLight}" BorderThickness="0,1,0,0" Padding="0,20,0,0" Visibility="{Binding IsParentTask, Converter={StaticResource VisibilityConverter}}" Margin="0,0,0,20">
                                <StackPanel>
                                    <TextBlock Text="SUBTASKS" Style="{StaticResource LabelText}" Margin="0,0,0,10"/>
                                    <ItemsControl ItemsSource="{Binding Subtasks}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#0DFFFFFF" CornerRadius="8" Padding="12,8" Margin="0,0,0,8">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <CheckBox IsChecked="{Binding IsComplete}" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="White" Margin="10,0" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="2" Text="{Binding PercentComplete, StringFormat='{}{0}%'}" Foreground="{StaticResource TextSub}" FontSize="12" VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- Comments Section -->
                            <Border BorderBrush="{StaticResource GlassBorderLight}" BorderThickness="0,1,0,0" Padding="0,20,0,0" Margin="0,0,0,20"
                                    Visibility="{Binding IsCreateMode, Converter={StaticResource VisibilityConverter}, ConverterParameter='Invert'}">
                                <StackPanel>
                                    <TextBlock Text="COMMENTS" Style="{StaticResource LabelText}" Margin="0,0,0,10"/>
                                    
                                    <!-- Add Comment -->
                                    <Grid Margin="0,0,0,15">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Text="{Binding NewCommentContent, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernInput}" ap:WatermarkProperties.Watermark="Type a comment..."/>
                                        <Button Grid.Column="1" Content="Add" Command="{Binding AddCommentCommand}" Style="{StaticResource ActionButtonPrimary}" Margin="10,0,0,0"/>
                                    </Grid>

                                    <!-- Comments List -->
                                    <ItemsControl ItemsSource="{Binding Comments}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#05FFFFFF" CornerRadius="8" Padding="12" Margin="0,0,0,12" BorderBrush="#10FFFFFF" BorderThickness="1">
                                                    <StackPanel>
                                                        <Grid>
                                                            <TextBlock Text="{Binding AuthorName}" Foreground="{StaticResource AccentBlue}" FontWeight="Bold" FontSize="12"/>
                                                            <TextBlock Text="{Binding CreatedAtUtc, StringFormat='{}{0:dd MMM HH:mm}'}" Foreground="{StaticResource TextSub}" FontSize="10" HorizontalAlignment="Right"/>
                                                        </Grid>
                                                        <TextBlock Text="{Binding Content}" Foreground="White" TextWrapping="Wrap" Margin="0,5,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </ScrollViewer>

                    <!-- Footer -->
                    <Border Grid.Row="1" VerticalAlignment="Bottom" Background="#10000000" Padding="20,15" Visibility="{Binding IsCreateMode, Converter={StaticResource VisibilityConverter}}">
                        <Button Content="Create Task" Command="{Binding CreateTaskCommand}" Style="{StaticResource ActionButtonPrimary}" HorizontalAlignment="Stretch" Height="45"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
