<UserControl x:Class="OCC.WpfClient.Features.CustomerHub.Views.CustomerDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:OCC.WpfClient.Features.CustomerHub.ViewModels"
             xmlns:ap="clr-namespace:OCC.WpfClient.Infrastructure.AttachedProperties"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="900"
             d:DataContext="{d:DesignInstance Type=vm:CustomerDetailViewModel}">

    <Grid>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Detail Modal -->
            <Border Grid.Column="1" Grid.Row="1" Style="{StaticResource DetailViewModalBorder}" Margin="0,20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="5" Opacity="0.5"/>
                </Border.Effect>

                <Grid>
                    <!-- Background Decoration -->
                    <Path Data="{StaticResource IconAddUser}" Fill="White" Opacity="0.02" 
                          Stretch="Uniform" Margin="40" HorizontalAlignment="Right" 
                          VerticalAlignment="Bottom" Width="300" Height="300"/>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Border Grid.Row="0" Style="{StaticResource DetailViewHeader}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding Title}" FontSize="32" FontWeight="Bold" Foreground="White" />
                                    <TextBlock Text="Manage clients, billing information and key contacts." FontSize="14" 
                                               Foreground="{StaticResource TextSub}" Margin="0,4,0,0"/>
                                </StackPanel>

                                <Button Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Top" 
                                        Style="{StaticResource WindowCloseButton}" Command="{Binding CancelCommand}"/>
                            </Grid>
                        </Border>

                        <!-- Content -->
                        <ScrollViewer x:Name="MainScrollViewer" Grid.Row="1" Style="{StaticResource DetailViewContentScroll}" Padding="20,20,20,20">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="20" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Left Column: Core Info -->
                                    <StackPanel Grid.Column="0">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                            <Path Data="{StaticResource IconPersonal}" Style="{StaticResource SectionIcon}"/>
                                            <TextBlock Text="Customer Information" Style="{StaticResource SectionHeaderText}"/>
                                        </StackPanel>

                                        <StackPanel Margin="0,0,0,15">
                                            <TextBlock Text="Customer Name" Style="{StaticResource FormLabelText}"/>
                                            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernInput}" ap:WatermarkProperties.Watermark="Enter customer name..."/>
                                        </StackPanel>
                                        
                                        <StackPanel Margin="0,0,0,15">
                                            <TextBlock Text="Header Display" Style="{StaticResource FormLabelText}"/>
                                            <TextBox Text="{Binding Header, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernInput}" ap:WatermarkProperties.Watermark="Optional UI header..."/>
                                        </StackPanel>
                                        
                                        <StackPanel Margin="0,0,0,15">
                                            <TextBlock Text="Email Address" Style="{StaticResource FormLabelText}"/>
                                            <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernInput}" ap:WatermarkProperties.Watermark="primary@email.com"/>
                                        </StackPanel>
                                        
                                        <StackPanel Margin="0,0,0,15">
                                            <TextBlock Text="Phone Number" Style="{StaticResource FormLabelText}"/>
                                            <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernInput}" ap:WatermarkProperties.Watermark="+1 234 567 890"/>
                                        </StackPanel>
                                        
                                        <StackPanel Margin="0,0,0,25">
                                            <TextBlock Text="Billing Address" Style="{StaticResource FormLabelText}"/>
                                            <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernInput}" MinHeight="80" Height="Auto" TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top" ap:WatermarkProperties.Watermark="Full address..."/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Right Column: Contacts -->
                                    <StackPanel Grid.Column="2">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                            <Path Data="{StaticResource IconTeam}" Style="{StaticResource SectionIcon}"/>
                                            <TextBlock Text="Key Contacts" Style="{StaticResource SectionHeaderText}"/>
                                            
                                            <Button HorizontalAlignment="Right" Style="{StaticResource SecondaryButton}" Height="26" Padding="10,0" Margin="15,0,0,0" Command="{Binding AddContactCommand}">
                                                <StackPanel Orientation="Horizontal">
                                                    <Path Data="{StaticResource IconPlus}" Fill="{StaticResource AccentBlue}" Width="10" Height="10" Stretch="Uniform" Margin="0,0,6,0"/>
                                                    <TextBlock Text="Add Contact" FontSize="11"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>

                                        <ItemsControl x:Name="ContactsItemsControl" ItemsSource="{Binding Contacts}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#10FFFFFF" CornerRadius="8" Padding="15" Margin="0,0,0,10" BorderBrush="#20FFFFFF" BorderThickness="1">
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                            </Grid.RowDefinitions>
                                                            
                                                            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,-10,-10,5">
                                                                <ToggleButton x:Name="ExpandBtn" Background="Transparent" BorderThickness="0" Cursor="Hand" Focusable="False" KeyboardNavigation.IsTabStop="False">
                                                                    <ToggleButton.Style>
                                                                        <Style TargetType="ToggleButton">
                                                                            <Setter Property="IsChecked" Value="False"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Id, Converter={StaticResource IsGuidEmptyConverter}}" Value="True">
                                                                                    <Setter Property="IsChecked" Value="True"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </ToggleButton.Style>
                                                                    <ToggleButton.Template>
                                                                        <ControlTemplate TargetType="ToggleButton">
                                                                            <Border Background="Transparent" Padding="5">
                                                                                <Path x:Name="Icon" Data="{StaticResource IconChevronDown}" Fill="{StaticResource TextSub}" Width="16" Height="16" Stretch="Uniform"/>
                                                                            </Border>
                                                                            <ControlTemplate.Triggers>
                                                                                <Trigger Property="IsChecked" Value="True">
                                                                                    <Setter TargetName="Icon" Property="Data" Value="{StaticResource IconChevronUp}"/>
                                                                                </Trigger>
                                                                            </ControlTemplate.Triggers>
                                                                        </ControlTemplate>
                                                                    </ToggleButton.Template>
                                                                </ToggleButton>
                                                                
                                                                <Button Background="Transparent" BorderThickness="0" Padding="5" Cursor="Hand" Margin="2,0,0,0"
                                                                        Focusable="False" KeyboardNavigation.IsTabStop="False"
                                                                        Command="{Binding DataContext.RemoveContactCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}">
                                                                    <Path Data="{StaticResource IconClose}" Fill="{StaticResource TextSub}" Width="12" Height="12" Stretch="Uniform"/>
                                                                </Button>
                                                            </StackPanel>

                                                            <StackPanel Grid.Row="1" Margin="0,0,0,12">
                                                                <TextBlock Text="Name" Style="{StaticResource FormLabelText}" />
                                                                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernInput}" ap:WatermarkProperties.Watermark="Contact name..." />
                                                            </StackPanel>

                                                            <StackPanel Grid.Row="2" Visibility="{Binding IsChecked, ElementName=ExpandBtn, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                <StackPanel Margin="0,0,0,12">
                                                                    <TextBlock Text="Email" Style="{StaticResource FormLabelText}" />
                                                                    <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernInput}" ap:WatermarkProperties.Watermark="Email address..." />
                                                                </StackPanel>

                                                                <StackPanel Margin="0,0,0,12">
                                                                    <TextBlock Text="Phone" Style="{StaticResource FormLabelText}" />
                                                                    <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernInput}" ap:WatermarkProperties.Watermark="Phone number..." />
                                                                </StackPanel>

                                                                <StackPanel Margin="0,0,0,0">
                                                                    <TextBlock Text="Department" Style="{StaticResource FormLabelText}" />
                                                                    <TextBox Text="{Binding Department, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernInput}" ap:WatermarkProperties.Watermark="Department..." />
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Footer Actions -->
                        <Border Grid.Row="2" Style="{StaticResource DetailViewFooter}">
                            <StackPanel>
                                <!-- Premium Validation Summary Card -->
                                <Border Margin="0,0,0,15"
                                        Background="#1AEE4444" BorderBrush="{StaticResource ErrorRed}" 
                                        BorderThickness="1" CornerRadius="12" Padding="15,10">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Setter Property="Opacity" Value="0"/>
                                            <Style.Triggers>
                                                <!-- TRIGGER: Signal received from ViewModel pulse (0 -> 1) -->
                                                <DataTrigger Binding="{Binding AnimationPulse}" Value="1">
                                                    <DataTrigger.EnterActions>
                                                        <StopStoryboard BeginStoryboardName="PremiumErrorAnim"/>
                                                        <BeginStoryboard x:Name="PremiumErrorAnim">
                                                            <Storyboard>
                                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility">
                                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Visible}"/>
                                                                </ObjectAnimationUsingKeyFrames>
                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3"/>
                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0" BeginTime="0:0:2.5" Duration="0:0:0.5"/>
                                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" BeginTime="0:0:3.1">
                                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Collapsed}"/>
                                                                </ObjectAnimationUsingKeyFrames>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.EnterActions>
                                                </DataTrigger>

                                                <!-- Safety: Ensure it hides immediately if form becomes valid -->
                                                <DataTrigger Binding="{Binding HasErrors}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Setter Property="Opacity" Value="0"/>
                                                    <DataTrigger.EnterActions>
                                                        <StopStoryboard BeginStoryboardName="PremiumErrorAnim"/>
                                                    </DataTrigger.EnterActions>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="15" ShadowDepth="0" Color="{StaticResource ErrorRedColor}" Opacity="0.2"/>
                                    </Border.Effect>
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <Path Data="M12,2C6.48,2,2,6.48,2,12s4.48,10,10,10s10-4.48,10-10S17.52,2,12,2z M13,17h-2v-2h2V17z M13,13h-2V7h2V13z"
                                                  Fill="{StaticResource ErrorRed}" Width="16" Height="16" Stretch="Uniform" Margin="0,0,10,0"/>
                                            <TextBlock Text="VALIDATION ERRORS" Foreground="{StaticResource ErrorRed}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <ItemsControl ItemsSource="{Binding ValidationErrors}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}" Foreground="White" FontSize="13" Margin="26,2,0,2" Opacity="0.9"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <Grid>
                                    <Button HorizontalAlignment="Left" Style="{StaticResource SecondaryButton}" Command="{Binding PrintCommand}" Width="150" Height="40">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="{StaticResource IconPrint}" Fill="White" Width="14" Height="14" Stretch="Uniform" Margin="0,0,10,0"/>
                                            <TextBlock Text="Print Profile" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Content="Cancel" Style="{StaticResource CancelButton}" Command="{Binding CancelCommand}" Width="110" Height="40" Margin="0,0,15,0"/>
                                        <Button Content="Save Customer" Style="{StaticResource PrimaryButton}" Command="{Binding SaveCommand}" Width="150" Height="40"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- Busy Overlay -->
        <Grid Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=False}" Panel.ZIndex="100">
            <Border Background="{StaticResource BackgroundDark}" Opacity="0.7"/>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Background="#33FFFFFF" Foreground="{StaticResource AccentBlue}"/>
                <TextBlock Text="{Binding BusyText}" Margin="0,10" Foreground="White" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>

