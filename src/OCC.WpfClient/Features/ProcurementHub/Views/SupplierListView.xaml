<UserControl x:Class="OCC.WpfClient.Features.ProcurementHub.Views.SupplierListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:OCC.WpfClient.Features.ProcurementHub.ViewModels"
             xmlns:views="clr-namespace:OCC.WpfClient.Features.ProcurementHub.Views"
             xmlns:ap="clr-namespace:OCC.WpfClient.Infrastructure.AttachedProperties"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200"
             d:DataContext="{d:DesignInstance Type=vm:SupplierViewModel}">

    <UserControl.Resources>
        <DataTemplate DataType="{x:Type vm:SupplierDetailViewModel}">
            <views:SupplierDetailView />
        </DataTemplate>
    </UserControl.Resources>
    
    <Grid Margin="5,10,5,5">
        <!-- Main Background Content -->
        <Grid>
            <Grid.Style>
                <Style TargetType="Grid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsOverlayActive}" Value="True">
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <BlurEffect Radius="15"/>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Opacity" Value="0.4"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /> <!-- Header -->
                <RowDefinition Height="Auto" /> <!-- Stats & Search -->
                <RowDefinition Height="*" />    <!-- Grid -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="5,0,5,20">
                <StackPanel>
                    <TextBlock Text="Supplier Management" FontSize="26" FontWeight="Bold" Foreground="White" />
                    <TextBlock Text="Manage procurement sources and bank details." Style="{StaticResource FormLabelText}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Style="{StaticResource PrimaryButton}" Command="{Binding AddSupplierCommand}" Width="150" Height="36" Cursor="Hand">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconPlus}" Fill="White" Width="12" Height="12" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Add Supplier" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Stats & Search Line -->
            <Border Grid.Row="1" Background="{StaticResource GlassBackground}" BorderBrush="{StaticResource GlassBorder}" 
                    BorderThickness="1" CornerRadius="10" Padding="15,10" Margin="5,0,5,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" /> <!-- Search Icon -->
                        <ColumnDefinition Width="200" />  <!-- Search Box -->
                        <ColumnDefinition Width="150" />  <!-- Branch Filter -->
                        <ColumnDefinition Width="*" />    <!-- Spacer -->
                        <ColumnDefinition Width="Auto" /> <!-- Stats -->
                    </Grid.ColumnDefinitions>

                    <!-- Search -->
                    <Path Grid.Column="0" Data="{StaticResource IconSearch}" Fill="{StaticResource TextSub}" Width="14" Height="14" Margin="5,0,10,0" VerticalAlignment="Center" Stretch="Uniform"/>
                    <TextBox Grid.Column="1" Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" 
                               Style="{StaticResource ModernInput}" Height="32" Padding="8,0" BorderThickness="0" Background="Transparent"
                               ap:WatermarkProperties.Watermark="Search suppliers..."/>

                    <!-- Branch Filter -->
                    <ComboBox Grid.Column="2" ItemsSource="{Binding BranchOptions}" SelectedItem="{Binding SelectedBranchFilter}" 
                              Style="{StaticResource ModernComboBox}" Height="32" Margin="15,0,0,0"/>

                    <!-- Stats -->
                    <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel Margin="0,0,30,0">
                            <TextBlock Text="TOTAL SUPPLIERS" FontSize="10" Foreground="{StaticResource TextSub}" FontWeight="Bold"/>
                            <TextBlock Text="{Binding TotalCount}" FontSize="18" Foreground="White" FontWeight="SemiBold"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Supplier Grid -->
            <Border Grid.Row="2" Style="{StaticResource GlassCard}" Margin="5,0,5,5" ClipToBounds="True" CornerRadius="0">
                <DataGrid ItemsSource="{Binding Items}" 
                          SelectedItem="{Binding SelectedItem}"
                          AutoGenerateColumns="False" 
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None"
                          CanUserAddRows="False"
                          Style="{StaticResource ModernDataGrid}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="NAME" Binding="{Binding Name}" Width="*" FontWeight="SemiBold" />
                        <DataGridTextColumn Header="BRANCH" Binding="{Binding Branch}" Width="120" Foreground="{StaticResource TextSub}" />
                        <DataGridTextColumn Header="CONTACT" Binding="{Binding ContactPerson}" Width="*" Foreground="{StaticResource TextSub}" />
                        <DataGridTextColumn Header="PHONE" Binding="{Binding Phone}" Width="150" />
                        
                        <DataGridTemplateColumn Header="ACTIONS" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Command="{Binding DataContext.EditSupplierCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                CommandParameter="{Binding}" Style="{StaticResource ToolbarIconButton}" Margin="5" ToolTip="Open Details">
                                            <Path Data="{StaticResource IconExternalLink}" Fill="White" Width="14" Height="14" Stretch="Uniform" Opacity="0.8"/>
                                        </Button>
                                        <Button Command="{Binding DataContext.EditSupplierCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                CommandParameter="{Binding}" Style="{StaticResource ToolbarIconButton}" Margin="5" ToolTip="Edit">
                                            <Path Data="{StaticResource IconEdit}" Fill="{StaticResource AccentBlue}" Width="14" Height="14" Stretch="Uniform"/>
                                        </Button>
                                        <Button Command="{Binding DataContext.DeleteSupplierCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                CommandParameter="{Binding}" Style="{StaticResource ToolbarIconButton}" Margin="5" ToolTip="Delete">
                                            <Path Data="{StaticResource IconTrash}" Fill="{StaticResource ErrorRed}" Width="14" Height="14" Stretch="Uniform"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                            <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                            <Setter Property="ap:CommandProperties.DoubleClickCommand" 
                                    Value="{Binding DataContext.EditSupplierCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                            <Setter Property="ap:CommandProperties.CommandParameter" Value="{Binding}"/>
                            <Setter Property="ContextMenu">
                                <Setter.Value>
                                    <ContextMenu Style="{StaticResource ModernContextMenu}">
                                        <MenuItem Header="Edit Supplier" 
                                                  Command="{Binding Path=PlacementTarget.Tag.EditSupplierCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding}">
                                            <MenuItem.Icon>
                                                <Path Data="{StaticResource IconEdit}" Fill="{StaticResource AccentBlue}" Width="12" Height="12" Stretch="Uniform"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <Separator Style="{x:Null}" Visibility="Collapsed"/>
                                        <MenuItem Header="Delete Supplier" 
                                                  Command="{Binding Path=PlacementTarget.Tag.DeleteSupplierCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding}"
                                                  Foreground="{StaticResource ErrorRed}">
                                            <MenuItem.Icon>
                                                <Path Data="{StaticResource IconTrash}" Fill="{StaticResource ErrorRed}" Width="12" Height="12" Stretch="Uniform"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                    </ContextMenu>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGrid.RowStyle>
                </DataGrid>
            </Border>

            <!-- Loading Overlay -->
            <Border Grid.Row="2" Background="#80000000" CornerRadius="12" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="200" Height="4" Foreground="{StaticResource AccentBlue}" Background="#20FFFFFF"/>
                    <TextBlock Text="{Binding BusyText}" Foreground="White" Margin="0,15,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Detail View Overlay -->
        <ContentControl Content="{Binding OverlayViewModel}" />
    </Grid>
</UserControl>
