<UserControl x:Class="OCC.WpfClient.Features.ProcurementHub.Views.InventoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:OCC.WpfClient.Features.ProcurementHub.ViewModels"
             xmlns:ap="clr-namespace:OCC.WpfClient.Infrastructure.AttachedProperties"
             xmlns:infra="clr-namespace:OCC.WpfClient.Infrastructure"
             xmlns:conv="clr-namespace:OCC.WpfClient.Infrastructure.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1024"
             d:DataContext="{d:DesignInstance Type=vm:InventoryViewModel}">

    <UserControl.Resources>
        <conv:VisibilityConverter x:Key="VisibilityConverter"/>
        <infra:BindingProxy x:Key="Proxy" Data="{Binding}" />
    </UserControl.Resources>

    <Grid Margin="0"  Background="{StaticResource AppBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!-- Header -->
            <RowDefinition Height="Auto" />
            <!-- Compact Filters & Stats -->
            <RowDefinition Height="*" />
            <!-- Grid -->
        </Grid.RowDefinitions>

        <!-- Header: Title, Subtitle, and Add Button -->
        <Grid Grid.Row="0" Margin="10">
            <StackPanel>
                <TextBlock Text="Inventory Management" Style="{StaticResource HeaderText}"/>
                <TextBlock Text="Track stock levels, reorder points, and warehouse locations." 
                           Style="{StaticResource LabelText}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Style="{StaticResource PrimaryButton}" Command="{Binding AddItemCommand}">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource IconPlus}" Fill="White" Width="16" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Add Stock Item" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Filters & Search Bar Row (Standardized with Employee Hub) -->
        <Border Grid.Row="1" Style="{StaticResource GlassCard}" Padding="15,10" Margin="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <!-- Search Icon -->
                    <ColumnDefinition Width="Auto" />
                    <!-- Search Box -->
                    <ColumnDefinition Width="*" MinWidth="180" />
                    <!-- Divider -->
                    <ColumnDefinition Width="Auto" />
                    <!-- Category Filter -->
                    <ColumnDefinition Width="Auto" />
                    <!-- Divider -->
                    <ColumnDefinition Width="Auto" />
                    <!-- Status Filter -->
                    <ColumnDefinition Width="Auto" />
                    <!-- Columns -->
                    <ColumnDefinition Width="Auto" />
                    <!-- Spacer -->
                    <ColumnDefinition Width="*" />
                    <!-- Stats Badges -->
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Search -->
                <Path Grid.Column="0" Data="{StaticResource IconSearch}" Fill="{StaticResource TextSub}" 
                      Width="14" Height="14" Margin="5,0,10,0" VerticalAlignment="Center" Stretch="Uniform"/>
                <TextBox Grid.Column="1" Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernInput}" 
                         ap:WatermarkProperties.Watermark="Search items or SKUs..."
                         Height="32" Padding="8,0" BorderThickness="0" Background="Transparent"/>

                <Border Grid.Column="2" Width="1" Height="20" Background="{StaticResource GlassBorder}" Margin="15,0" VerticalAlignment="Center"/>

                <!-- Category Filter (Mockup for UI Consistency) -->
                <ComboBox Grid.Column="3" Height="30" Style="{StaticResource ModernComboBox}" Margin="0,0,10,0" SelectedIndex="0">
                    <ComboBoxItem Content="All Categories" />
                    <ComboBoxItem Content="Tools" />
                    <ComboBoxItem Content="Electrical" />
                    <ComboBoxItem Content="Plumbing" />
                    <ComboBoxItem Content="Materials" />
                </ComboBox>

                <!-- Status Filter (Mockup for UI Consistency) -->
                <ComboBox Grid.Column="4" Height="30" Style="{StaticResource ModernComboBox}" SelectedIndex="0">
                    <ComboBoxItem Content="All Statuses" />
                    <ComboBoxItem Content="OK" />
                    <ComboBoxItem Content="Low Stock" />
                    <ComboBoxItem Content="Out of Stock" />
                </ComboBox>

                <Border Grid.Column="5" Width="1" Height="20" Background="{StaticResource GlassBorder}" Margin="15,0" VerticalAlignment="Center"/>

                <!-- Columns Selection -->
                <StackPanel Grid.Column="6" Orientation="Horizontal">
                    <Grid>
                        <ToggleButton x:Name="ColumnsToggle" 
                                      Style="{StaticResource ToolbarToggleButton}" 
                                      Width="100" Height="30">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconList}" Fill="White" Width="14" Height="14" Stretch="Uniform" Margin="0,0,8,0" Opacity="0.8"/>
                                <TextBlock Text="COLUMNS" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                            </StackPanel>
                        </ToggleButton>
                        <Popup IsOpen="{Binding IsChecked, ElementName=ColumnsToggle}" StaysOpen="False" PlacementTarget="{Binding ElementName=ColumnsToggle}" Placement="Bottom" AllowsTransparency="True" PopupAnimation="Fade">
                            <Border Background="{StaticResource BackgroundDark}" BorderBrush="{StaticResource GlassBorder}" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,5,0,0" Width="200">
                                <StackPanel>
                                    <TextBlock Text="DISPLAY COLUMNS" FontSize="10" FontWeight="Bold" Foreground="{StaticResource AccentBlue}" Margin="0,0,0,8"/>
                                    <CheckBox Content="SKU" IsChecked="{Binding IsSkuVisible, Mode=TwoWay}" Style="{StaticResource ModernCheckBox}" Margin="0,2"/>
                                    <CheckBox Content="Description" IsChecked="{Binding IsDescriptionVisible, Mode=TwoWay}" Style="{StaticResource ModernCheckBox}" Margin="0,2"/>
                                    <CheckBox Content="Category" IsChecked="{Binding IsCategoryVisible, Mode=TwoWay}" Style="{StaticResource ModernCheckBox}" Margin="0,2"/>
                                    <CheckBox Content="Quantity" IsChecked="{Binding IsQuantityVisible, Mode=TwoWay}" Style="{StaticResource ModernCheckBox}" Margin="0,2"/>
                                    <CheckBox Content="Location" IsChecked="{Binding IsLocationVisible, Mode=TwoWay}" Style="{StaticResource ModernCheckBox}" Margin="0,2"/>
                                    <CheckBox Content="Status" IsChecked="{Binding IsStatusVisible, Mode=TwoWay}" Style="{StaticResource ModernCheckBox}" Margin="0,2"/>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>

                    <!-- Print -->
                    <Button Command="{Binding PrintCommand}" Style="{StaticResource ToolbarButton}">
                        <StackPanel Orientation="Horizontal" Margin="10,0">
                            <Path Data="{StaticResource IconPrint}" Fill="White" Width="14" Height="14" Stretch="Uniform" Margin="0,0,8,0" Opacity="0.8"/>
                            <TextBlock Text="PRINT" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Stats Badges -->
                <StackPanel Grid.Column="8" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#20FFFFFF" CornerRadius="12" Padding="10,4" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="TOTAL: " FontSize="10" Foreground="{StaticResource TextSub}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding TotalCount}" FontSize="12" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#20FF4B4B" CornerRadius="12" Padding="10,4" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="LOW STOCK: " FontSize="10" Foreground="{StaticResource TextSub}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding LowStockCount}" FontSize="12" FontWeight="Bold" Foreground="{StaticResource ErrorRed}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- DataGrid Section: Wrapped in reference-compliant border -->
        <Border Grid.Row="2" Style="{StaticResource GlassCard}" Padding="2" ClipToBounds="True" CornerRadius="0"
                Margin="10,0,10,10">
            <DataGrid ItemsSource="{Binding Items}" AutoGenerateColumns="False" 
                      Background="Transparent" BorderThickness="0" CanUserAddRows="False"
                      IsReadOnly="True" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.CanContentScroll="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="SKU" Binding="{Binding Sku}" Width="150" Visibility="{Binding Data.IsSkuVisible, Source={StaticResource Proxy}, Converter={StaticResource VisibilityConverter}}"/>
                    <DataGridTextColumn Header="DESCRIPTION" Binding="{Binding Description}" Width="Auto" Visibility="{Binding Data.IsDescriptionVisible, Source={StaticResource Proxy}, Converter={StaticResource VisibilityConverter}}"/>
                    <DataGridTextColumn Header="CATEGORY" Binding="{Binding Category, Converter={StaticResource FriendlyEnumConverter}}" Width="150" Visibility="{Binding Data.IsCategoryVisible, Source={StaticResource Proxy}, Converter={StaticResource VisibilityConverter}}"/>
                    <DataGridTextColumn Header="QUANTITY" Binding="{Binding QuantityOnHand}" Width="120" Visibility="{Binding Data.IsQuantityVisible, Source={StaticResource Proxy}, Converter={StaticResource VisibilityConverter}}">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLowStock}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource ErrorRed}"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="LOCATION" Binding="{Binding Location}" Width="150" Visibility="{Binding Data.IsLocationVisible, Source={StaticResource Proxy}, Converter={StaticResource VisibilityConverter}}"/>
                    <DataGridTextColumn Header="STATUS" Binding="{Binding Status, Converter={StaticResource FriendlyEnumConverter}}" Width="120" Visibility="{Binding Data.IsStatusVisible, Source={StaticResource Proxy}, Converter={StaticResource VisibilityConverter}}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Loading Overlay -->
        <ContentControl Grid.Row="2" Style="{StaticResource StandardLoadingOverlay}" 
                        Visibility="{Binding IsBusy, Converter={StaticResource VisibilityConverter}}"/>
    </Grid>
</UserControl>


