<UserControl x:Class="OCC.WpfClient.Features.ProcurementHub.Views.Dialogs.ReceiveStockDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OCC.WpfClient.Features.ProcurementHub.Views.Dialogs"
             xmlns:vm="clr-namespace:OCC.WpfClient.Features.ProcurementHub.ViewModels.Dialogs"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="900"
             d:DataContext="{d:DesignInstance Type=vm:ReceiveStockViewModel}">
    
    <Grid Background="#CC000000">
        <Border Style="{StaticResource GlassCard}" Width="850" Height="650" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Header -->
                    <RowDefinition Height="*"/>    <!-- Content -->
                    <RowDefinition Height="Auto"/> <!-- Footer -->
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="{Binding Title}" FontSize="24" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="{Binding Order.SupplierName, StringFormat='Supplier: {0}'}" 
                                   Foreground="#AAA" FontSize="14" Margin="0,5,0,0"/>
                    </StackPanel>
                    
                    <Button Style="{StaticResource GhostButton}" Command="{Binding CloseCommand}" 
                            HorizontalAlignment="Right" VerticalAlignment="Top" Padding="5">
                        <Path Data="{StaticResource IconClose}" Fill="White" Width="14" Height="14" Stretch="Uniform"/>
                    </Button>
                </Grid>

                <!-- Content Area -->
                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Info Alert -->
                    <Border Background="#1500FF88" BorderBrush="#00FF88" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Path Data="{StaticResource IconInfo}" Fill="#00FF88" Width="20" Height="20" Stretch="Uniform" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Enter the quantity received for each item. This will update inventory levels immediately." 
                                       Foreground="White" VerticalAlignment="Center" Margin="15,0" TextWrapping="Wrap"/>
                            <Button Grid.Column="2" Style="{StaticResource SecondaryButton}" Content="Receive All Remaining" 
                                    Command="{Binding ReceiveAllCommand}" Padding="15,5" Height="30"/>
                        </Grid>
                    </Border>

                    <!-- Items List -->
                    <Border Grid.Row="1" Background="{StaticResource GlassBackground}" BorderBrush="{StaticResource GlassBorder}" BorderThickness="1" CornerRadius="8">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding OrderItems}" Margin="10">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#08FFFFFF" BorderBrush="#1FFFFFFF" BorderThickness="1" CornerRadius="6" Margin="0,0,0,10" Padding="15">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>      <!-- Info -->
                                                    <ColumnDefinition Width="100"/>    <!-- Ordered -->
                                                    <ColumnDefinition Width="100"/>    <!-- Received -->
                                                    <ColumnDefinition Width="120"/>    <!-- Input -->
                                                    <ColumnDefinition Width="100"/>    <!-- Remaining -->
                                                </Grid.ColumnDefinitions>

                                                <!-- Item Info -->
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Description}" Foreground="White" FontWeight="SemiBold" FontSize="14"/>
                                                    <TextBlock Text="{Binding ItemCode, StringFormat='SKU: {0}'}" Foreground="#888" FontSize="12"/>
                                                </StackPanel>

                                                <!-- Ordered -->
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                    <TextBlock Text="Ordered" Foreground="#888" FontSize="10" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="{Binding QuantityOrdered}" Foreground="White" FontSize="14" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="{Binding UnitOfMeasure}" Foreground="#666" FontSize="10" HorizontalAlignment="Center"/>
                                                </StackPanel>

                                                <!-- Received So Far -->
                                                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                    <TextBlock Text="Received" Foreground="#888" FontSize="10" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="{Binding QuantityReceivedSoFar}" Foreground="White" FontSize="14" HorizontalAlignment="Center"/>
                                                </StackPanel>

                                                <!-- Receive Now Input -->
                                                <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="10,0">
                                                    <TextBlock Text="RECEIVE NOW" Foreground="#00FF88" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                                    <TextBox Text="{Binding ReceiveNow, UpdateSourceTrigger=PropertyChanged}" 
                                                             Style="{StaticResource ModernInput}" 
                                                             TextAlignment="Center" 
                                                             Height="35" FontSize="16" FontWeight="Bold"/>
                                                </StackPanel>

                                                <!-- Remaining -->
                                                <StackPanel Grid.Column="4" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                    <TextBlock Text="Remaining" Foreground="#888" FontSize="10" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="{Binding NewRemaining}" Foreground="White" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <!-- Footer -->
                <Grid Grid.Row="2" Margin="0,15,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource SecondaryButton}" Content="Cancel" Command="{Binding CloseCommand}" Width="120" Margin="0,0,10,0"/>
                        <Button Style="{StaticResource PrimaryButton}" Content="CONFIRM RECEIPT" Command="{Binding SubmitReceivingCommand}" Width="180"/>
                    </StackPanel>
                </Grid>

                <!-- Loading Overlay -->
                <Grid Grid.RowSpan="3" Background="#AA000000" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <ProgressBar IsIndeterminate="True" Width="200" Height="4" Foreground="#00FF88" Background="#33FFFFFF" BorderThickness="0"/>
                        <TextBlock Text="{Binding BusyText}" Foreground="White" HorizontalAlignment="Center" Margin="0,15,0,0"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
