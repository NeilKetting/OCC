<infra:BaseListView x:Class="OCC.WpfClient.Features.HseqHub.Views.IncidentListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:OCC.WpfClient.Features.HseqHub.ViewModels"
             xmlns:dto="clr-namespace:OCC.Shared.DTOs;assembly=OCC.Shared"
             xmlns:infra="clr-namespace:OCC.WpfClient.Infrastructure"
             xmlns:ap="clr-namespace:OCC.WpfClient.Infrastructure.AttachedProperties"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200">

    <UserControl.Resources>
        <infra:BindingProxy x:Key="Proxy" Data="{Binding}" />
    </UserControl.Resources>

    <Grid Background="{StaticResource BackgroundDark}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Grid.Column="0" Margin="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Path Data="{StaticResource IconAlert}" Width="24" Height="24" Fill="{StaticResource AlertOrange}" Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Workplace Incidents" Style="{StaticResource HeaderText}"/>
                </StackPanel>
                <TextBlock Text="Report and track workplace health and safety incidents" Style="{StaticResource LabelText}" Opacity="0.7"/>
            </StackPanel>
            <Button Grid.Column="1" Style="{StaticResource ActionButtonPrimary}" Command="{Binding ToggleAddCommand}" 
                        Visibility="{Binding Editor.IsOpen, Converter={StaticResource VisibilityConverter}, ConverterParameter='Invert'}"
                        Content="+ REPORT INCIDENT" VerticalAlignment="Center"/>
        </Grid>

        <!-- Toolbar -->
        <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource GlassCard}" Padding="15,10" Margin="15,0,20,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <!-- Search Icon -->
                    <ColumnDefinition Width="250" />
                    <!-- Search Box -->
                    <ColumnDefinition Width="*" />
                    <!-- Spacer -->
                    <ColumnDefinition Width="Auto" />
                    <!-- Actions -->
                </Grid.ColumnDefinitions>

                <!-- Search -->
                <Path Grid.Column="0" Data="{StaticResource IconSearch}" Fill="{StaticResource TextSub}" Width="14" Height="14" Margin="5,0,10,0" VerticalAlignment="Center" Stretch="Uniform"/>
                <TextBox Grid.Column="1" Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource ToolbarTextBox}"
                         ap:WatermarkProperties.Watermark="Search incidents..."/>

                <!-- Actions -->
                <StackPanel Grid.Column="3" Orientation="Horizontal">
                    <Grid Margin="0,0,10,0">
                        <ToggleButton x:Name="ColumnsToggle" Style="{StaticResource ToolbarToggleButton}">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconList}" Fill="White" Width="14" Height="14" Stretch="Uniform" Margin="0,0,8,0" Opacity="0.8"/>
                                <TextBlock Text="COLUMNS" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                            </StackPanel>
                        </ToggleButton>
                        <Popup IsOpen="{Binding IsChecked, ElementName=ColumnsToggle}" StaysOpen="False" PlacementTarget="{Binding ElementName=ColumnsToggle}" Placement="Bottom" AllowsTransparency="True" PopupAnimation="Fade">
                            <Border Background="{StaticResource BackgroundDark}" BorderBrush="{StaticResource GlassBorder}" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,5,0,0" Width="200">
                                <StackPanel>
                                    <TextBlock Text="DISPLAY COLUMNS" FontSize="10" FontWeight="Bold" Foreground="{StaticResource PrimaryTeal}" Margin="0,0,0,8"/>
                                    <CheckBox Content="Type" IsChecked="{Binding IsTypeVisible, Mode=TwoWay}" Style="{StaticResource ModernCheckBox}" Margin="0,2"/>
                                    <CheckBox Content="Severity" IsChecked="{Binding IsSeverityVisible, Mode=TwoWay}" Style="{StaticResource ModernCheckBox}" Margin="0,2"/>
                                    <CheckBox Content="Status" IsChecked="{Binding IsStatusVisible, Mode=TwoWay}" Style="{StaticResource ModernCheckBox}" Margin="0,2"/>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>

                    <Button Command="{Binding PrintCommand}" Style="{StaticResource ToolbarButton}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconPrint}" Fill="White" Width="14" Height="14" Stretch="Uniform" Margin="0,0,8,0" Opacity="0.8"/>
                            <TextBlock Text="PRINT" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Data Table -->
        <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource GlassCard}" Padding="0" Margin="15,0,20,20">
            <DataGrid ItemsSource="{Binding Items}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      SelectedItem="{Binding SelectedItem}"
                      Style="{StaticResource ModernDataGrid}">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                        <Setter Property="ContextMenu">
                            <Setter.Value>
                                <ContextMenu>
                                    <MenuItem Header="Delete Incident" 
                                              Command="{Binding DataContext.DeleteIncidentCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                              CommandParameter="{Binding}">
                                        <MenuItem.Icon>
                                            <Path Data="{StaticResource IconDelete}" Fill="{StaticResource ErrorRed}" Width="14" Height="14" Stretch="Uniform"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </ContextMenu>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat='d MMM yyyy'}" Width="Auto"/>
                    <DataGridTextColumn Header="Type" Binding="{Binding Type, Converter={StaticResource FriendlyEnumConverter}}" Width="*" Visibility="{Binding Data.IsTypeVisible, Source={StaticResource Proxy}, Converter={StaticResource VisibilityConverter}}"/>
                    <DataGridTemplateColumn Header="Severity" Width="Auto" Visibility="{Binding Data.IsSeverityVisible, Source={StaticResource Proxy}, Converter={StaticResource VisibilityConverter}}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="4" Padding="8,2" Background="{Binding Severity, Converter={StaticResource SeverityColorConverter}}" Margin="5">
                                    <TextBlock Text="{Binding Severity, Converter={StaticResource FriendlyEnumConverter}}" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Location" Binding="{Binding Location}" Width="*"/>
                    <DataGridTemplateColumn Header="Status" Width="Auto" Visibility="{Binding Data.IsStatusVisible, Source={StaticResource Proxy}, Converter={StaticResource VisibilityConverter}}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="10" Padding="8,2" Background="#20FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Status, Converter={StaticResource FriendlyEnumConverter}}" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="ACTIONS" Width="Auto">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Style="{StaticResource ToolbarIconButton}" 
                                            Command="{Binding DataContext.OpenIncidentCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                            CommandParameter="{Binding}" ToolTip="View Details">
                                        <Path Data="{StaticResource IconEye}" Width="14" Height="14" Fill="{StaticResource TextSub}" Stretch="Uniform"/>
                                    </Button>
                                    <Button Style="{StaticResource ToolbarIconButton}" 
                                            Command="{Binding DataContext.DeleteIncidentCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                            CommandParameter="{Binding}" ToolTip="Delete">
                                        <Path Data="{StaticResource IconDelete}" Width="14" Height="14" Fill="{StaticResource ErrorRed}" Stretch="Uniform"/>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Side Panel Editor -->
        <Border Grid.RowSpan="3" Grid.Column="1" Style="{StaticResource GlassCard}" Width="500" Margin="0,20,20,20"
                Visibility="{Binding Editor.IsOpen, Converter={StaticResource VisibilityConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Incident Details" Style="{StaticResource HeaderText}" Margin="0,0,0,20"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,0,20,0">
                        <TextBlock Text="Incident Date" Style="{StaticResource FormLabelText}"/>
                        <DatePicker SelectedDate="{Binding Editor.NewIncident.Date}" Style="{StaticResource ModernDatePicker}" Margin="0,0,0,16"/>

                        <TextBlock Text="Incident Type" Style="{StaticResource FormLabelText}"/>
                        <ComboBox ItemsSource="{Binding Editor.IncidentTypes}" 
                                  SelectedItem="{Binding Editor.NewIncident.Type}"
                                  Style="{StaticResource ModernComboBox}"
                                  Margin="0,0,0,16">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource FriendlyEnumConverter}}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <TextBlock Text="Severity" Style="{StaticResource FormLabelText}"/>
                        <ComboBox ItemsSource="{Binding Editor.Severities}" 
                                  SelectedItem="{Binding Editor.NewIncident.Severity}"
                                  Style="{StaticResource ModernComboBox}"
                                  Margin="0,0,0,16">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource FriendlyEnumConverter}}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <TextBlock Text="Location" Style="{StaticResource FormLabelText}"/>
                        <TextBox Text="{Binding Editor.NewIncident.Location}" Style="{StaticResource ModernInput}" Margin="0,0,0,16"/>

                        <TextBlock Text="Description" Style="{StaticResource FormLabelText}"/>
                        <TextBox Text="{Binding Editor.NewIncident.Description}" 
                                 Style="{StaticResource ModernInput}" 
                                 TextWrapping="Wrap" AcceptsReturn="True" MinHeight="100" Margin="0,0,0,16"/>

                        <TextBlock Text="Immediate Action Taken" Style="{StaticResource FormLabelText}"/>
                        <TextBox Text="{Binding Editor.NewIncident.ActionTaken}" 
                                 Style="{StaticResource ModernInput}" 
                                 TextWrapping="Wrap" AcceptsReturn="True" MinHeight="80" Margin="0,0,0,16"/>
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Row="2" Margin="0,20,0,0">
                    <Button Style="{StaticResource PrimaryButton}" 
                            Command="{Binding Editor.SaveIncidentCommand}" 
                            Content="REPORT INCIDENT" Margin="0,0,0,10"/>
                    <Button Style="{StaticResource SecondaryButton}" 
                            Command="{Binding Editor.ClearFormCommand}" 
                            Content="CANCEL"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.RowSpan="3" Grid.ColumnSpan="2" Visibility="{Binding IsBusy, Converter={StaticResource VisibilityConverter}}" Background="#80000000">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Margin="0,0,0,16"/>
                <TextBlock Text="Loading Incident Data..." Foreground="White"/>
            </StackPanel>
        </Border>
    </Grid>
</infra:BaseListView>
