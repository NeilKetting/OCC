<infra:BaseListView x:Class="OCC.WpfClient.Features.HseqHub.Views.TrainingListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:OCC.WpfClient.Features.HseqHub.ViewModels"
             xmlns:infra="clr-namespace:OCC.WpfClient.Infrastructure"
             xmlns:ap="clr-namespace:OCC.WpfClient.Infrastructure.AttachedProperties"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200">

    <UserControl.Resources>
        <infra:BindingProxy x:Key="Proxy" Data="{Binding}" />
    </UserControl.Resources>

    <Grid Background="{StaticResource BackgroundDark}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="15,20,20,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Path Data="{StaticResource IconTeam}" Width="24" Height="24" Fill="{StaticResource PrimaryTeal}" Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Training Matrix" Style="{StaticResource HeaderText}" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="Create and track training and certificates" Style="{StaticResource LabelText}" Opacity="0.7"/>
            </StackPanel>
            <Button Grid.Column="1" Style="{StaticResource ActionButtonPrimary}" Command="{Binding ToggleAddCommand}" Content="+ ADD TRAINING" VerticalAlignment="Center"/>
        </Grid>

        <!-- Toolbar -->
        <Border Grid.Row="1" Style="{StaticResource GlassCard}" Padding="15,10" Margin="15,0,20,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <!-- Search Icon -->
                    <ColumnDefinition Width="200" />
                    <!-- Search Box -->
                    <ColumnDefinition Width="Auto" />
                    <!-- Category Filter -->
                    <ColumnDefinition Width="Auto" />
                    <!-- Expiry Filter -->
                    <ColumnDefinition Width="*" />
                    <!-- Spacer -->
                    <ColumnDefinition Width="Auto" />
                    <!-- Actions -->
                </Grid.ColumnDefinitions>

                <!-- Search -->
                <Path Grid.Column="0" Data="{StaticResource IconSearch}" Fill="{StaticResource TextSub}" Width="14" Height="14" Margin="5,0,10,0" VerticalAlignment="Center" Stretch="Uniform"/>
                <TextBox Grid.Column="1" Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource ToolbarTextBox}"
                         ap:WatermarkProperties.Watermark="Search training..."/>

                <!-- Category Filter -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="20,0">
                    <TextBlock Text="CATEGORY" VerticalAlignment="Center" FontSize="10" FontWeight="Bold" Foreground="{StaticResource PrimaryTeal}" Margin="0,0,10,0" Opacity="0.8"/>
                    <ComboBox ItemsSource="{Binding Categories}" SelectedItem="{Binding CategoryFilter}" Style="{StaticResource ToolbarComboBox}" Width="150"/>
                </StackPanel>

                <!-- Expiry Warning -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="10,0">
                    <TextBlock Text="EXPIRY WARNING" VerticalAlignment="Center" FontSize="10" FontWeight="Bold" Foreground="{StaticResource PrimaryTeal}" Margin="0,0,10,0" Opacity="0.8"/>
                    <TextBox Text="{Binding ExpiryWarningDays}" Style="{StaticResource ToolbarTextBox}" Width="60" Background="#1AFFFFFF" BorderThickness="1" BorderBrush="{StaticResource GlassBorder}"/>
                    <TextBlock Text="DAYS" VerticalAlignment="Center" FontSize="9" Foreground="{StaticResource TextSub}" Margin="8,0,0,0" Opacity="0.6"/>
                </StackPanel>

                <!-- Actions -->
                <StackPanel Grid.Column="5" Orientation="Horizontal">
                    <ToggleButton Command="{Binding FilterExpiringCommand}" Style="{StaticResource ToolbarToggleButton}" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconClock}" Fill="White" Width="14" Height="14" Stretch="Uniform" Margin="0,0,8,0" Opacity="0.8"/>
                            <TextBlock Text="SHOW EXPIRING" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                        </StackPanel>
                    </ToggleButton>

                    <Grid Margin="0,0,10,0">
                        <ToggleButton x:Name="ColumnsToggle" Style="{StaticResource ToolbarToggleButton}">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconList}" Fill="White" Width="14" Height="14" Stretch="Uniform" Margin="0,0,8,0" Opacity="0.8"/>
                                <TextBlock Text="COLUMNS" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                            </StackPanel>
                        </ToggleButton>
                        <Popup IsOpen="{Binding IsChecked, ElementName=ColumnsToggle}" StaysOpen="False" PlacementTarget="{Binding ElementName=ColumnsToggle}" Placement="Bottom" AllowsTransparency="True" PopupAnimation="Fade">
                            <Border Background="{StaticResource BackgroundDark}" BorderBrush="{StaticResource GlassBorder}" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,5,0,0" Width="200">
                                <StackPanel>
                                    <TextBlock Text="DISPLAY COLUMNS" FontSize="10" FontWeight="Bold" Foreground="{StaticResource PrimaryTeal}" Margin="0,0,0,8"/>
                                    <CheckBox Content="Role / Skill" IsChecked="{Binding IsRoleVisible, Mode=TwoWay}" Style="{StaticResource ModernCheckBox}" Margin="0,2"/>
                                    <CheckBox Content="Trainer" IsChecked="{Binding IsTrainerVisible, Mode=TwoWay}" Style="{StaticResource ModernCheckBox}" Margin="0,2"/>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>

                    <Button Command="{Binding PrintCommand}" Style="{StaticResource ToolbarButton}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconPrint}" Fill="White" Width="14" Height="14" Stretch="Uniform" Margin="0,0,8,0" Opacity="0.8"/>
                            <TextBlock Text="PRINT" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="2" Margin="15,0,20,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Training Records Grid -->
            <Border Grid.Column="0" Style="{StaticResource GlassCard}" Padding="0" Margin="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- DataGrid -->
                    <DataGrid Grid.Row="0" ItemsSource="{Binding Items}"
                               AutoGenerateColumns="False"
                               IsReadOnly="True"
                               HeadersVisibility="Column"
                               GridLinesVisibility="Horizontal"
                               Style="{StaticResource ModernDataGrid}">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                                <Setter Property="ContextMenu">
                                    <Setter.Value>
                                        <ContextMenu>
                                            <MenuItem Header="Delete Training" 
                                                      Command="{Binding DataContext.DeleteTrainingCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                      CommandParameter="{Binding}">
                                                <MenuItem.Icon>
                                                    <Path Data="{StaticResource IconDelete}" Fill="{StaticResource ErrorRed}" Width="14" Height="14" Stretch="Uniform"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                        </ContextMenu>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Employee" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="5">
                                            <Border CornerRadius="12" Width="24" Height="24" Background="{StaticResource PrimaryTeal}" Margin="0,0,10,0">
                                                <TextBlock Text="{Binding EmployeeName[0]}" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="10" FontWeight="Bold"/>
                                            </Border>
                                            <TextBlock Text="{Binding EmployeeName}" VerticalAlignment="Center" Foreground="White"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Skill / Role" Binding="{Binding Role}" Width="*" Visibility="{Binding Data.IsRoleVisible, Source={StaticResource Proxy}, Converter={StaticResource VisibilityConverter}}"/>

                            <DataGridTemplateColumn Header="Expiry Date" Width="Auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="4" Padding="8,2" Background="{Binding IsExpiring, Converter={StaticResource ExpiryColorConverter}}" Margin="5">
                                            <TextBlock Text="{Binding ValidUntil, StringFormat='dd MMM yyyy'}" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="Trainer" Binding="{Binding Trainer}" Width="*" Visibility="{Binding Data.IsTrainerVisible, Source={StaticResource Proxy}, Converter={StaticResource VisibilityConverter}}"/>

                            <DataGridTemplateColumn Header="ACTIONS" Width="Auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button Style="{StaticResource ToolbarIconButton}" 
                                                    Command="{Binding DataContext.OpenTrainingCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                    CommandParameter="{Binding}" ToolTip="View Certificate">
                                                <Path Data="{StaticResource IconEye}" Width="14" Height="14" Fill="{StaticResource TextSub}" Stretch="Uniform"/>
                                            </Button>
                                            <Button Style="{StaticResource ToolbarIconButton}" 
                                                    Command="{Binding DataContext.DeleteTrainingCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                    CommandParameter="{Binding}" ToolTip="Delete">
                                                <Path Data="{StaticResource IconDelete}" Width="14" Height="14" Fill="{StaticResource ErrorRed}" Stretch="Uniform"/>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Editor Side Panel -->
            <Border Grid.Column="1" Style="{StaticResource GlassCard}" Width="500" Margin="20,0,0,0"
                    Visibility="{Binding Editor.IsOpen, Converter={StaticResource VisibilityConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Training Details" Style="{StaticResource HeaderText}" Margin="0,0,0,20"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,0,20,0">
                            <TextBlock Text="Employee" Style="{StaticResource FormLabelText}"/>
                            <ComboBox ItemsSource="{Binding Editor.Employees}" 
                                      SelectedItem="{Binding Editor.SelectedEmployee}"
                                      DisplayMemberPath="DisplayName"
                                      IsEditable="True"
                                      Style="{StaticResource ModernComboBox}"
                                      Margin="0,0,0,16"/>

                            <TextBlock Text="Skill / Role" Style="{StaticResource FormLabelText}"/>
                            <TextBox Text="{Binding Editor.NewRecord.Role}" IsReadOnly="True" Style="{StaticResource ModernInput}" Margin="0,0,0,16"/>

                            <TextBlock Text="Certificate Type" Style="{StaticResource FormLabelText}"/>
                            <ComboBox ItemsSource="{Binding Editor.CertificateTypes}" 
                                      SelectedItem="{Binding Editor.NewRecord.CertificateType}"
                                      Style="{StaticResource ModernComboBox}"
                                      Margin="0,0,0,16">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Converter={StaticResource FriendlyEnumConverter}}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <TextBlock Text="Issue Date" Style="{StaticResource FormLabelText}"/>
                            <DatePicker SelectedDate="{Binding Editor.NewRecord.DateCompleted}" Style="{StaticResource ModernDatePicker}" Margin="0,0,0,16"/>

                            <TextBlock Text="Expiry Date" Style="{StaticResource FormLabelText}"/>
                            <DatePicker SelectedDate="{Binding Editor.NewRecord.ValidUntil}" Style="{StaticResource ModernDatePicker}" Margin="0,0,0,16"/>

                            <TextBlock Text="Trainer / Provider" Style="{StaticResource FormLabelText}"/>
                            <ComboBox ItemsSource="{Binding Editor.Trainers}" 
                                      Text="{Binding Editor.NewRecord.Trainer}"
                                      IsEditable="True"
                                      Style="{StaticResource ModernComboBox}"
                                      Margin="0,0,0,16"/>

                            <TextBlock Text="Certificate Document" Style="{StaticResource FormLabelText}"/>
                            <Button Style="{StaticResource SecondaryButton}" 
                                    Command="{Binding Editor.UploadCertificateCommand}"
                                    Content="Select File" HorizontalAlignment="Stretch" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding Editor.CertificateFileName}" Style="{StaticResource LabelText}" Opacity="0.7" TextWrapping="Wrap" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2" Margin="0,20,0,0">
                        <Button Style="{StaticResource PrimaryButton}" 
                                Command="{Binding Editor.SaveTrainingCommand}" 
                                Content="SAVE RECORD" Margin="0,0,0,10"/>
                        <Button Style="{StaticResource SecondaryButton}" 
                                Command="{Binding Editor.ClearFormCommand}" 
                                Content="CANCEL"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Loading Overlay -->
        <Border Grid.RowSpan="3" Visibility="{Binding IsBusy, Converter={StaticResource VisibilityConverter}}" Background="#80000000">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Margin="0,0,0,16"/>
                <TextBlock Text="Loading Training Data..." Foreground="White"/>
            </StackPanel>
        </Border>
    </Grid>
</infra:BaseListView>
