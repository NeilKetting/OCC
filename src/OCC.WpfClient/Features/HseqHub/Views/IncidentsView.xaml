<UserControl x:Class="OCC.WpfClient.Features.HseqHub.Views.IncidentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:OCC.WpfClient.Features.HseqHub.ViewModels"
             xmlns:dto="clr-namespace:OCC.Shared.DTOs;assembly=OCC.Shared"
             xmlns:infra="clr-namespace:OCC.WpfClient.Infrastructure"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200">

    <UserControl.Resources>
        <infra:BindingProxy x:Key="Proxy" Data="{Binding}" />
    </UserControl.Resources>
    
    <Grid Background="{StaticResource BackgroundDark}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Style="{StaticResource ToolbarBorder}" Margin="20,20,20,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel>
                        <TextBlock Text="Incidents" Style="{StaticResource HeaderText}"/>
                        <TextBlock Text="Report and track workplace incidents" Style="{StaticResource TitleText}" Opacity="0.7"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Search Box -->
                        <Border Background="#20FFFFFF" CornerRadius="4" Margin="0,0,15,0" Width="200" Height="32">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Path Data="{StaticResource IconSearch}" Fill="{StaticResource TextSub}" Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <TextBox Grid.Column="1" Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" BorderThickness="0" Foreground="White" VerticalContentAlignment="Center" CaretBrush="White">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Style.Triggers>
                                                <Trigger Property="Text" Value="">
                                                    <Setter Property="Background">
                                                        <Setter.Value>
                                                            <VisualBrush Stretch="None" AlignmentX="Left">
                                                                <VisualBrush.Visual>
                                                                    <TextBlock Text="Search incidents..." Foreground="{StaticResource TextSub}" Opacity="0.5" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                                                </VisualBrush.Visual>
                                                            </VisualBrush>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                            </Grid>
                        </Border>

                        <!-- Column Toggles -->
                        <Grid Margin="0,0,15,0">
                            <ToggleButton x:Name="ColumnsToggle" Style="{StaticResource ToolbarToggleButton}" Height="28" Padding="10,0">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconList}" Fill="White" Width="14" Height="14" Stretch="Uniform" Margin="0,0,8,0" Opacity="0.8"/>
                                    <TextBlock Text="COLUMNS" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                </StackPanel>
                            </ToggleButton>
                            <Popup IsOpen="{Binding IsChecked, ElementName=ColumnsToggle}" StaysOpen="False" PlacementTarget="{Binding ElementName=ColumnsToggle}" Placement="Bottom" AllowsTransparency="True" PopupAnimation="Fade">
                                <Border Background="{StaticResource BackgroundDark}" BorderBrush="{StaticResource GlassBorder}" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,5,0,0" Width="200">
                                    <StackPanel>
                                        <TextBlock Text="DISPLAY COLUMNS" FontSize="10" FontWeight="Bold" Foreground="{StaticResource PrimaryTeal}" Margin="0,0,0,8"/>
                                        <CheckBox Content="Type" IsChecked="{Binding IsTypeVisible, Mode=TwoWay}" Style="{StaticResource ModernCheckBox}" Margin="0,2"/>
                                        <CheckBox Content="Severity" IsChecked="{Binding IsSeverityVisible, Mode=TwoWay}" Style="{StaticResource ModernCheckBox}" Margin="0,2"/>
                                        <CheckBox Content="Status" IsChecked="{Binding IsStatusVisible, Mode=TwoWay}" Style="{StaticResource ModernCheckBox}" Margin="0,2"/>
                                    </StackPanel>
                                </Border>
                            </Popup>
                        </Grid>

                        <Button Command="{Binding PrintCommand}" Style="{StaticResource ToolbarButton}" Margin="10,0">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconPrint}" Fill="White" Width="14" Height="14" Stretch="Uniform" Margin="0,0,8,0" Opacity="0.8"/>
                                <TextBlock Text="PRINT" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource PrimaryButton}" Command="{Binding ToggleAddCommand}" 
                                Visibility="{Binding Editor.IsOpen, Converter={StaticResource VisibilityConverter}, ConverterParameter='Invert'}"
                                VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconPlus}" Width="14" Height="14" Fill="White" Stretch="Uniform" Margin="0,0,8,0"/>
                                <TextBlock Text="REPORT INCIDENT"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Data Table -->
            <Border Grid.Row="1" Style="{StaticResource ToolbarBorder}" Margin="20">
                <DataGrid ItemsSource="{Binding Items}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          SelectedItem="{Binding SelectedItem}"
                          Style="{StaticResource ModernDataGrid}">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                            <Setter Property="ContextMenu">
                                <Setter.Value>
                                    <ContextMenu>
                                        <MenuItem Header="Delete Incident" 
                                                  Command="{Binding DataContext.DeleteIncidentCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                  CommandParameter="{Binding}">
                                            <MenuItem.Icon>
                                                <Path Data="{StaticResource IconDelete}" Fill="{StaticResource ErrorRed}" Width="14" Height="14" Stretch="Uniform"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                    </ContextMenu>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat='dd MMM yyyy'}" 
                                            Width="Auto"/>
                        <DataGridTextColumn Header="Type" Binding="{Binding Type, Converter={StaticResource FriendlyEnumConverter}}" Width="Auto" 
                                            Visibility="{Binding Data.IsTypeVisible, Source={StaticResource Proxy}, Converter={StaticResource VisibilityConverter}}"/>
                        <DataGridTemplateColumn Header="Severity" Width="Auto" Visibility="{Binding Data.IsSeverityVisible, Source={StaticResource Proxy}, Converter={StaticResource VisibilityConverter}}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="4" Padding="8,4" Background="#20FFFFFF" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="5,0">
                                         <TextBlock Text="{Binding Severity, Converter={StaticResource FriendlyEnumConverter}}" Foreground="White" FontSize="11"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Location" Binding="{Binding Location}" Width="Auto"/>

                        <DataGridTemplateColumn Header="Status" Width="Auto" Visibility="{Binding Data.IsStatusVisible, Source={StaticResource Proxy}, Converter={StaticResource VisibilityConverter}}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="12" Padding="8,2" Background="#20FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center">
                                         <TextBlock Text="{Binding Status, Converter={StaticResource FriendlyEnumConverter}}" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="ACTIONS" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Style="{StaticResource ToolbarIconButton}" 
                                                Command="{Binding DataContext.OpenIncidentCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                CommandParameter="{Binding}" ToolTip="Edit">
                                            <Path Data="{StaticResource IconEdit}" Width="14" Height="14" Fill="{StaticResource TextSub}" Stretch="Uniform"/>
                                        </Button>
                                        <Button Style="{StaticResource ToolbarIconButton}" 
                                                Command="{Binding DataContext.DeleteIncidentCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                CommandParameter="{Binding}" ToolTip="Delete">
                                            <Path Data="{StaticResource IconDelete}" Width="14" Height="14" Fill="{StaticResource ErrorRed}" Stretch="Uniform"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <!-- Loading Overlay -->
        <Border Grid.ColumnSpan="2" Visibility="{Binding IsBusy, Converter={StaticResource VisibilityConverter}}" Background="#80000000" Panel.ZIndex="1000">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Margin="0,0,0,16"/>
                <TextBlock Text="{Binding BusyText}" Foreground="White"/>
            </StackPanel>
        </Border>

        <!-- Side Panel Editor -->
        <Border Grid.Column="1" Style="{StaticResource ToolbarBorder}" Width="500" Margin="0,20,20,20" Background="{StaticResource BackgroundDark}"
                Visibility="{Binding Editor.IsOpen, Converter={StaticResource VisibilityConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="New Incident" Style="{StaticResource HeaderText}" Margin="0,0,0,24"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,20">
                    <StackPanel Margin="0,0,20,0">
                        <TextBlock Text="Date &amp; Time" Style="{StaticResource FormLabelText}"/>
                        <DatePicker SelectedDate="{Binding Editor.Incident.Date}" Style="{StaticResource ModernDatePicker}" Margin="0,0,0,16"/>

                        <ComboBox ItemsSource="{Binding Editor.IncidentTypes}" SelectedItem="{Binding Editor.Incident.Type}" Style="{StaticResource ModernComboBox}" Margin="0,0,0,16">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource FriendlyEnumConverter}}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <TextBlock Text="Severity" Style="{StaticResource FormLabelText}"/>
                        <ComboBox ItemsSource="{Binding Editor.IncidentSeverities}" SelectedItem="{Binding Editor.Incident.Severity}" Style="{StaticResource ModernComboBox}" Margin="0,0,0,16">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource FriendlyEnumConverter}}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <TextBlock Text="Location / Site" Style="{StaticResource FormLabelText}"/>
                        <TextBox Text="{Binding Editor.Incident.Location}" Style="{StaticResource ModernInput}" Margin="0,0,0,16"/>

                        <TextBlock Text="Description" Style="{StaticResource FormLabelText}"/>
                        <TextBox Text="{Binding Editor.Incident.Description}" Style="{StaticResource ModernInput}" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="100" Margin="0,0,0,16"/>

                        <TextBlock Text="Root Cause (Optional)" Style="{StaticResource FormLabelText}"/>
                        <TextBox Text="{Binding Editor.Incident.RootCause}" Style="{StaticResource ModernInput}" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="80" Margin="0,0,0,16"/>

                        <TextBlock Text="Corrective Action (Optional)" Style="{StaticResource FormLabelText}"/>
                        <TextBox Text="{Binding Editor.Incident.CorrectiveAction}" Style="{StaticResource ModernInput}" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="80" Margin="0,0,0,16"/>

                        <Separator Background="{StaticResource GlassBorderUltraLight}" Margin="0,10,0,16"/>
                        
                        <TextBlock Text="INCIDENT PHOTOS" Style="{StaticResource TitleText}" Margin="0,0,0,10"/>
                        <ItemsControl ItemsSource="{Binding Editor.Photos}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource ToolbarBorder}" Background="{StaticResource BackgroundDark}" Margin="0,0,0,8" Padding="10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding FileSize}" Style="{StaticResource LabelText}" Opacity="0.6"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <Button Style="{StaticResource ToolbarIconButton}" Command="{Binding DataContext.Editor.ViewAttachmentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding FilePath}">
                                                    <Path Data="{StaticResource IconEye}" Fill="{StaticResource PrimaryTeal}" Width="14" Height="14" Stretch="Uniform"/>
                                                </Button>
                                                <Button Style="{StaticResource ToolbarIconButton}" Command="{Binding DataContext.Editor.DeletePhotoCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}">
                                                    <Path Data="{StaticResource IconDelete}" Fill="{StaticResource ErrorRed}" Width="14" Height="14" Stretch="Uniform"/>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        
                        <Button Style="{StaticResource SecondaryButton}" HorizontalAlignment="Stretch" Margin="0,10,0,0">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconPlus}" Width="12" Height="12" Fill="White" Stretch="Uniform" Margin="0,0,8,0"/>
                                <TextBlock Text="Add Photo"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Row="2">
                    <Button Style="{StaticResource PrimaryButton}" HorizontalAlignment="Stretch" Command="{Binding Editor.SaveIncidentCommand}" Content="SAVE REPORT" Margin="0,0,0,12"/>
                    <Button Style="{StaticResource SecondaryButton}" HorizontalAlignment="Stretch" Command="{Binding CancelAddCommand}" Content="CANCEL"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>


