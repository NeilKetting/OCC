<infra:BaseListView x:Class="OCC.WpfClient.Features.HseqHub.Views.PerformanceMonitoringListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:OCC.WpfClient.Features.HseqHub.ViewModels"
             xmlns:infra="clr-namespace:OCC.WpfClient.Infrastructure"
             xmlns:ap="clr-namespace:OCC.WpfClient.Infrastructure.AttachedProperties"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200">

    <Grid Background="{StaticResource BackgroundDark}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="15,20,20,10">
            <StackPanel Orientation="Horizontal">
                <Path Data="{StaticResource IconLiveView}" Width="24" Height="24" Fill="{StaticResource PrimaryTeal}" Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Center"/>
                <TextBlock Text="Performance Monitoring" Style="{StaticResource HeaderText}"/>
            </StackPanel>
                <TextBlock Text="Safe work hours and incident frequency tracking" Style="{StaticResource LabelText}" Opacity="0.7"/>
        </StackPanel>

        <!-- Toolbar -->
        <Border Grid.Row="1" Style="{StaticResource GlassCard}" Padding="15,10" Margin="20,0,20,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <!-- Search Icon -->
                    <ColumnDefinition Width="250" />
                    <!-- Search Box -->
                    <ColumnDefinition Width="*" />
                    <!-- Spacer -->
                    <ColumnDefinition Width="Auto" />
                    <!-- Actions -->
                </Grid.ColumnDefinitions>

                <!-- Search -->
                <Path Grid.Column="0" Data="{StaticResource IconSearch}" Fill="{StaticResource TextSub}" Width="14" Height="14" Margin="5,0,10,0" VerticalAlignment="Center" Stretch="Uniform"/>
                <TextBox Grid.Column="1" Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource ToolbarTextBox}"
                         ap:WatermarkProperties.Watermark="Search records..."/>

                <!-- Actions -->
                <StackPanel Grid.Column="3" Orientation="Horizontal">
                    <Button Command="{Binding PrintCommand}" Style="{StaticResource ToolbarButton}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconPrint}" Fill="White" Width="14" Height="14" Stretch="Uniform" Margin="0,0,8,0" Opacity="0.8"/>
                            <TextBlock Text="PRINT" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Data Table -->
        <Border Grid.Row="2" Style="{StaticResource GlassCard}" Padding="0" Margin="15,0,20,20">
            <DataGrid ItemsSource="{Binding SafeHours}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      Style="{StaticResource ModernDataGrid}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Month" Binding="{Binding Month, StringFormat='MMMM yyyy'}" Width="Auto"/>
                    <DataGridTextColumn Header="Safe Hours" Binding="{Binding SafeWorkHours}" Width="Auto"/>
                    <DataGridTextColumn Header="Incidents" Binding="{Binding IncidentReported}" Width="Auto"/>
                    <DataGridTextColumn Header="Near Misses" Binding="{Binding NearMisses}" Width="Auto"/>
                    <DataGridTextColumn Header="Root Cause" Binding="{Binding RootCause}" Width="*"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="Auto"/>
                    <DataGridTextColumn Header="Reported By" Binding="{Binding ReportedBy}" Width="Auto"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.RowSpan="3" Visibility="{Binding IsBusy, Converter={StaticResource VisibilityConverter}}" Background="#80000000">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Margin="0,0,0,16"/>
                <TextBlock Text="Loading Performance Data..." Foreground="White"/>
            </StackPanel>
        </Border>
    </Grid>
</infra:BaseListView>
