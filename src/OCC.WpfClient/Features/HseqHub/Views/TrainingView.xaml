<UserControl x:Class="OCC.WpfClient.Features.HseqHub.Views.TrainingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:OCC.WpfClient.Features.HseqHub.ViewModels"
             xmlns:dto="clr-namespace:OCC.Shared.DTOs;assembly=OCC.Shared"
             xmlns:infra="clr-namespace:OCC.WpfClient.Infrastructure"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1200">

    <UserControl.Resources>
        <infra:BindingProxy x:Key="Proxy" Data="{Binding}" />
    </UserControl.Resources>
    
    <Grid Background="{StaticResource BackgroundDark}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{StaticResource ToolbarBorder}" Margin="20,20,20,0">
            <StackPanel Orientation="Horizontal">
                <Path Data="{StaticResource IconTeam}" Width="24" Height="24" Fill="{StaticResource PrimaryTeal}" Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Center"/>
                <TextBlock Text="Training Matrix" Style="{StaticResource HeaderText}" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <!-- Training Records Grid -->
            <Border Grid.Column="0" Style="{StaticResource ToolbarBorder}" Margin="0,0,20,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Grid Toolbar -->
                    <WrapPanel Grid.Row="0" Margin="0,0,0,15">
                        <StackPanel Orientation="Horizontal" Margin="0,0,15,5">
                            <TextBlock Text="Category:" Style="{StaticResource FormLabelText}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <ComboBox ItemsSource="{Binding Categories}" SelectedItem="{Binding CategoryFilter}" Width="150" Style="{StaticResource CompactComboBox}"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,15,5">
                            <TextBlock Text="Expiry Warning:" Style="{StaticResource FormLabelText}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBox Text="{Binding ExpiryWarningDays}" Width="50" VerticalContentAlignment="Center" Style="{StaticResource CompactTextBox}"/>
                            <TextBlock Text=" Days" Foreground="{StaticResource TextSub}" VerticalAlignment="Center" Margin="5,0,0,0" FontSize="11"/>
                        </StackPanel>

                        <Button Style="{StaticResource SecondaryButton}" Command="{Binding FilterExpiringCommand}" Content="Show Expiring" Height="24" Padding="10,0" FontSize="11" Margin="0,0,8,5"/>
                        <Button Style="{StaticResource SecondaryButton}" Command="{Binding LoadDataCommand}" Content="Reload" Height="24" Padding="10,0" FontSize="11" Margin="0,0,15,5"/>

                        <!-- Column Toggles -->
                        <Grid Margin="0,0,15,5">
                            <ToggleButton x:Name="ColumnsToggle" Style="{StaticResource ToolbarToggleButton}" Height="24" Padding="8,0">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconList}" Fill="White" Width="12" Height="12" Stretch="Uniform" Margin="0,0,6,0" Opacity="0.8"/>
                                    <TextBlock Text="COLUMNS" VerticalAlignment="Center" FontSize="10" FontWeight="SemiBold" Foreground="White"/>
                                </StackPanel>
                            </ToggleButton>
                            <Popup IsOpen="{Binding IsChecked, ElementName=ColumnsToggle}" StaysOpen="False" PlacementTarget="{Binding ElementName=ColumnsToggle}" Placement="Bottom" AllowsTransparency="True" PopupAnimation="Fade">
                                <Border Background="{StaticResource BackgroundDark}" BorderBrush="{StaticResource GlassBorder}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,5,0,0" Width="180">
                                    <StackPanel>
                                        <TextBlock Text="DISPLAY COLUMNS" FontSize="9" FontWeight="Bold" Foreground="{StaticResource PrimaryTeal}" Margin="0,0,0,8"/>
                                        <CheckBox Content="Role / Skill" IsChecked="{Binding IsRoleVisible, Mode=TwoWay}" Style="{StaticResource ModernCheckBox}" Margin="0,2"/>
                                        <CheckBox Content="Trainer" IsChecked="{Binding IsTrainerVisible, Mode=TwoWay}" Style="{StaticResource ModernCheckBox}" Margin="0,2"/>
                                    </StackPanel>
                                </Border>
                            </Popup>
                        </Grid>
                        
                        <Button Style="{StaticResource PrimaryButton}" Command="{Binding ToggleAddCommand}" Content="+ Add Training" Height="24" Padding="10,0" FontSize="11" Margin="0,0,0,5"/>
                    </WrapPanel>

                    <!-- DataGrid -->
                    <DataGrid Grid.Row="1" ItemsSource="{Binding TrainingRecords}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              Style="{StaticResource ModernDataGrid}">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                                <Setter Property="ContextMenu">
                                    <Setter.Value>
                                        <ContextMenu>
                                            <MenuItem Header="Edit Record" Command="{Binding DataContext.EditRecordCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}">
                                                <MenuItem.Icon>
                                                    <Path Data="{StaticResource IconEdit}" Fill="White" Width="14" Height="14" Stretch="Uniform"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="View Certificate" Command="{Binding DataContext.ViewCertificateCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}">
                                                <MenuItem.Icon>
                                                    <Path Data="{StaticResource IconEye}" Fill="White" Width="14" Height="14" Stretch="Uniform"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <Separator Background="{StaticResource GlassBorderUltraLight}"/>
                                            <MenuItem Header="Delete Record" Command="{Binding DataContext.DeleteRecordCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}">
                                                <MenuItem.Icon>
                                                    <Path Data="{StaticResource IconDelete}" Fill="{StaticResource ErrorRed}" Width="14" Height="14" Stretch="Uniform"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                        </ContextMenu>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Employee" Binding="{Binding EmployeeName}" Width="Auto" FontWeight="SemiBold" />
                            <DataGridTextColumn Header="Topic / Skill" Binding="{Binding TrainingTopic}" Width="Auto" />
                            <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="Auto" Visibility="{Binding Data.IsRoleVisible, Source={StaticResource Proxy}, Converter={StaticResource VisibilityConverter}}" />
                            <DataGridTextColumn Header="Trainer" Binding="{Binding Trainer}" Width="Auto" Visibility="{Binding Data.IsTrainerVisible, Source={StaticResource Proxy}, Converter={StaticResource VisibilityConverter}}" />
                            <DataGridTextColumn Header="Issue Date" Binding="{Binding DateCompleted, StringFormat='d MMM yyyy'}" Width="Auto"/>
                            <DataGridTextColumn Header="Expiry Date" Binding="{Binding ValidUntil, StringFormat='d MMM yyyy'}" Width="Auto"/>
                            
                            <DataGridTemplateColumn Header="Validity" Width="Auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="4" Padding="8,4" Background="#20FFFFFF" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="5,0">
                                            <TextBlock Text="{Binding ValidityStatus}" Foreground="White" FontSize="11"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="ACTIONS" Width="Auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button Style="{StaticResource ToolbarIconButton}" 
                                                    Command="{Binding DataContext.ViewCertificateCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                    CommandParameter="{Binding}" 
                                                    Visibility="{Binding HasCertificate, Converter={StaticResource VisibilityConverter}}"
                                                    ToolTip="View Certificate">
                                                <Path Data="{StaticResource IconAttach}" Width="14" Height="14" Fill="{StaticResource PrimaryTeal}" Stretch="Uniform"/>
                                            </Button>
                                            <Button Style="{StaticResource ToolbarIconButton}" 
                                                    Command="{Binding DataContext.EditRecordCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                    CommandParameter="{Binding}"
                                                    ToolTip="Edit">
                                                <Path Data="{StaticResource IconEdit}" Width="14" Height="14" Fill="{StaticResource TextSub}" Stretch="Uniform"/>
                                            </Button>
                                            <Button Style="{StaticResource ToolbarIconButton}" 
                                                    Command="{Binding DataContext.DeleteRecordCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                    CommandParameter="{Binding}"
                                                    ToolTip="Delete">
                                                <Path Data="{StaticResource IconDelete}" Width="14" Height="14" Fill="{StaticResource ErrorRed}" Stretch="Uniform"/>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Editor Side Panel -->
            <Border Grid.Column="1" Style="{StaticResource ToolbarBorder}" Width="350" 
                    Visibility="{Binding Editor.IsOpen, Converter={StaticResource VisibilityConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Training Details" Style="{StaticResource HeaderText}" Margin="0,0,0,20"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Employee" Style="{StaticResource FormLabelText}"/>
                            <ComboBox ItemsSource="{Binding Editor.Employees}" 
                                      SelectedItem="{Binding Editor.SelectedEmployee}"
                                      DisplayMemberPath="DisplayName"
                                      IsEditable="True"
                                      Style="{StaticResource ModernComboBox}"
                                      Margin="0,0,0,16"/>

                            <TextBlock Text="Skill / Role" Style="{StaticResource FormLabelText}"/>
                            <TextBox Text="{Binding Editor.NewRecord.Role}" IsReadOnly="True" Style="{StaticResource ModernInput}" Margin="0,0,0,16"/>

                            <TextBlock Text="Certificate Type" Style="{StaticResource FormLabelText}"/>
                            <ComboBox ItemsSource="{Binding Editor.CertificateTypes}" 
                                      SelectedItem="{Binding Editor.NewRecord.CertificateType}"
                                      Style="{StaticResource ModernComboBox}"
                                      Margin="0,0,0,16"/>

                            <TextBlock Text="Issue Date" Style="{StaticResource FormLabelText}"/>
                            <DatePicker SelectedDate="{Binding Editor.NewRecord.DateCompleted}" Style="{StaticResource ModernDatePicker}" Margin="0,0,0,16"/>

                            <TextBlock Text="Expiry Date" Style="{StaticResource FormLabelText}"/>
                            <DatePicker SelectedDate="{Binding Editor.NewRecord.ValidUntil}" Style="{StaticResource ModernDatePicker}" Margin="0,0,0,16"/>

                            <TextBlock Text="Trainer / Provider" Style="{StaticResource FormLabelText}"/>
                            <ComboBox ItemsSource="{Binding Editor.Trainers}" 
                                      Text="{Binding Editor.NewRecord.Trainer}"
                                      IsEditable="True"
                                      Style="{StaticResource ModernComboBox}"
                                      Margin="0,0,0,16"/>

                            <TextBlock Text="Certificate Document" Style="{StaticResource FormLabelText}"/>
                            <Button Style="{StaticResource SecondaryButton}" 
                                    Command="{Binding Editor.UploadCertificateCommand}"
                                    Content="Select File" HorizontalAlignment="Stretch" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding Editor.CertificateFileName}" Style="{StaticResource LabelText}" Opacity="0.7" TextWrapping="Wrap" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2" Margin="0,20,0,0">
                        <Button Style="{StaticResource PrimaryButton}" 
                                Command="{Binding Editor.SaveTrainingCommand}" 
                                Content="SAVE RECORD" Margin="0,0,0,10"/>
                        <Button Style="{StaticResource SecondaryButton}" 
                                Command="{Binding Editor.ClearFormCommand}" 
                                Content="CANCEL"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Loading Overlay -->
        <Border Grid.RowSpan="2" Visibility="{Binding IsBusy, Converter={StaticResource VisibilityConverter}}" Background="#80000000">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Margin="0,0,0,16"/>
                <TextBlock Text="Loading Training Data..." Foreground="White"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
