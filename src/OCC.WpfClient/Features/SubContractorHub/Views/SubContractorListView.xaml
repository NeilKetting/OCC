<UserControl x:Class="OCC.WpfClient.Features.SubContractorHub.Views.SubContractorListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:OCC.WpfClient.Features.SubContractorHub.ViewModels"
             xmlns:views="clr-namespace:OCC.WpfClient.Features.SubContractorHub.Views"
             xmlns:ap="clr-namespace:OCC.WpfClient.Infrastructure.AttachedProperties"
             xmlns:infra="clr-namespace:OCC.WpfClient.Infrastructure"
             xmlns:conv="clr-namespace:OCC.WpfClient.Infrastructure.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200"
             d:DataContext="{d:DesignInstance Type=vm:SubContractorListViewModel}">

    <UserControl.Resources>
        <DataTemplate DataType="{x:Type vm:SubContractorDetailViewModel}">
            <views:SubContractorDetailView />
        </DataTemplate>
        <infra:BindingProxy x:Key="Proxy" Data="{Binding}" />
        <conv:VisibilityConverter x:Key="VisibilityConverter" />
    </UserControl.Resources>

    <Grid Margin="0" Background="{StaticResource AppBackground}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <!-- Main Background Content -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.Style>
                <Style TargetType="Grid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsOverlayActive}" Value="True">
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <BlurEffect Radius="15"/>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Opacity" Value="0.4"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /> <!-- Header -->
                <RowDefinition Height="Auto" /> <!-- Stats & Search -->
                <RowDefinition Height="*" />    <!-- Grid -->
            </Grid.RowDefinitions>

             <!-- Header -->
            <Grid Grid.Row="0" Margin="10">
                <StackPanel>
                <TextBlock Text="Partners" FontSize="28" FontWeight="Bold" Foreground="White" />
                <TextBlock Text="Manage specialized service providers and trades." Style="{StaticResource FormLabelText}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Style="{StaticResource PrimaryButton}" Command="{Binding AddSubContractorCommand}" Width="180" Height="36" Cursor="Hand">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconPlus}" Fill="White" Width="12" Height="12" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Add Partner" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Stats & Search Line -->
            <Border Grid.Row="1" Style="{StaticResource GlassCard}" Padding="15,10" Margin="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" /> <!-- Search Icon -->
                        <ColumnDefinition Width="250" />  <!-- Search Box -->
                        <ColumnDefinition Width="Auto" /> <!-- Branch Filter -->
                        <ColumnDefinition Width="Auto" /> <!-- Specialty Filter -->
                        <ColumnDefinition Width="Auto" /> <!-- Divider -->
                        <ColumnDefinition Width="Auto" /> <!-- Columns -->
                        <ColumnDefinition Width="*" />    <!-- Spacer -->
                        <ColumnDefinition Width="Auto" /> <!-- Stats -->
                    </Grid.ColumnDefinitions>

                    <!-- Search -->
                    <Path Grid.Column="0" Data="{StaticResource IconSearch}" Fill="{StaticResource TextSub}" Width="14" Height="14" Margin="5,0,10,0" VerticalAlignment="Center" Stretch="Uniform"/>
                    <TextBox Grid.Column="1" Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource ModernInput}" Height="34" Padding="8,0" BorderThickness="0" Background="Transparent"
                             ap:WatermarkProperties.Watermark="Search partners..."/>

                    <!-- Branch Filter -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
                        <ComboBox ItemsSource="{Binding Branches}" SelectedItem="{Binding SelectedBranch}" Style="{StaticResource ModernComboBox}" Width="150" Height="34"/>
                    </StackPanel>

                    <!-- Specialty Filter -->
                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                        <ComboBox ItemsSource="{Binding Specialties}" SelectedItem="{Binding SelectedSpecialty}" Style="{StaticResource ModernComboBox}" Width="180" Height="34"/>
                    </StackPanel>

                    <!-- Columns Selection -->
                    <Grid Grid.Column="4">
                        <ToggleButton x:Name="ColumnsToggle" Style="{StaticResource ToolbarToggleButton}" Width="100" Height="34">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconList}" Fill="White" Width="14" Height="14" Stretch="Uniform" Margin="0,0,8,0" Opacity="0.8"/>
                                <TextBlock Text="COLUMNS" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                            </StackPanel>
                        </ToggleButton>
                        <Popup IsOpen="{Binding IsChecked, ElementName=ColumnsToggle}" StaysOpen="False" PlacementTarget="{Binding ElementName=ColumnsToggle}" Placement="Bottom" AllowsTransparency="True" PopupAnimation="Fade">
                            <Border Background="{StaticResource BackgroundDark}" BorderBrush="{StaticResource GlassBorder}" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,5,0,0" Width="180">
                                <StackPanel>
                                    <TextBlock Text="DISPLAY COLUMNS" FontSize="10" FontWeight="Bold" Foreground="{StaticResource AccentBlue}" Margin="0,0,0,8"/>
                                    <CheckBox Content="Branch" IsChecked="{Binding IsBranchVisible, Mode=TwoWay}" Style="{StaticResource ModernCheckBox}" Margin="0,2"/>
                                    <CheckBox Content="Trade" IsChecked="{Binding IsSpecialtiesVisible, Mode=TwoWay}" Style="{StaticResource ModernCheckBox}" Margin="0,2"/>
                                    <CheckBox Content="Phone" IsChecked="{Binding IsPhoneVisible, Mode=TwoWay}" Style="{StaticResource ModernCheckBox}" Margin="0,2"/>
                                    <CheckBox Content="Email" IsChecked="{Binding IsEmailVisible, Mode=TwoWay}" Style="{StaticResource ModernCheckBox}" Margin="0,2"/>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>
                    
                    <Button Command="{Binding PrintCommand}" Style="{StaticResource ToolbarButton}" Margin="10,0" Grid.Column="5">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconPrint}" Fill="White" Width="14" Height="14" Stretch="Uniform" Margin="0,0,8,0" Opacity="0.8"/>
                            <TextBlock Text="PRINT" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                        </StackPanel>
                    </Button>
                    
                    <!-- Stats -->
                    <StackPanel Grid.Column="7" Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel Margin="20,0,10,0">
                            <TextBlock Text="MATCHED" FontSize="10" Foreground="{StaticResource TextSub}" FontWeight="Bold" HorizontalAlignment="Right"/>
                            <TextBlock Text="{Binding TotalCount}" FontSize="18" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Grid -->
            <Border Grid.Row="2" Style="{StaticResource GlassCard}" Margin="10,5,10,10" HorizontalAlignment="Stretch" CornerRadius="0">
                <DataGrid ItemsSource="{Binding Items}" 
                          SelectedItem="{Binding SelectedItem}"
                          AutoGenerateColumns="False" 
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None"
                          CanUserAddRows="False"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.CanContentScroll="False"
                          Style="{StaticResource ModernDataGrid}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="NAME" Binding="{Binding Name}" Width="Auto" FontWeight="SemiBold" />
                        <DataGridTextColumn Header="BRANCH" Binding="{Binding Branch}" Width="Auto" Visibility="{Binding Data.IsBranchVisible, Source={StaticResource Proxy}, Converter={StaticResource VisibilityConverter}}">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="10,0"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextSub}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="SPECIALTIES" Binding="{Binding Specialties}" Width="Auto" Foreground="{StaticResource AccentBlue}" Visibility="{Binding Data.IsSpecialtiesVisible, Source={StaticResource Proxy}, Converter={StaticResource VisibilityConverter}}"/>
                        <DataGridTextColumn Header="EMAIL" Binding="{Binding Email}" Width="Auto" Foreground="{StaticResource TextSub}" Visibility="{Binding Data.IsEmailVisible, Source={StaticResource Proxy}, Converter={StaticResource VisibilityConverter}}"/>
                        <DataGridTextColumn Header="PHONE" Binding="{Binding Phone}" Width="Auto" Visibility="{Binding Data.IsPhoneVisible, Source={StaticResource Proxy}, Converter={StaticResource VisibilityConverter}}"/>
                        
                        <DataGridTemplateColumn Header="ACTIONS" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Command="{Binding DataContext.EditSubContractorCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                CommandParameter="{Binding}" Style="{StaticResource ToolbarIconButton}" Margin="5" ToolTip="Open Details">
                                            <Path Data="{StaticResource IconExternalLink}" Fill="White" Width="14" Height="14" Stretch="Uniform" Opacity="0.8"/>
                                        </Button>
                                        <Button Command="{Binding DataContext.EditSubContractorCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                CommandParameter="{Binding}" Style="{StaticResource ToolbarIconButton}" Margin="5" ToolTip="Edit">
                                            <Path Data="{StaticResource IconEdit}" Fill="{StaticResource AccentBlue}" Width="14" Height="14" Stretch="Uniform"/>
                                        </Button>
                                        <Button Command="{Binding DataContext.DeleteSubContractorCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                                CommandParameter="{Binding}" Style="{StaticResource ToolbarIconButton}" Margin="5" ToolTip="Delete">
                                            <Path Data="{StaticResource IconTrash}" Fill="{StaticResource ErrorRed}" Width="14" Height="14" Stretch="Uniform"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                            <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                            <Setter Property="ap:CommandProperties.DoubleClickCommand" 
                                    Value="{Binding DataContext.EditSubContractorCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                            <Setter Property="ap:CommandProperties.CommandParameter" Value="{Binding}"/>
                            <Setter Property="ContextMenu">
                                <Setter.Value>
                                    <ContextMenu Style="{StaticResource ModernContextMenu}">
                                        <MenuItem Header="Edit Partner" 
                                                  Command="{Binding Path=PlacementTarget.Tag.EditSubContractorCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding}">
                                            <MenuItem.Icon>
                                                <Path Data="{StaticResource IconEdit}" Fill="{StaticResource AccentBlue}" Width="12" Height="12" Stretch="Uniform"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <Separator Style="{x:Null}" Visibility="Collapsed"/>
                                        <MenuItem Header="Delete Partner" 
                                                  Command="{Binding Path=PlacementTarget.Tag.DeleteSubContractorCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding}"
                                                  Foreground="{StaticResource ErrorRed}">
                                            <MenuItem.Icon>
                                                <Path Data="{StaticResource IconTrash}" Fill="{StaticResource ErrorRed}" Width="12" Height="12" Stretch="Uniform"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                    </ContextMenu>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGrid.RowStyle>
                </DataGrid>
            </Border>

            <!-- Loading Overlay -->
            <Border Grid.Row="2" Background="#80000000" CornerRadius="0" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="200" Height="4" Foreground="{StaticResource AccentBlue}" Background="#20FFFFFF"/>
                    <TextBlock Text="{Binding BusyText}" Foreground="White" Margin="0,15,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Detail View Overlay -->
        <ContentControl Content="{Binding OverlayViewModel}" />
    </Grid>
</UserControl>


