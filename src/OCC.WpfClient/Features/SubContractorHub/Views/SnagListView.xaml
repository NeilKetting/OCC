<UserControl x:Class="OCC.WpfClient.Features.SubContractorHub.Views.SnagListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:OCC.WpfClient.Features.SubContractorHub.ViewModels"
             xmlns:local="clr-namespace:OCC.WpfClient.Features.SubContractorHub.Views"
             xmlns:ap="clr-namespace:OCC.WpfClient.Infrastructure.AttachedProperties"
             xmlns:conv="clr-namespace:OCC.WpfClient.Infrastructure.Converters"
             xmlns:infra="clr-namespace:OCC.WpfClient.Infrastructure"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200"
             d:DataContext="{d:DesignInstance Type=vm:SnagListViewModel}">

    <UserControl.Resources>
        <conv:StatusToColorConverter x:Key="StatusToColorConverter" />
        <conv:VisibilityConverter x:Key="VisibilityConverter" />
        <infra:BindingProxy x:Key="Proxy" Data="{Binding}" />
    </UserControl.Resources>

    <Grid Margin="0" Background="{StaticResource AppBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Header -->
            <RowDefinition Height="Auto" /> <!-- Filters -->
            <RowDefinition Height="*" />    <!-- List -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="20,10">
            <StackPanel>
                <TextBlock Text="Snag Management" FontSize="28" FontWeight="Bold" Foreground="White" />
                <TextBlock Text="Track and resolve post-completion quality issues." Style="{StaticResource FormLabelText}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Style="{StaticResource PrimaryButton}" Command="{Binding AddSnagCommand}" Width="160" Height="36">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource IconPlus}" Fill="White" Width="12" Height="12" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Record Snag" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Filters Bar -->
        <Border Grid.Row="1" Style="{StaticResource GlassCard}" Padding="15,10" Margin="20,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" /> <!-- Search -->
                    <ColumnDefinition Width="200" />
                    <ColumnDefinition Width="Auto" /> <!-- Project Filter -->
                    <ColumnDefinition Width="Auto" /> <!-- Partner Filter -->
                    <ColumnDefinition Width="Auto" /> <!-- Status Filter -->
                    <ColumnDefinition Width="Auto" /> <!-- Columns -->
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" /> <!-- Count -->
                </Grid.ColumnDefinitions>

                <Path Grid.Column="0" Data="{StaticResource IconSearch}" Fill="{StaticResource TextSub}" Width="14" Height="14" Margin="5,0,10,0" VerticalAlignment="Center" Stretch="Uniform"/>
                <TextBox Grid.Column="1" Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource ModernInput}" Height="34" Padding="8,0" BorderThickness="0" Background="Transparent"
                         ap:WatermarkProperties.Watermark="Search snags..."/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="20,0">
                    <ComboBox ItemsSource="{Binding Projects}" SelectedItem="{Binding SelectedFilterProject}" DisplayMemberPath="Name"
                              Style="{StaticResource ModernComboBox}" Width="180" Height="34">
                        <ComboBox.Resources>
                            <Style TargetType="ComboBoxItem" BasedOn="{StaticResource {x:Type ComboBoxItem}}">
                                <Setter Property="Foreground" Value="White"/>
                            </Style>
                        </ComboBox.Resources>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="20,0">
                    <ComboBox ItemsSource="{Binding SubContractors}" SelectedItem="{Binding SelectedFilterSubContractor}" DisplayMemberPath="Name"
                              Style="{StaticResource ModernComboBox}" Width="180" Height="34"/>
                </StackPanel>

                <StackPanel Grid.Column="4" Orientation="Horizontal" Margin="20,0">
                    <ComboBox ItemsSource="{Binding Statuses}" SelectedItem="{Binding SelectedStatus}" 
                              Style="{StaticResource ModernComboBox}" Width="140" Height="34"/>
                </StackPanel>

                <!-- Columns Selection -->
                <Grid Grid.Column="5">
                    <ToggleButton x:Name="ColumnsToggle" Style="{StaticResource ToolbarToggleButton}" Width="100" Height="34">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconList}" Fill="White" Width="14" Height="14" Stretch="Uniform" Margin="0,0,8,0" Opacity="0.8"/>
                            <TextBlock Text="COLUMNS" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                        </StackPanel>
                    </ToggleButton>
                    <Popup IsOpen="{Binding IsChecked, ElementName=ColumnsToggle}" StaysOpen="False" PlacementTarget="{Binding ElementName=ColumnsToggle}" Placement="Bottom" AllowsTransparency="True" PopupAnimation="Fade">
                        <Border Background="{StaticResource BackgroundDark}" BorderBrush="{StaticResource GlassBorder}" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,5,0,0" Width="180">
                            <StackPanel>
                                <TextBlock Text="DISPLAY COLUMNS" FontSize="10" FontWeight="Bold" Foreground="{StaticResource AccentBlue}" Margin="0,0,0,8"/>
                                <CheckBox Content="Status" IsChecked="{Binding IsStatusVisible, Mode=TwoWay}" Style="{StaticResource ModernCheckBox}" Margin="0,2"/>
                                <CheckBox Content="Partner" IsChecked="{Binding IsPartnerVisible, Mode=TwoWay}" Style="{StaticResource ModernCheckBox}" Margin="0,2"/>
                                <CheckBox Content="Project" IsChecked="{Binding IsProjectVisible, Mode=TwoWay}" Style="{StaticResource ModernCheckBox}" Margin="0,2"/>
                                <CheckBox Content="Due Date" IsChecked="{Binding IsDueDateVisible, Mode=TwoWay}" Style="{StaticResource ModernCheckBox}" Margin="0,2"/>
                            </StackPanel>
                        </Border>
                    </Popup>
                  </Grid>
                  
                  <Button Command="{Binding PrintCommand}" Style="{StaticResource ToolbarButton}" Margin="10,0" Grid.Column="6">
                      <StackPanel Orientation="Horizontal">
                          <Path Data="{StaticResource IconPrint}" Fill="White" Width="14" Height="14" Stretch="Uniform" Margin="0,0,8,0" Opacity="0.8"/>
                          <TextBlock Text="PRINT" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                      </StackPanel>
                  </Button>

                <StackPanel Grid.Column="7" VerticalAlignment="Center">
                    <TextBlock Text="TOTAL SNAGS" FontSize="10" Foreground="{StaticResource TextSub}" FontWeight="Bold" HorizontalAlignment="Right"/>
                    <TextBlock Text="{Binding TotalCount}" FontSize="18" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- List View -->
        <Border Grid.Row="2" Style="{StaticResource GlassCard}" Margin="20,10" CornerRadius="0">
            <DataGrid ItemsSource="{Binding Items}" 
                      SelectedItem="{Binding SelectedItem}"
                      AutoGenerateColumns="False" 
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="None"
                      CanUserAddRows="False"
                      Style="{StaticResource ModernDataGrid}">
                <DataGrid.Columns>   

                    <DataGridTextColumn Header="SNAG TITLE" Binding="{Binding Title}" Width="Auto" FontWeight="SemiBold"/>

                    <DataGridTemplateColumn Header="PARTNER" Width="Auto" Visibility="{Binding Data.IsPartnerVisible, Source={StaticResource Proxy}, Converter={StaticResource VisibilityConverter}}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="5">
                                    <Border Width="8" Height="8" CornerRadius="4" Background="{Binding SubContractor.ColorTheme}" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding SubContractor.Name}" Foreground="White"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="PROJECT" Binding="{Binding Project.Name}" Width="Auto" Foreground="{StaticResource TextSub}" Visibility="{Binding Data.IsProjectVisible, Source={StaticResource Proxy}, Converter={StaticResource VisibilityConverter}}"/>

                    <DataGridTemplateColumn Header="STATUS" Width="Auto" Visibility="{Binding Data.IsStatusVisible, Source={StaticResource Proxy}, Converter={StaticResource VisibilityConverter}}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{Binding Status, Converter={StaticResource StatusToColorConverter}, ConverterParameter=0.1}" 
                                     BorderBrush="{Binding Status, Converter={StaticResource StatusToColorConverter}}"
                                     BorderThickness="1" CornerRadius="10" Padding="8,2" HorizontalAlignment="Left" Margin="5">
                                    <TextBlock Text="{Binding Status, Converter={StaticResource FriendlyEnumConverter}}" Foreground="{Binding Status, Converter={StaticResource StatusToColorConverter}}" 
                                            FontSize="11" FontWeight="Bold"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="DUE DATE" Width="Auto" Visibility="{Binding Data.IsDueDateVisible, Source={StaticResource Proxy}, Converter={StaticResource VisibilityConverter}}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DueDate, StringFormat=d}" VerticalAlignment="Center" Margin="5"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="ACTIONS" Width="Auto">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource ToolbarIconButton}" Command="{Binding DataContext.EditSnagCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}">
                                    <Path Data="{StaticResource IconEdit}" Fill="{StaticResource AccentBlue}" Width="14" Height="14" Stretch="Uniform"/>
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.Row="2" Background="#80000000" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Foreground="{StaticResource AccentBlue}" Background="#20FFFFFF"/>
                <TextBlock Text="Loading snag list..." Foreground="White" Margin="0,15,0,0" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Overlay Drawer -->
        <ContentControl Content="{Binding OverlayViewModel}" 
                        Visibility="{Binding IsOverlayVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
            <ContentControl.Resources>
                <DataTemplate DataType="{x:Type vm:SnagDetailViewModel}">
                    <local:SnagDetailView />
                </DataTemplate>
            </ContentControl.Resources>
        </ContentControl>
    </Grid>
</UserControl>


