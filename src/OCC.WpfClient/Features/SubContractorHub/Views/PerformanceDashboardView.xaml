<UserControl x:Class="OCC.WpfClient.Features.SubContractorHub.Views.PerformanceDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:OCC.WpfClient.Features.SubContractorHub.ViewModels"
             xmlns:conv="clr-namespace:OCC.WpfClient.Infrastructure.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200"
             d:DataContext="{d:DesignInstance Type=vm:PerformanceDashboardViewModel}">

    <UserControl.Resources>
        <conv:PercentageToWidthConverter x:Key="PercentageToWidthConverter" />
        <conv:TierToIconConverter x:Key="TierToIconConverter" />
        <conv:TierToColorConverter x:Key="TierToColorConverter" />
    </UserControl.Resources>

    <Grid Background="{StaticResource AppBackground}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="30">
                <!-- Header -->
                <Grid Margin="0,0,0,30">
                    <StackPanel>
                        <TextBlock Text="Partner Performance Hub" FontSize="32" FontWeight="Bold" Foreground="White" />
                        <TextBlock Text="Tiered ranking system based on quality, reliability, and on-time delivery." Style="{StaticResource FormLabelText}"/>
                    </StackPanel>
                    
                    <Border HorizontalAlignment="Right" VerticalAlignment="Center" Background="#10FFFFFF" CornerRadius="8" Padding="15,8">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Fill="{StaticResource SuccessGreen}" Margin="0,0,10,0">
                                <Ellipse.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0.3" Duration="0:0:1" AutoReverse="True"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Ellipse.Triggers>
                            </Ellipse>
                            <TextBlock Text="LIVE QUALITY TRACKING" Foreground="{StaticResource TextSub}" FontSize="11" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Tier Summary Cards -->
                <UniformGrid Columns="4" Margin="0,0,0,30">
                    <!-- Top Tier -->
                    <Border Style="{StaticResource GlassCard}" Margin="0,0,15,0" Padding="20" BorderBrush="#B9F2FF" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="DIAMOND PARTNERS" FontSize="11" Foreground="#B9F2FF" FontWeight="Bold"/>
                            <StackPanel Orientation="Horizontal" Margin="0,10">
                                <Path Data="{StaticResource IconDiamond}" Fill="#B9F2FF" Width="24" Height="24" Stretch="Uniform" Margin="0,0,10,0"/>
                                <TextBlock Text="{Binding DiamondCount}" FontSize="42" FontWeight="Bold" Foreground="White"/>
                            </StackPanel>
                            <TextBlock Text="Unmatched Quality" FontSize="11" Foreground="{StaticResource TextSub}"/>
                        </StackPanel>
                    </Border>

                    <!-- Gold -->
                    <Border Style="{StaticResource GlassCard}" Margin="0,0,15,0" Padding="20" BorderBrush="#FFD700" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="GOLD PARTNERS" FontSize="11" Foreground="#FFD700" FontWeight="Bold"/>
                            <StackPanel Orientation="Horizontal" Margin="0,10">
                                <Path Data="{StaticResource IconMedal}" Fill="#FFD700" Width="24" Height="24" Stretch="Uniform" Margin="0,0,10,0"/>
                                <TextBlock Text="{Binding GoldCount}" FontSize="42" FontWeight="Bold" Foreground="White"/>
                            </StackPanel>
                            <TextBlock Text="High Performance" FontSize="11" Foreground="{StaticResource TextSub}"/>
                        </StackPanel>
                    </Border>

                    <!-- Silver -->
                    <Border Style="{StaticResource GlassCard}" Margin="0,0,15,0" Padding="20" BorderBrush="#C0C0C0" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="SILVER PARTNERS" FontSize="11" Foreground="#C0C0C0" FontWeight="Bold"/>
                            <StackPanel Orientation="Horizontal" Margin="0,10">
                                <Path Data="{StaticResource IconMedal}" Fill="#C0C0C0" Width="24" Height="24" Stretch="Uniform" Margin="0,0,10,0"/>
                                <TextBlock Text="{Binding SilverCount}" FontSize="42" FontWeight="Bold" Foreground="White"/>
                            </StackPanel>
                            <TextBlock Text="Reliable Standard" FontSize="11" Foreground="{StaticResource TextSub}"/>
                        </StackPanel>
                    </Border>

                    <!-- Bronze -->
                    <Border Style="{StaticResource GlassCard}" Padding="20" BorderBrush="#CD7F32" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="BRONZE PARTNERS" FontSize="11" Foreground="#CD7F32" FontWeight="Bold"/>
                            <StackPanel Orientation="Horizontal" Margin="0,10">
                                <Path Data="{StaticResource IconMedal}" Fill="#CD7F32" Width="24" Height="24" Stretch="Uniform" Margin="0,0,10,0"/>
                                <TextBlock Text="{Binding BronzeCount}" FontSize="42" FontWeight="Bold" Foreground="White"/>
                            </StackPanel>
                            <TextBlock Text="Improvement Needed" FontSize="11" Foreground="{StaticResource TextSub}"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Detailed Breakdowns -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <!-- Partners List -->
                    <Border Grid.Column="0" Style="{StaticResource GlassCard}" Margin="0,0,15,0" Padding="25">
                        <StackPanel>
                            <Grid Margin="0,0,0,20">
                                <TextBlock Text="Partner Performance Rankings" FontSize="20" FontWeight="Bold" Foreground="White"/>
                                <Button Content="View Snag History" HorizontalAlignment="Right" Style="{StaticResource SecondaryButton}" Padding="10,0" Width="140" Height="28"/>
                            </Grid>

                            <ItemsControl ItemsSource="{Binding TopPerformers}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#05FFFFFF" Margin="0,0,0,10" Padding="15" CornerRadius="8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20" Background="{Binding ColorTheme}" Opacity="0.8" Margin="0,0,15,0">
                                                    <TextBlock Text="{Binding Name[0]}" Foreground="White" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="18"/>
                                                </Border>

                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" Foreground="White" FontWeight="SemiBold" FontSize="16"/>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Path Data="{Binding PerformanceTier, Converter={StaticResource TierToIconConverter}}" 
                                                              Fill="{Binding PerformanceTier, Converter={StaticResource TierToColorConverter}}" 
                                                              Width="12" Height="12" Stretch="Uniform" Margin="0,0,5,0"/>
                                                        <TextBlock Text="{Binding PerformanceTier}" Foreground="{Binding PerformanceTier, Converter={StaticResource TierToColorConverter}}" FontSize="11" FontWeight="Bold"/>
                                                        <TextBlock Text=" • " Foreground="{StaticResource TextSub}"/>
                                                        <TextBlock Text="{Binding Specialties}" Foreground="{StaticResource TextSub}" FontSize="11" TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                </StackPanel>

                                                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="30,0">
                                                    <TextBlock Text="SCORE" FontSize="9" Foreground="{StaticResource TextSub}" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Rating, StringFormat=N1}" Foreground="White" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="3" VerticalAlignment="Center">
                                                    <TextBlock Text="ON-TIME" FontSize="9" Foreground="{StaticResource TextSub}" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="{Binding OnTimeRate, StringFormat={}{0:P0}}" Foreground="{StaticResource SuccessGreen}" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Alert / Low Performer Sidebar -->
                    <StackPanel Grid.Column="1">
                        <Border Style="{StaticResource GlassCard}" Padding="20" 
                                MinHeight="250"
                                Background="#10EE4444" 
                                BorderBrush="{StaticResource ErrorRed}" BorderThickness="1" Margin="0,0,0,15">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                    <Path Data="{StaticResource IconAlertTriangle}" Fill="{StaticResource ErrorRed}" Width="16" Height="16" Stretch="Uniform" Margin="0,0,10,0"/>
                                    <TextBlock Text="Performance Alerts" Foreground="{StaticResource ErrorRed}" FontWeight="Bold"/>
                                </StackPanel>
                                <ItemsControl ItemsSource="{Binding LowPerformers}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,12">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}" Foreground="White" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding Rating, StringFormat='Rating: {0:N1}'}" FontSize="11" Foreground="{StaticResource TextSub}"/>
                                                </StackPanel>
                                                <Button Content="Inspect" HorizontalAlignment="Right" Style="{StaticResource ToolbarIconButton}" Foreground="{StaticResource ErrorRed}" FontSize="10"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
