<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:OCC.Client.Mobile.Shell.BottomNav"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="700"
             x:Class="OCC.Client.Mobile.Shell.BottomNav.MobileShellBottomNavView"
             x:DataType="vm:MobileShellBottomNavViewModel">
    <Grid RowDefinitions="*, Auto" Background="{DynamicResource PremiumMainBackground}">
        <!-- Content -->
        <ContentControl Grid.Row="0" Content="{Binding CurrentView}"/>
        
        <!-- Premium Bottom Nav -->
        <Border Grid.Row="1" Background="#1E293B" BorderBrush="#334155" BorderThickness="0,1,0,0" Padding="15,12,15,25">
            <UniformGrid Columns="2">
                <Button Command="{Binding NavigateToDashboardCommand}" Background="Transparent" BorderThickness="0" Padding="0">
                    <StackPanel Spacing="6">
                        <PathIcon Data="{StaticResource IconDashboard}" Width="24" Height="24" Foreground="#F97316"/>
                        <TextBlock Text="DASHBOARD" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" Foreground="White" LetterSpacing="1.2"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding NavigateToRollCallCommand}" Background="Transparent" BorderThickness="0" Padding="0">
                    <StackPanel Spacing="6">
                        <PathIcon Data="{StaticResource IconTeam}" Width="24" Height="24" Foreground="#94A3B8"/>
                        <TextBlock Text="ROLL CALL" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#94A3B8" LetterSpacing="1.2"/>
                    </StackPanel>
                </Button>
            </UniformGrid>
        </Border>
    </Grid>
</UserControl>
