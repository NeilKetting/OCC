<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:OCC.Client.Mobile.Features.Auth.Login"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="800"
             x:Class="OCC.Client.Mobile.Features.Auth.Login.MobileLoginView"
             x:DataType="vm:MobileLoginViewModel">
    <UserControl.Background>
        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
            <GradientStop Offset="0" Color="#0F172A"/>
            <GradientStop Offset="1" Color="#1E293B"/>
        </LinearGradientBrush>
    </UserControl.Background>

    <Grid>
        <!-- Background Decorative Element -->
        <Border Height="400" VerticalAlignment="Top">
            <Border.Background>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                    <GradientStop Offset="0" Color="#2563EB"/>
                    <GradientStop Offset="1" Color="Transparent"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.OpacityMask>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                    <GradientStop Offset="0" Color="Black"/>
                    <GradientStop Offset="1" Color="Transparent"/>
                </LinearGradientBrush>
            </Border.OpacityMask>
        </Border>

        <ScrollViewer>
            <Border Padding="35,100,35,40">
                <StackPanel Spacing="40">
                
                <!-- Branding -->
                <StackPanel Spacing="15" HorizontalAlignment="Center">
                    <Border Width="100" Height="100" CornerRadius="25" Background="White">
                        <Image Source="avares://OCC.Client/Assets/Images/occ_logo2.png" Margin="15"/>
                    </Border>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="OPERATIONS" FontSize="14" FontWeight="Bold" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                        <TextBlock Text="CENTER" FontSize="32" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <!-- Login Card -->
                <Border Background="#1E293B" CornerRadius="24" Padding="25" BorderBrush="#334155" BorderThickness="1">
                    <StackPanel Spacing="25">
                        <TextBlock Text="Authorized Access" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                        
                        <StackPanel Spacing="15">
                            <StackPanel Spacing="8">
                                <TextBlock Text="EMAIL ADDRESS" FontSize="11" FontWeight="Bold" Foreground="#64748B"/>
                                <TextBox Text="{Binding Email}" Watermark="name@company.com" Height="50" CornerRadius="12" Background="#0F172A" BorderThickness="0" Foreground="White"/>
                            </StackPanel>

                            <StackPanel Spacing="8">
                                <TextBlock Text="SECURITY KEY" FontSize="11" FontWeight="Bold" Foreground="#64748B"/>
                                <TextBox Text="{Binding Password}" PasswordChar="*" Watermark="••••••••" Height="50" CornerRadius="12" Background="#0F172A" BorderThickness="0" Foreground="White"/>
                            </StackPanel>
                            
                            <CheckBox IsChecked="{Binding RememberMe}" Content="Remember this device" Foreground="#94A3B8" FontSize="13"/>
                        </StackPanel>

                        <Button Command="{Binding LoginCommand}" Height="55" CornerRadius="15" BorderThickness="0">
                            <Button.Background>
                                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                                    <GradientStop Offset="0" Color="#F97316"/>
                                    <GradientStop Offset="1" Color="#EC4899"/>
                                </LinearGradientBrush>
                            </Button.Background>
                            <TextBlock Text="SIGN IN" FontWeight="Bold" FontSize="16" Foreground="White"/>
                        </Button>
                    </StackPanel>
                </Border>

                <TextBlock Text="Secure Connection v2.1.8" FontSize="12" Foreground="#475569" HorizontalAlignment="Center" Margin="0,20,0,0"/>
            </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Border IsVisible="{Binding IsBusy}" Background="#F00F172A">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20">
                <ProgressBar IsIndeterminate="True" Width="100" Height="4" Foreground="#F97316"/>
                <TextBlock Text="Verifying Credentials..." Foreground="White" FontSize="14" FontWeight="SemiBold"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
