<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:OCC.Client.Mobile.Features.Dashboard"
             xmlns:models="using:OCC.Shared.Models"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="800"
             x:Class="OCC.Client.Mobile.Features.Dashboard.SiteManagerDashboardView"
             x:DataType="vm:SiteManagerDashboardViewModel"
             Background="#0F172A">
    
    <Grid RowDefinitions="Auto, *">
        <!-- Premium Header -->
        <Border Grid.Row="0" Padding="25,40,25,25" Background="#1E293B">
            <StackPanel Spacing="5">
                <Grid ColumnDefinitions="*, Auto">
                    <TextBlock Text="Site Manager" FontSize="14" FontWeight="SemiBold" Foreground="#94A3B8"/>
                    <Button Grid.Column="1" Command="{Binding RefreshCommand}" Background="Transparent" Padding="0">
                        <PathIcon Data="{StaticResource IconRefresh}" Width="20" Height="20" Foreground="#F97316"/>
                    </Button>
                </Grid>
                <TextBlock Text="Operations Center" FontSize="26" FontWeight="Bold" Foreground="White"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1">
            <StackPanel Spacing="25" Margin="20">
                
                <!-- Daily Crew Module (Clock-In) -->
                <Border Background="#1E293B" CornerRadius="16" Padding="20">
                    <StackPanel Spacing="15">
                        <Grid ColumnDefinitions="*, Auto">
                            <TextBlock Text="Daily Crew" FontSize="18" FontWeight="Bold" Foreground="White"/>
                            <Button Grid.Column="1" Content="Clock In" Classes="Primary" Padding="12,6" FontSize="12" CornerRadius="8" Background="#F97316"/>
                        </Grid>
                        <ItemsControl ItemsSource="{Binding OverdueTasks}" MaxHeight="60">
                            <!-- Placeholder for Crew Avatars -->
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="-10"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="40" Height="40" CornerRadius="20" BorderBrush="#1E293B" BorderThickness="2" Background="#334155">
                                        <TextBlock Text="JD" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" Foreground="White"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Status Categories -->
                <StackPanel Spacing="15">
                    
                    <!-- Overdue Tasks -->
                    <Expander Header="Overdue Tasks" IsExpanded="True" IsVisible="{Binding OverdueTasks.Count}" 
                              Background="Transparent" BorderThickness="0" Padding="0">
                        <ItemsControl ItemsSource="{Binding OverdueTasks}" Margin="0,10,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:DashboardTaskViewModel">
                                    <Border Background="#334155" CornerRadius="12" Padding="15" Margin="0,0,0,10" BorderBrush="#EF4444" BorderThickness="1">
                                        <Grid ColumnDefinitions="*, Auto">
                                            <StackPanel Spacing="5">
                                                <TextBlock Text="{Binding Task.Name}" FontWeight="Bold" Foreground="White"/>
                                                <TextBlock Text="{Binding Task.Priority}" FontSize="12" Foreground="#EF4444"/>
                                            </StackPanel>
                                            <Button Grid.Column="1" Command="{Binding ToggleStatusCommand}" Classes="IconButton">
                                                <PathIcon Data="{StaticResource IconCheck}" Foreground="#94A3B8"/>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Expander>

                    <!-- Due Today -->
                    <Expander Header="Due Today" IsExpanded="True" 
                              Background="Transparent" BorderThickness="0" Padding="0">
                        <ItemsControl ItemsSource="{Binding TodayTasks}" Margin="0,10,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:DashboardTaskViewModel">
                                    <Border Background="#1E293B" CornerRadius="12" Padding="15" Margin="0,0,0,10">
                                        <Grid ColumnDefinitions="*, Auto">
                                            <StackPanel Spacing="5">
                                                <TextBlock Text="{Binding Task.Name}" FontWeight="Bold" Foreground="White"/>
                                                <TextBlock Text="Finishing Today" FontSize="12" Foreground="#F97316"/>
                                            </StackPanel>
                                            <Button Grid.Column="1" Command="{Binding ToggleStatusCommand}" Classes="IconButton">
                                                <PathIcon Data="{StaticResource IconCheck}" Foreground="#94A3B8"/>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Expander>

                    <!-- On Hold -->
                    <Expander Header="On Hold" IsExpanded="False" IsVisible="{Binding OnHoldTasks.Count}" 
                              Background="Transparent" BorderThickness="0" Padding="0">
                        <ItemsControl ItemsSource="{Binding OnHoldTasks}" Margin="0,10,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:DashboardTaskViewModel">
                                    <Border Background="#1E293B" CornerRadius="12" Padding="15" Margin="0,0,0,10" Opacity="0.7">
                                        <StackPanel Spacing="5">
                                            <TextBlock Text="{Binding Task.Name}" FontWeight="Bold" Foreground="#94A3B8"/>
                                            <TextBlock Text="{Binding Task.HoldReason}" FontSize="11" Foreground="#64748B" FontStyle="Italic"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Expander>

                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Busy Overlay -->
        <Border Grid.Row="1" IsVisible="{Binding IsBusy}" Background="#B00F172A">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
                <ProgressBar IsIndeterminate="True" Width="100" Height="4" Foreground="#F97316"/>
                <TextBlock Text="Syncing Field Data..." Foreground="White" FontSize="12"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
