<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:OCC.Client.Mobile.Features.Dashboard"
             xmlns:models="using:OCC.Shared.Models"
             xmlns:dtos="using:OCC.Shared.DTOs"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="800"
             x:Class="OCC.Client.Mobile.Features.Dashboard.SiteManagerDashboardView"
             x:DataType="vm:SiteManagerDashboardViewModel">
    <UserControl.Background>
        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
            <GradientStop Offset="0" Color="#0F172A"/>
            <GradientStop Offset="1" Color="#1E293B"/>
        </LinearGradientBrush>
    </UserControl.Background>

    <Grid RowDefinitions="Auto, *">
        <!-- Header -->
        <Border Grid.Row="0" Padding="25,50,25,20">
            <Grid ColumnDefinitions="*, Auto">
                <StackPanel Spacing="5">
                    <TextBlock Text="Site Manager" FontSize="12" FontWeight="Bold" Foreground="#94A3B8"/>
                    <TextBlock Text="Operations Center" FontSize="26" FontWeight="Bold" Foreground="White"/>
                </StackPanel>
                
                <Button Grid.Column="1" Command="{Binding RefreshCommand}" Background="Transparent" Padding="8">
                    <PathIcon Data="{StaticResource IconRefresh}" Width="22" Height="22" Foreground="#F97316"/>
                </Button>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1">
            <Border Padding="25,10,25,30">
                <StackPanel Spacing="30">
                    
                    <!-- Active Projects Section -->
                    <StackPanel Spacing="15">
                        <TextBlock Text="ACTIVE PROJECTS" FontSize="11" FontWeight="Bold" Foreground="#64748B"/>
                        
                        <ItemsControl ItemsSource="{Binding Projects}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:DashboardProjectViewModel">
                                    <Border Background="#1E293B" CornerRadius="20" Padding="20" Margin="0,0,0,15"
                                            BorderBrush="#334155" BorderThickness="1">
                                        <StackPanel Spacing="18">
                                            <Grid ColumnDefinitions="*, Auto">
                                                <StackPanel Spacing="4">
                                                    <Button Command="{Binding $parent[UserControl].((vm:SiteManagerDashboardViewModel)DataContext).NavigateToProjectCommand}" 
                                                            CommandParameter="{Binding Project}"
                                                            Background="Transparent" Padding="0" HorizontalAlignment="Left">
                                                        <TextBlock Text="{Binding Project.Name}" FontSize="18" FontWeight="Bold" Foreground="White" TextWrapping="Wrap"/>
                                                    </Button>
                                                    <TextBlock Text="{Binding Project.Status}" FontSize="12" Foreground="#94A3B8"/>
                                                </StackPanel>
                                                
                                                <Border Grid.Column="1" CornerRadius="12" Padding="10,5">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                                                            <GradientStop Offset="0" Color="#10B981"/>
                                                            <GradientStop Offset="1" Color="#059669"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                    <TextBlock Text="{Binding Project.Progress, StringFormat='{}{0}%'}" FontSize="12" FontWeight="Bold" Foreground="White"/>
                                                </Border>
                                            </Grid>
                                            
                                            <!-- Dynamic Progress Bar -->
                                            <Border x:Name="ProgressBarContainer" Height="8" Background="#334155" CornerRadius="4" ClipToBounds="True">
                                                <Border HorizontalAlignment="Left" CornerRadius="4">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                                                            <GradientStop Offset="0" Color="#F97316"/>
                                                            <GradientStop Offset="1" Color="#EC4899"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                    <Border.Width>
                                                        <MultiBinding Converter="{StaticResource PercentageToWidthConverter}">
                                                            <Binding Path="Project.Progress"/>
                                                            <Binding Path="Bounds.Width" ElementName="ProgressBarContainer"/>
                                                        </MultiBinding>
                                                    </Border.Width>
                                                </Border>
                                            </Border>

                                            <Grid ColumnDefinitions="*, Auto">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <PathIcon Data="{StaticResource IconTeam}" Width="14" Height="14" Foreground="#94A3B8"/>
                                                    <TextBlock Text="Daily Crew" FontSize="13" Foreground="#94A3B8"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" Text="Manage" FontSize="12" FontWeight="Bold" Foreground="#F97316"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Tasks Section -->
                    <Grid ColumnDefinitions="*, Auto" Margin="0,10,0,0">
                        <TextBlock Text="OVERDUE TASKS" FontSize="11" FontWeight="Bold" Foreground="#64748B"/>
                        <Border Grid.Column="1" Background="#EF4444" CornerRadius="10" Padding="8,2" IsVisible="{Binding OverdueTasks.Count}">
                            <TextBlock Text="{Binding OverdueTasks.Count}" FontSize="10" FontWeight="Bold" Foreground="White"/>
                        </Border>
                    </Grid>

                    <ItemsControl ItemsSource="{Binding OverdueTasks}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:DashboardTaskViewModel">
                                <Border Background="#1E293B" CornerRadius="16" Padding="15" Margin="0,0,0,10"
                                        BorderBrush="#2D1B1B" BorderThickness="1">
                                    <Grid ColumnDefinitions="*, Auto">
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="{Binding Task.Name}" FontWeight="Bold" Foreground="White"/>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{Binding Task.Project.Name}" FontSize="12" Foreground="#94A3B8"/>
                                                <TextBlock Text="•" FontSize="12" Foreground="#64748B"/>
                                                <TextBlock Text="{Binding Task.Priority}" FontSize="12" FontWeight="Bold" Foreground="#EF4444"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <Button Grid.Column="1" Command="{Binding ToggleStatusCommand}" Classes="IconButton" VerticalAlignment="Center">
                                            <PathIcon Data="{StaticResource IconCheck}" Foreground="#64748B" Width="18" Height="18"/>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="{Binding DiagnosticInfo}" FontSize="10" Foreground="#475569" TextWrapping="Wrap" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>
