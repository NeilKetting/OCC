<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:OCC.Client.Mobile.Features.Dashboard"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="800"
             x:Class="OCC.Client.Mobile.Features.Dashboard.MobileProjectDetailView"
             x:DataType="vm:MobileProjectDetailViewModel">
    <UserControl.Background>
        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
            <GradientStop Offset="0" Color="#0F172A"/>
            <GradientStop Offset="1" Color="#1E293B"/>
        </LinearGradientBrush>
    </UserControl.Background>
    
    <Grid RowDefinitions="Auto, *">
        <!-- Header -->
        <Border Grid.Row="0" Padding="20,50,20,25" Background="#1E293B" CornerRadius="0,0,30,30">
            <StackPanel Spacing="20">
                <Grid ColumnDefinitions="Auto, *">
                    <Button Command="{Binding GoBackCommand}" Background="Transparent" Padding="8" Margin="0,0,10,0">
                        <PathIcon Data="{StaticResource IconBack}" Width="20" Height="20" Foreground="#94A3B8"/>
                    </Button>
                    <TextBlock Grid.Column="1" Text="{Binding Project.Name}" FontSize="22" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" TextWrapping="Wrap"/>
                </Grid>
                
                <!-- Stats Row -->
                <Grid ColumnDefinitions="*, *, *">
                    <StackPanel Spacing="4">
                        <TextBlock Text="HEALTH" FontSize="10" FontWeight="Bold" Foreground="#64748B"/>
                        <TextBlock Text="Excellent" FontSize="14" FontWeight="Bold" Foreground="#10B981"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="4">
                        <TextBlock Text="PROGRESS" FontSize="10" FontWeight="Bold" Foreground="#64748B"/>
                        <TextBlock Text="{Binding Progress, StringFormat='{}{0}%'}" FontSize="14" FontWeight="Bold" Foreground="#F97316"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="4">
                        <TextBlock Text="LOCATION" FontSize="10" FontWeight="Bold" Foreground="#64748B"/>
                        <TextBlock Text="{Binding Project.City}" FontSize="14" FontWeight="Bold" Foreground="White"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1">
            <Border Padding="25">
                <StackPanel Spacing="30">
                    
                    <!-- Site Info Card -->
                    <Border Background="#1E293B" CornerRadius="20" Padding="20" BorderBrush="#334155" BorderThickness="1">
                        <StackPanel Spacing="15">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Border Background="#263449" CornerRadius="8" Padding="8">
                                    <PathIcon Data="{StaticResource IconLocation}" Width="16" Height="16" Foreground="#F97316"/>
                                </Border>
                                <TextBlock Text="Project Location" FontSize="16" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="{Binding Project.FullAddress}" FontSize="14" Foreground="#94A3B8" TextWrapping="Wrap" LineHeight="22"/>
                        </StackPanel>
                    </Border>

                    <!-- Tasks Section -->
                    <StackPanel Spacing="18">
                        <TextBlock Text="SITE ACTIVITIES" FontSize="11" FontWeight="Bold" Foreground="#64748B"/>
                        
                        <ItemsControl ItemsSource="{Binding Tasks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:DashboardTaskViewModel">
                                    <Border Background="#1E293B" CornerRadius="16" Padding="18" Margin="0,0,0,12"
                                            BorderBrush="#334155" BorderThickness="1">
                                        <StackPanel Spacing="15">
                                            <Grid ColumnDefinitions="*, Auto">
                                                <StackPanel Spacing="4">
                                                    <TextBlock Text="{Binding Task.Name}" FontWeight="Bold" Foreground="White"/>
                                                    <TextBlock Text="{Binding Task.Status}" FontSize="12" FontWeight="SemiBold" Foreground="{Binding Task.StatusColor}"/>
                                                </StackPanel>
                                                <Button Grid.Column="1" Command="{Binding ToggleStatusCommand}" Background="Transparent" Padding="5">
                                                    <PathIcon Data="{StaticResource IconCheck}" Foreground="#94A3B8" Width="20" Height="20"/>
                                                </Button>
                                            </Grid>
                                            
                                            <!-- Mini Progress Bar -->
                                            <Border x:Name="MiniProgressBar" Height="6" Background="#334155" CornerRadius="3" ClipToBounds="True">
                                                <Border HorizontalAlignment="Left" CornerRadius="3">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                                                            <GradientStop Offset="0" Color="#F97316"/>
                                                            <GradientStop Offset="1" Color="#EC4899"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                    <Border.Width>
                                                        <MultiBinding Converter="{StaticResource PercentageToWidthConverter}">
                                                            <Binding Path="Task.PercentComplete"/>
                                                            <Binding Path="Bounds.Width" ElementName="MiniProgressBar"/>
                                                        </MultiBinding>
                                                    </Border.Width>
                                                </Border>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Border Grid.RowSpan="2" IsVisible="{Binding IsBusy}" Background="#F00F172A">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20">
                <ProgressBar IsIndeterminate="True" Width="120" Height="4" Foreground="#F97316"/>
                <TextBlock Text="Synchronizing Site Data..." Foreground="White" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
