<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Design.PreviewWith>
        <Border Padding="20">
            <StackPanel Spacing="10">
                <Button Classes="primary" Content="Primary Button" Width="200"/>
                <TextBox PlaceholderText="Standard TextBox" Width="200"/>
            </StackPanel>
        </Border>
    </Design.PreviewWith>

    <!-- Brand Colors (Official WPF Palette) -->
    <Styles.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="BrandOrangeBrush" Color="#FF8F00"/>
                    <SolidColorBrush x:Key="BrandDarkBrush" Color="#262E3F"/>
                    <SolidColorBrush x:Key="BrandDarkerBrush" Color="#080E1A"/>
                    <SolidColorBrush x:Key="BrandSlateBrush" Color="#1A1F2B"/>
                    <SolidColorBrush x:Key="BrandAccentBlueBrush" Color="#2E9DFF"/>
                    <SolidColorBrush x:Key="BrandTextBrush" Color="#FFFFFF"/>
                    <SolidColorBrush x:Key="BrandSubTextBrush" Color="#A0FFFFFF"/>
                    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#1A1F2B"/>
                    <SolidColorBrush x:Key="InputBorderBrush" Color="#33475A6B"/>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="BrandOrangeBrush" Color="#FF8F00"/>
                    <SolidColorBrush x:Key="BrandDarkBrush" Color="#F8FAFC"/>
                    <SolidColorBrush x:Key="BrandDarkerBrush" Color="#F1F5F9"/>
                    <SolidColorBrush x:Key="BrandSlateBrush" Color="#E2E8F0"/>
                    <SolidColorBrush x:Key="BrandAccentBlueBrush" Color="#0284C7"/>
                    <SolidColorBrush x:Key="BrandTextBrush" Color="#0F172A"/>
                    <SolidColorBrush x:Key="BrandSubTextBrush" Color="#64748B"/>
                    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#FFFFFF"/>
                    <SolidColorBrush x:Key="InputBorderBrush" Color="#CBD5E1"/>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Styles.Resources>

    <!-- Base Alignment Styles -->
    <Style Selector="TextBlock">
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <Style Selector="Label">
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Global Button Styles -->
    <Style Selector="Button.primary">
        <Setter Property="Background" Value="{DynamicResource BrandOrangeBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Padding" Value="20,10"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Transitions">
            <Transitions>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1" />
                <BrushTransition Property="Background" Duration="0:0:0.2" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.primary:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#FF9F1A"/> <!-- Slightly lighter orange for hover -->
        <Setter Property="RenderTransform" Value="scale(1.02)"/>
    </Style>
    <Style Selector="Button.primary:pressed">
        <Setter Property="RenderTransform" Value="scale(0.98)"/>
    </Style>

    <!-- Global TextBox Styles -->
    <Style Selector="TextBox">
        <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="18,12"/>
        <Setter Property="Foreground" Value="{DynamicResource BrandTextBrush}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="CaretBrush" Value="{DynamicResource BrandOrangeBrush}"/>
        <Setter Property="SelectionBrush" Value="{DynamicResource BrandOrangeBrush}"/>
    </Style>
    <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BrandOrangeBrush}"/>
        <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}"/>
    </Style>

    <!-- Feature Cards -->
    <Style Selector="Button.feature-card">
        <Setter Property="Background" Value="#1E293B"/>
        <Setter Property="BorderBrush" Value="#334155"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Transitions">
            <Transitions>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1" />
                <BrushTransition Property="Background" Duration="0:0:0.2" />
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.feature-card:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#334155"/>
        <Setter Property="RenderTransform" Value="scale(1.01)"/>
    </Style>

    <!-- Icon Action Buttons -->
    <Style Selector="Button.icon-action">
        <Setter Property="Background" Value="#1E293B"/>
        <Setter Property="BorderBrush" Value="#334155"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="20"/>
        <Setter Property="Width" Value="36"/>
        <Setter Property="Height" Value="36"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
    <Style Selector="Button.icon-action:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="#334155"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BrandOrangeBrush}"/>
    </Style>
    <!-- Status Selection Buttons -->
    <Style Selector="RadioButton.status-btn">
        <Setter Property="Background" Value="#1E293B"/>
        <Setter Property="Foreground" Value="#94A3B8"/>
        <Setter Property="Padding" Value="15,10"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="#334155"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Padding="{TemplateBinding Padding}">
                    <ContentPresenter Content="{TemplateBinding Content}"
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
    <Style Selector="RadioButton.status-btn:checked">
        <Setter Property="Background" Value="{DynamicResource BrandOrangeBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BrandOrangeBrush}"/>
    </Style>
    <Style Selector="RadioButton.status-btn:pointerover">
        <Setter Property="Background" Value="#334155"/>
    </Style>
    <!-- Tab Navigation Buttons -->
    <Style Selector="Button.tab-button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
    </Style>
    <Style Selector="Button.tab-button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="Button.tab-button:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="Button.tab-button Path">
        <Setter Property="Fill" Value="#94A3B8"/>
    </Style>
    <Style Selector="Button.tab-button TextBlock">
        <Setter Property="Foreground" Value="#94A3B8"/>
    </Style>
</Styles>
