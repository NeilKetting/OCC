<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:OCC.Mobile.Features.HSEQ"
             x:DataType="vm:HseqListViewModel"
             x:Class="OCC.Mobile.Features.HSEQ.HseqListView"
             Background="{DynamicResource BrandDarkBrush}">

    <Grid RowDefinitions="Auto, *">
        <!-- Header -->
        <Border Grid.Row="0" Background="#1E293B" Padding="20,15">
            <Grid ColumnDefinitions="Auto, *, Auto">
                <Button Command="{Binding GoBackCommand}" Background="Transparent" Padding="5">
                    <Path Fill="White" Data="M20,11V13H8L13.5,18.5L12.08,19.92L4.16,12L12.08,4.08L13.5,5.5L8,11H20Z" />
                </Button>
                <TextBlock Grid.Column="1" Text="Safety Documents" Foreground="White" FontSize="20" FontWeight="Bold" Margin="15,0,0,0" VerticalAlignment="Center"/>
                <Button Grid.Column="2" Command="{Binding LoadDataCommand}" Background="Transparent" Padding="5">
                    <Path Fill="White" Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z" />
                </Button>
            </Grid>
        </Border>

        <!-- Document List -->
        <Grid Grid.Row="1">
            <ScrollViewer>
                <ItemsControl ItemsSource="{Binding Documents}" Margin="15">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding ((vm:HseqListViewModel)DataContext).OpenDocumentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Background="Transparent" Padding="0" HorizontalAlignment="Stretch" Margin="0,0,0,10">
                                <Border Background="#1A1F2B" CornerRadius="12" Padding="15" BorderBrush="#334155" BorderThickness="1">
                                    <Grid ColumnDefinitions="Auto, *, Auto">
                                        <!-- File Icon -->
                                        <Border Width="45" Height="45" Background="#2E9DFF" CornerRadius="8">
                                            <Path Fill="White" Data="M14,2H6A2,2 0 0,0 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V8L14,2M18,20H6V4H13V9H18V20Z" 
                                                  Stretch="Uniform" Margin="12"/>
                                        </Border>

                                        <StackPanel Grid.Column="1" Margin="15,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Title}" Foreground="White" FontSize="16" FontWeight="SemiBold"/>
                                            <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,4,0,0">
                                                <TextBlock Text="{Binding Category}" Foreground="#94A3B8" FontSize="12"/>
                                                <TextBlock Text="•" Foreground="#475569" FontSize="12"/>
                                                <TextBlock Text="{Binding FileSize}" Foreground="#94A3B8" FontSize="12"/>
                                                <TextBlock Text="•" Foreground="#475569" FontSize="12"/>
                                                <TextBlock Text="{Binding Version}" Foreground="#94A3B8" FontSize="12"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <Path Grid.Column="2" Fill="#475569" Data="M8.59,16.58L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.58Z" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Loading Overlay -->
            <Border Background="#CC000000" IsVisible="{Binding IsLoading}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20">
                    <ProgressBar IsIndeterminate="True" Width="200" Height="4" Foreground="{DynamicResource BrandOrangeBrush}"/>
                    <TextBlock Text="Fetching Safety Files..." Foreground="White" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Empty State -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" IsVisible="{Binding !Documents.Count}" Opacity="0.5">
                <Path Fill="#94A3B8" Width="80" Height="80" Data="M14,2H6A2,2 0 0,0 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V8L14,2M18,20H6V4H13V9H18V20Z" Stretch="Uniform"/>
                <TextBlock Text="No safety documents found for this project." Foreground="#94A3B8" Margin="0,20,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
