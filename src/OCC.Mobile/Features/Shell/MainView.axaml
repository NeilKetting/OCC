<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:OCC.Mobile.Features.Shell"
             x:DataType="vm:MainViewModel"
             x:Class="OCC.Mobile.Features.Shell.MainView">
    <Grid RowDefinitions="*, Auto">
        <!-- Main Content -->
        <TransitioningContentControl Grid.Row="0" Content="{Binding CurrentView}">
            <TransitioningContentControl.PageTransition>
                <CrossFade Duration="00:00:00.250" />
            </TransitioningContentControl.PageTransition>
        </TransitioningContentControl>
 
        <!-- Bottom Tab Bar -->
        <Border Grid.Row="1" 
                Background="{DynamicResource BrandDarkerBrush}" 
                BorderBrush="#1E293B" 
                BorderThickness="0,1,0,0"
                Padding="10,8"
                IsVisible="{Binding IsShellVisible}">
            <UniformGrid Columns="5">
                <Button Command="{Binding NavigateToDashboardCommand}" Classes="tab-button">
                    <StackPanel Spacing="4">
                        <Path Fill="White" Data="M10,20V14H14V20H19V12H22L12,3L2,12H5V20H10Z" Stretch="Uniform" Width="20" Height="20"/>
                        <TextBlock Text="Overview" FontSize="10" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
 
                <Button Command="{Binding NavigateToProjectsCommand}" Classes="tab-button">
                    <StackPanel Spacing="4">
                        <Path Fill="White" Data="M3,13H11V15H3V13M3,17H11V19H3V17M13,3H21V5H13V3M13,7H21V9H13V7M13,11H21V13H13V11M3,3H11V11H3V3M13,15H21V17H13V15M13,19H21V21H13V19M3,21V21H11V21H3V21Z" Stretch="Uniform" Width="20" Height="20"/>
                        <TextBlock Text="Projects" FontSize="10" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
 
                <Button Command="{Binding NavigateToTasksCommand}" Classes="tab-button">
                    <StackPanel Spacing="4">
                        <Path Fill="White" Data="M19,3H5C3.89,3 3,3.89 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V5C21,3.89 20.1,3 19,3M19,19H5V5H19V19M16.06,11.5L15,10.44L11,14.44L8.94,12.38L7.88,13.44L11,16.56L16.06,11.5Z" Stretch="Uniform" Width="20" Height="20"/>
                        <TextBlock Text="Tasks" FontSize="10" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
 
                <Button Command="{Binding NavigateToHseqCommand}" Classes="tab-button">
                    <StackPanel Spacing="4">
                        <Path Fill="White" Data="M12,1L3,5V11C3,16.55 6.84,21.74 12,23C17.16,21.74 21,16.55 21,11V5L12,1M12,5A3,3 0 0,1 15,8A3,3 0 0,1 12,11A3,3 0 0,1 9,8A3,3 0 0,1 12,5M17.13,17C15.92,18.85 14.11,20.24 12,20.92C9.89,20.24 8.08,18.85 6.87,17C6.53,16.5 6.24,16 6,15.47C6,13.47 10,12.33 12,12.33C14,12.33 18,13.47 18,15.47C17.76,16 17.47,16.5 17.13,17Z" Stretch="Uniform" Width="20" Height="20"/>
                        <TextBlock Text="HSEQ" FontSize="10" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
 
                <Button Command="{Binding NavigateToProfileCommand}" Classes="tab-button">
                    <StackPanel Spacing="4">
                        <Path Fill="White" Data="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z" Stretch="Uniform" Width="20" Height="20"/>
                        <TextBlock Text="Profile" FontSize="10" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </UniformGrid>
        </Border>
 
        <!-- Busy Overlay -->
        <Border Grid.RowSpan="2"
                Background="#80000000" 
                IsVisible="{Binding IsBusy}"
                ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20">
                <ProgressBar IsIndeterminate="True" Width="200" Foreground="#F97316"/>
                <TextBlock Text="{Binding BusyText}" Foreground="White" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
