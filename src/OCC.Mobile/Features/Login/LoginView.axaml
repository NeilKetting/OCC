<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:OCC.Mobile.Features.Login"
             x:DataType="vm:LoginViewModel"
             x:Class="OCC.Mobile.Features.Login.LoginView">

    <Grid Background="{DynamicResource BrandDarkBrush}">
        <ScrollViewer HorizontalScrollBarVisibility="Disabled">
            <StackPanel VerticalAlignment="Top" HorizontalAlignment="Center" Spacing="0" MaxWidth="450" Margin="20,5,20,100">
                <!-- Official Logo Section -->
                <Image Source="avares://OCC.Mobile/Assets/occ_logo.png" Height="200" RenderOptions.BitmapInterpolationMode="HighQuality" />
                                
                <TextBlock Text="Welcome back. Let's keep building." 
                           Foreground="{DynamicResource BrandSubTextBrush}" 
                           FontSize="18" 
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <!-- Input Section -->
                <StackPanel Spacing="15" Margin="0,20,0,0">
                    <TextBox Text="{Binding Username}" 
                             PlaceholderText="Username or Email" 
                             Height="55" />
                    
                    <TextBox Text="{Binding Password}" 
                             PlaceholderText="Password" 
                             PasswordChar="*" 
                             Height="55" />
                    
                    <Grid ColumnDefinitions="*, *" Margin="5,0,5,10">
                        <!-- Environment Switcher -->
                        <StackPanel Grid.Column="0" Spacing="5">
                            <TextBlock Text="Environment" Foreground="{DynamicResource BrandSubTextBrush}" FontSize="12"/>
                            <ComboBox ItemsSource="{Binding Environments}"
                                      SelectedItem="{Binding SelectedEnvironment}"
                                      HorizontalAlignment="Stretch"
                                      Height="40"
                                      Background="{DynamicResource InputBackgroundBrush}"/>
                        </StackPanel>

                        <!-- Save Email -->
                        <CheckBox Grid.Column="1" 
                                  Content="Remember Email" 
                                  Foreground="{DynamicResource BrandSubTextBrush}"
                                  IsChecked="{Binding RememberEmail}"
                                  VerticalAlignment="Bottom"
                                  HorizontalAlignment="Right"/>
                    </Grid>

                    <!-- Custom IP Input (Visible only if Local is selected) -->
                    <StackPanel Spacing="5" Margin="0,0,0,10" IsVisible="{Binding SelectedEnvironment, ConverterParameter=Local, Converter={StaticResource EnumToBoolConverter}}">
                        <TextBlock Text="Local API IP (e.g. http://192.168.1.10:5237)" Foreground="{DynamicResource BrandSubTextBrush}" FontSize="12"/>
                        <TextBox Text="{Binding CustomLocalUrl}" 
                                 PlaceholderText="http://0.0.0.0:5237"
                                 Height="45"
                                 Background="{DynamicResource InputBackgroundBrush}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Error Message -->
                <TextBlock Text="{Binding ErrorMessage}" 
                           Foreground="#EF4444" 
                           FontSize="14" 
                           HorizontalAlignment="Center"
                           IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                <!-- Login Button -->
                <Button Command="{Binding LoginCommand}" 
                        Classes="primary"
                        Height="60" 
                        HorizontalAlignment="Stretch" 
                        Content="LOG IN"/>

                <Button Background="Transparent" 
                        BorderThickness="0" 
                        HorizontalAlignment="Center"
                        Margin="0,10">
                    <TextBlock Text="Need an account? Register here" Foreground="{DynamicResource BrandOrangeBrush}" FontSize="14" FontWeight="SemiBold"/>
                </Button>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
