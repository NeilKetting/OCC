<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:OCC.Mobile.Features.Dashboard"
             xmlns:conv="clr-namespace:OCC.Mobile.Infrastructure.Converters"
             x:DataType="vm:TaskDetailViewModel"
             x:Class="OCC.Mobile.Features.Dashboard.TaskDetailView">
 
    <UserControl.Resources>
        <conv:EqualityConverter x:Key="EqualityConverter" />
    </UserControl.Resources>
 
    <UserControl.Styles>
        <Style Selector="RadioButton.status-btn">
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Name="RootBorder" 
                            Background="{TemplateBinding Background}" 
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8" 
                            Padding="12,8">
                        <ContentPresenter Name="PART_ContentPresenter"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Center"
                                          RecognizesAccessKey="True" />
                    </Border>
                </ControlTemplate>
            </Setter>
            <Setter Property="Background" Value="#1E293B" />
            <Setter Property="BorderBrush" Value="#334155" />
            <Setter Property="Foreground" Value="#94A3B8" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2" />
                    <BrushTransition Property="Foreground" Duration="0:0:0.2" />
                </Transitions>
            </Setter>
        </Style>
 
        <Style Selector="RadioButton.status-btn:checked">
            <Setter Property="Background" Value="{DynamicResource BrandOrangeBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrandOrangeBrush}" />
            <Setter Property="Foreground" Value="White" />
        </Style>
 
        <Style Selector="RadioButton.status-btn:pointerover:not(:checked)">
            <Setter Property="Background" Value="#334155" />
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto, *, Auto">
        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource BrandDarkerBrush}" Padding="20">
            <Grid ColumnDefinitions="Auto, *, Auto">
                <Button Grid.Column="0" Command="{Binding GoBackCommand}" Background="Transparent" Padding="5">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Path Fill="White" Data="M20,11V13H8L13.5,18.5L12.08,19.92L4.16,12L12.08,4.08L13.5,5.5L8,11H20Z" Stretch="Uniform" Width="20" Height="20"/>
                        <TextBlock Text="Back" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                
                <TextBlock Grid.Column="1" Text="Update Task" 
                           Foreground="White" 
                           FontSize="22" 
                           FontWeight="Bold" 
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" Background="{DynamicResource BrandDarkBrush}">
            <StackPanel Spacing="25" Margin="20">
                <!-- Task Info Header -->
                <StackPanel Spacing="5">
                    <TextBlock Text="{Binding Task.Name}" Foreground="White" FontSize="24" FontWeight="Bold" TextWrapping="Wrap"/>
                    <TextBlock Text="Construction Site: Engen Bendor" Foreground="{DynamicResource BrandSubTextBrush}" FontSize="14"/>
                </StackPanel>

                <StackPanel Spacing="10">
                    <TextBlock Text="CURRENT STATUS" Foreground="#94A3B8" FontSize="12" FontWeight="Bold"/>
                    <WrapPanel>
                        <RadioButton Content="Not Started" GroupName="StatusGroup" Classes="status-btn"
                                     IsChecked="{Binding Status, Converter={StaticResource EqualityConverter}, ConverterParameter='Not Started', Mode=OneWay}"
                                     Command="{Binding SetStatusCommand}" CommandParameter="Not Started" Margin="0,0,8,8"/>
                        
                        <RadioButton Content="Started" GroupName="StatusGroup" Classes="status-btn"
                                     IsChecked="{Binding Status, Converter={StaticResource EqualityConverter}, ConverterParameter='Started', Mode=OneWay}"
                                     Command="{Binding SetStatusCommand}" CommandParameter="Started" Margin="0,0,8,8"/>
                        
                        <RadioButton Content="Halfway" GroupName="StatusGroup" Classes="status-btn"
                                     IsChecked="{Binding Status, Converter={StaticResource EqualityConverter}, ConverterParameter='Halfway', Mode=OneWay}"
                                     Command="{Binding SetStatusCommand}" CommandParameter="Halfway" Margin="0,0,8,8"/>
                        
                        <RadioButton Content="Almost Done" GroupName="StatusGroup" Classes="status-btn"
                                     IsChecked="{Binding Status, Converter={StaticResource EqualityConverter}, ConverterParameter='Almost Done', Mode=OneWay}"
                                     Command="{Binding SetStatusCommand}" CommandParameter="Almost Done" Margin="0,0,8,8"/>
                        
                        <RadioButton Content="Completed" GroupName="StatusGroup" Classes="status-btn"
                                     IsChecked="{Binding Status, Converter={StaticResource EqualityConverter}, ConverterParameter='Completed', Mode=OneWay}"
                                     Command="{Binding SetStatusCommand}" CommandParameter="Completed" Margin="0,0,8,8"/>
                        
                        <RadioButton Content="On Hold" GroupName="StatusGroup" Classes="status-btn"
                                     IsChecked="{Binding Status, Converter={StaticResource EqualityConverter}, ConverterParameter='On Hold', Mode=OneWay}"
                                     Command="{Binding SetStatusCommand}" CommandParameter="On Hold" Margin="0,0,8,8"/>
                    </WrapPanel>
                </StackPanel>

                <!-- Progress Section -->
                <StackPanel Spacing="10">
                    <Grid>
                        <TextBlock Text="PROGRESS" Foreground="#94A3B8" FontSize="12" FontWeight="Bold"/>
                        <TextBlock Text="{Binding PercentComplete, StringFormat='{}{0}%'}" Foreground="White" FontSize="14" FontWeight="Bold" HorizontalAlignment="Right"/>
                    </Grid>
                    <ProgressBar Value="{Binding PercentComplete}" 
                                 Minimum="0" 
                                 Maximum="100" 
                                 Height="10" 
                                 CornerRadius="5"
                                 Background="#1E293B"
                                 Foreground="{DynamicResource BrandOrangeBrush}"/>
                </StackPanel>

                <!-- On Hold Reason (Visible only when status is On Hold) -->
                <Border Background="#1E293B" CornerRadius="12" Padding="15" IsVisible="{Binding IsOnHold}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="HOLD REASON" Foreground="#94A3B8" FontSize="12" FontWeight="Bold"/>
                        <TextBox Text="{Binding HoldReason}" 
                                 PlaceholderText="Explain why this task is being put on hold..."
                                 AcceptsReturn="True"
                                 MinHeight="100"
                                 TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Comments Section -->
                <StackPanel Spacing="15">
                    <TextBlock Text="COMMENTS" Foreground="#94A3B8" FontSize="12" FontWeight="Bold"/>
                    
                    <!-- Add Comment -->
                    <Border Background="#1E293B" CornerRadius="12" Padding="15">
                        <StackPanel Spacing="10">
                            <TextBox Text="{Binding NewCommentContent}" 
                                     PlaceholderText="Add a comment..."
                                     AcceptsReturn="True"
                                     MinHeight="60"
                                     TextWrapping="Wrap"/>
                            <Button Command="{Binding AddCommentCommand}" 
                                    Content="Post Comment" 
                                    Classes="primary" 
                                    HorizontalAlignment="Right"
                                    Padding="15,8"/>
                        </StackPanel>
                    </Border>

                    <!-- Comments List -->
                    <ItemsControl ItemsSource="{Binding Comments}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1A1F2B" CornerRadius="8" Padding="12" Margin="0,0,0,10">
                                    <StackPanel Spacing="5">
                                        <Grid>
                                            <TextBlock Text="{Binding AuthorName}" Foreground="{DynamicResource BrandOrangeBrush}" FontWeight="Bold" FontSize="13"/>
                                            <TextBlock Text="{Binding CreatedAtUtc, StringFormat='{}{0:g}'}" Foreground="#64748B" FontSize="11" HorizontalAlignment="Right"/>
                                        </Grid>
                                        <TextBlock Text="{Binding Content}" Foreground="White" FontSize="14" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer Actions Removed as we now auto-update -->
    </Grid>
</UserControl>
