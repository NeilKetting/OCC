<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:OCC.Mobile.Features.Dashboard"
             xmlns:models="clr-namespace:OCC.Shared.Models;assembly=OCC.Shared"
             x:DataType="vm:MyTasksViewModel"
             x:Class="OCC.Mobile.Features.Dashboard.MyTasksView">

    <Grid RowDefinitions="Auto, Auto, *">
        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource BrandDarkerBrush}" Padding="20">
            <Grid ColumnDefinitions="Auto, *, Auto">
                <Button Grid.Column="0" Command="{Binding GoBackCommand}" Background="Transparent" Padding="5">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Path Fill="White" Data="M20,11V13H8L13.5,18.5L12.08,19.92L4.16,12L12.08,4.08L13.5,5.5L8,11H20Z" Stretch="Uniform" Width="20" Height="20"/>
                        <TextBlock Text="Back" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                
                <TextBlock Grid.Column="1" Text="{Binding Title}" 
                           Foreground="White" 
                           FontSize="22" 
                           FontWeight="Bold" 
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="2" Command="{Binding LoadDataCommand}" Background="Transparent" Padding="5">
                    <Path Fill="White" Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z" Stretch="Uniform" Width="20" Height="20"/>
                </Button>
            </Grid>
        </Border>

        <!-- Search & Filters -->
        <Border Grid.Row="1" Background="{DynamicResource BrandDarkerBrush}" Padding="20,0,20,20">
            <StackPanel Spacing="15">
                <TextBox Text="{Binding SearchText}" PlaceholderText="Search tasks..." Classes="search">
                    <TextBox.InnerLeftContent>
                        <Path Fill="{DynamicResource BrandSubTextBrush}" Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L19.71,19L18.29,20.41L13.01,15.14C11.87,16.11 10.39,16.7 8.5,16.7C4.91,16.7 2,13.79 2,10.2C2,6.61 4.91,3.7 8.5,3.7C8.84,3.7 9.17,3.73 9.5,3.7M8.5,5.7C6,5.7 4,7.7 4,10.2C4,12.7 6,14.7 8.5,14.7C11,14.7 13,12.7 13,10.2C13,7.7 11,5.7 8.5,5.7Z" Width="18" Height="18" Margin="10,0,0,0"/>
                    </TextBox.InnerLeftContent>
                </TextBox>
                
                <Grid ColumnDefinitions="*, Auto">
                    <ScrollViewer Grid.Column="0" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <CheckBox IsChecked="{Binding ShowOverdueOnly}" Content="Overdue" Classes="chip"/>
                            <CheckBox IsChecked="{Binding ShowDueTodayOnly}" Content="Today" Classes="chip"/>
                            <CheckBox IsChecked="{Binding ShowDueThisWeekOnly}" Content="This Week" Classes="chip"/>
                            <CheckBox IsChecked="{Binding ShowOnHoldOnly}" Content="On Hold" Classes="chip"/>
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="5" Margin="10,0,0,0">
                        <Button Content="Expand All" Command="{Binding ExpandAllCommand}" ToolTip.Tip="Expand All" CornerRadius="4">
                            
                        </Button>
                        <Button Content="Collapse All" Command="{Binding CollapseAllCommand}" ToolTip.Tip="Collapse All" CornerRadius="4">
                            
                        </Button>
                    </StackPanel>
                </Grid>

                <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsBusy}" 
                             Height="2" Background="Transparent" Foreground="{DynamicResource BrandOrangeBrush}"
                             Margin="0,10,0,0"/>
            </StackPanel>
        </Border>

        <!-- Tasks List -->
        <ScrollViewer Grid.Row="2" Background="{DynamicResource BrandDarkBrush}">
            <ItemsControl ItemsSource="{Binding FilteredTasks}" Margin="20">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:ProjectTask">
                        <Grid Margin="{Binding IndentLevel, Converter={StaticResource IndentConverter}}">
                            <!-- Main Card Button (Opens Details) -->
                            <Button Classes="feature-card" 
                                    Command="{Binding $parent[UserControl].((vm:MyTasksViewModel)DataContext).SelectTaskCommand}"
                                    CommandParameter="{Binding}"
                                    Padding="15" HorizontalAlignment="Stretch">
                                <Grid ColumnDefinitions="Auto, *, Auto">
                                    
                                    <!-- Caret Area (Tappable for Expansion) -->
                                    <Button Grid.Column="0" 
                                            IsVisible="{Binding IsGroup}"
                                            Command="{Binding $parent[UserControl].((vm:MyTasksViewModel)DataContext).ToggleExpandCommand}"
                                            CommandParameter="{Binding}"
                                            Background="Transparent" 
                                            BorderThickness="0"
                                            Padding="0" 
                                            Width="40" 
                                            Height="40"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Left">
                                        <Path Fill="{DynamicResource BrandSubTextBrush}" 
                                              Data="{Binding IsExpanded, Converter={StaticResource BoolToPathDataConverter}, ConverterParameter='M7,10L12,15L17,10H7Z|M10,17L15,12L10,7V17Z'}" 
                                              Stretch="Uniform"
                                              Width="18" 
                                              Height="18" 
                                              VerticalAlignment="Center" 
                                              HorizontalAlignment="Center"/>
                                    </Button>

                                    <StackPanel Grid.Column="1" Spacing="5" VerticalAlignment="Center" Margin="{Binding IsGroup, Converter={StaticResource BoolToThicknessConverter}, ConverterParameter='0,0,0,0|10,0,0,0'}">
                                        <TextBlock Text="{Binding Name}" 
                                                   Foreground="White" 
                                                   FontSize="{Binding IsGroup, Converter={StaticResource BoolToFontSizeConverter}, ConverterParameter=18|16}" 
                                                   FontWeight="{Binding IsGroup, Converter={StaticResource BoolToFontWeightConverter}, ConverterParameter=Bold|SemiBold}"/>

                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <Border Background="{Binding StatusColor}" Width="8" Height="8" CornerRadius="4" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding Status}" Foreground="#94A3B8" FontSize="14"/>
                                            <TextBlock IsVisible="{Binding !IsGroup}" Text="•" Foreground="#475569" VerticalAlignment="Center"/>
                                            <TextBlock IsVisible="{Binding !IsGroup}" Text="{Binding FinishDate, StringFormat='Due: {0:MMM dd}'}" Foreground="#64748B" FontSize="14"/>
                                        </StackPanel>
                                        
                                        <!-- Progress Mini Bar -->
                                        <Grid Margin="0,5,0,0" ColumnDefinitions="*, Auto" IsVisible="{Binding !IsGroup}">
                                            <ProgressBar Value="{Binding PercentComplete}" Height="4" Background="#334155" Foreground="{DynamicResource BrandOrangeBrush}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding PercentComplete, StringFormat='{}{0}%'}" Foreground="#64748B" FontSize="10" Margin="10,0,0,0"/>
                                        </Grid>
                                    </StackPanel>
                                    
                                    <Path Grid.Column="2" Fill="#475569" Data="M8.59,16.58L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.58Z" Stretch="Uniform" Width="24" Height="24" VerticalAlignment="Center"/>
                                </Grid>
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
        
        <!-- Loading Overlay (Visible during first batch) -->
        <Border Grid.Row="2" Background="#AA000000" IsVisible="{Binding IsBusy}" IsHitTestVisible="True">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Foreground="{DynamicResource BrandOrangeBrush}" Background="#334155"/>
                <TextBlock Text="Syncing Tasks..." Foreground="White" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                <TextBlock Text="Please wait while we fetch your project data." Foreground="#94A3B8" FontSize="14" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
