<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:OCC.Mobile.Features.Dashboard"
             x:DataType="vm:DashboardViewModel"
             x:Name="root"
             x:Class="OCC.Mobile.Features.Dashboard.DashboardView">
    <ScrollViewer Background="{DynamicResource BrandDarkBrush}">
        <StackPanel Spacing="20" Margin="20">
            <TextBlock Text="Daily Overview" 
                       Foreground="{DynamicResource BrandTextBrush}" 
                       FontSize="22" 
                       FontWeight="Bold"/>
            
            <!-- Summary Info -->
            <StackPanel Spacing="5" Margin="0,0,0,10">
                <TextBlock Text="Active Projects" Foreground="#94A3B8" FontSize="12"/>
                <TextBlock Text="{Binding ActiveSitesCount, StringFormat='{}{0} Sites'}" Foreground="White" FontSize="24" FontWeight="Bold"/>
            </StackPanel>

            <!-- Project Cards List -->
            <ItemsControl ItemsSource="{Binding ActiveProjects}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Spacing="15"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#1E293B" CornerRadius="12" Padding="20">
                            <StackPanel Spacing="20">
                                <Grid ColumnDefinitions="*, Auto">
                                    <StackPanel Spacing="5">
                                        <TextBlock Text="Project Site" Foreground="#94A3B8" FontSize="11" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Name}" Foreground="White" FontSize="18" FontWeight="Bold" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <Border Grid.Column="1" Background="#F97316" Width="40" Height="40" CornerRadius="20" VerticalAlignment="Top">
                                        <Path Fill="White" Data="M10,20V14H14V20H19V12H22L12,3L2,12H5V20H10Z" 
                                                Stretch="Uniform" Margin="10"/>
                                    </Border>
                                </Grid>

                                <Separator Background="#334155" Height="1" Margin="0,-5"/>

                                <!-- Action Grid within the card -->
                                <UniformGrid Columns="6">
                                    <Button Classes="feature-card" 
                                            Command="{Binding #root.DataContext.NavigateToProjectTasksCommand, FallbackValue={x:Null}}"
                                            CommandParameter="{Binding}"
                                            Margin="2" Padding="8">
                                        <StackPanel Spacing="5" HorizontalAlignment="Center">
                                            <Border Background="#3B82F6" Width="28" Height="28" CornerRadius="14">
                                                <Path Fill="White" Data="M19,3H5C3.89,3 3,3.89 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V5C21,3.89 20.1,3 19,3M19,19H5V5H19V19M16.06,11.5L15,10.44L11,14.44L8.94,12.38L7.88,13.44L11,16.56L16.06,11.5Z" Stretch="Uniform" Margin="6"/>
                                            </Border>
                                            <TextBlock Text="Tasks" Foreground="White" FontSize="10" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <Button Classes="feature-card" 
                                            Command="{Binding #root.DataContext.NavigateToProjectHseqCommand, FallbackValue={x:Null}}"
                                            CommandParameter="{Binding}"
                                            Margin="2" Padding="8">
                                        <StackPanel Spacing="5" HorizontalAlignment="Center">
                                            <Border Background="#10B981" Width="28" Height="28" CornerRadius="14">
                                                <Path Fill="White" Data="M12,1L3,5V11C3,16.55 6.84,21.74 12,23C17.16,21.74 21,16.55 21,11V5L12,1M12,5A3,3 0 0,1 15,8A3,3 0 0,1 12,11A3,3 0 0,1 9,8A3,3 0 0,1 12,5M17.13,17C15.92,18.85 14.11,20.24 12,20.92C9.89,20.24 8.08,18.85 6.87,17C6.53,16.5 6.24,16 6,15.47C6,13.47 10,12.33 12,12.33C14,12.33 18,13.47 18,15.47C17.76,16 17.47,16.5 17.13,17Z" Stretch="Uniform" Margin="6"/>
                                            </Border>
                                            <TextBlock Text="HSEQ" Foreground="White" FontSize="10" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <Button Classes="feature-card" Margin="2" Padding="8">
                                        <StackPanel Spacing="5" HorizontalAlignment="Center">
                                            <Border Background="#F59E0B" Width="28" Height="28" CornerRadius="14">
                                                <Path Fill="White" Data="M12,20L10,22L8.5,20.5L10,19L12,20M12,4L14,2L15.5,3.5L14,5L12,4M20,10L22,12L20.5,13.5L19,12L20,10M4,10L2,12L3.5,13.5L5,12L4,10Z" Stretch="Uniform" Margin="6"/>
                                            </Border>
                                            <TextBlock Text="Inventory" Foreground="White" FontSize="10" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <Button Classes="feature-card" Margin="2" Padding="8">
                                        <StackPanel Spacing="5" HorizontalAlignment="Center">
                                            <Border Background="#8B5CF6" Width="28" Height="28" CornerRadius="14">
                                                <Path Fill="White" Data="M16,13C15.71,13 15.38,13 15.03,13.05C16.19,13.89 17,15.22 17,16.5V19H22V16.5C22,14.63 18.83,13.54 16,13.03M9,12A4,4 0 0,0 13,8A4,4 0 0,0 9,4A4,4 0 0,0 5,8A4,4 0 0,0 9,12M9,14C6.33,14 1,15.34 1,18V20H17V18C17,15.34 11.67,14 9,14Z" Stretch="Uniform" Margin="6"/>
                                            </Border>
                                            <TextBlock Text="Team" Foreground="White" FontSize="10" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- Due Today Count -->
                                    <Button Classes="feature-card" Margin="2" Padding="8">
                                        <StackPanel Spacing="5" HorizontalAlignment="Center">
                                            <Border Background="#6366F1" Width="28" Height="28" CornerRadius="14">
                                                <Grid>
                                                    <Path Fill="White" Data="M12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22A10,10 0 0,1 2,12A10,10 0 0,1 12,2M12.5,7V12.25L17,14.92L16.25,16.15L11,13V7H12.5Z" Stretch="Uniform" Margin="6"/>
                                                    <Border Background="#EF4444" MinWidth="14" Height="14" CornerRadius="7" 
                                                            HorizontalAlignment="Right" VerticalAlignment="Top" Margin="-2,-2,0,0"
                                                            IsVisible="{Binding ProjectManager, Converter={StaticResource StringNotEmptyConverter}}">
                                                        <TextBlock Text="{Binding ProjectManager}" Foreground="White" FontSize="8" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="3,0"/>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                            <TextBlock Text="Due Today" Foreground="White" FontSize="10" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- Overdue Count -->
                                    <Button Classes="feature-card" Margin="2" Padding="8">
                                        <StackPanel Spacing="5" HorizontalAlignment="Center">
                                            <Border Background="#EF4444" Width="28" Height="28" CornerRadius="14">
                                                <Grid>
                                                    <Path Fill="White" Data="M13,13H11V7H13M13,17H11V15H13M12,2L1,21H23L12,2Z" Stretch="Uniform" Margin="6"/>
                                                    <Border Background="White" MinWidth="14" Height="14" CornerRadius="7" 
                                                            HorizontalAlignment="Right" VerticalAlignment="Top" Margin="-2,-2,0,0"
                                                            IsVisible="{Binding Description, Converter={StaticResource StringNotEmptyConverter}}">
                                                        <TextBlock Text="{Binding Description}" Foreground="#EF4444" FontSize="8" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="3,0"/>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                            <TextBlock Text="Overdue" Foreground="White" FontSize="10" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </UniformGrid>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Recent Activity Placeholder -->
            <TextBlock Text="Recent Activity" 
                       Foreground="White" 
                       FontSize="18" 
                       FontWeight="SemiBold"
                       Margin="0,10,0,0"/>
            
            <Border Background="#1E293B" CornerRadius="12" Padding="15">
                <StackPanel Spacing="15">
                    <TextBlock Text="No recent activity reported." Foreground="#64748B" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
