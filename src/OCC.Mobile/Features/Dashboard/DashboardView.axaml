<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:OCC.Mobile.Features.Dashboard"
             x:DataType="vm:DashboardViewModel"
             x:Class="OCC.Mobile.Features.Dashboard.DashboardView">
    <ScrollViewer Background="{DynamicResource BrandDarkBrush}">
        <StackPanel Spacing="25" Margin="20">
            <!-- Greeting & Header -->
            <StackPanel Spacing="5">
                <TextBlock Text="{Binding Greeting}" 
                           Foreground="White" 
                           FontSize="32" 
                           FontWeight="ExtraBold"/>
                <TextBlock Text="Here's how your day looks so far" 
                           Foreground="#94A3B8" 
                           FontSize="16"/>
            </StackPanel>

            <!-- Radial Progress Area (Doughnut Charts) -->
            <Border Background="#1E293B" CornerRadius="20" Padding="20" BoxShadow="0 4 20 0 #40000000">
                <StackPanel Spacing="20">
                    <UniformGrid Columns="2">
                        <!-- Daily Chart -->
                        <StackPanel Spacing="12" HorizontalAlignment="Center">
                            <TextBlock Text="TODAY'S STATUS" Foreground="#94A3B8" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" LetterSpacing="1"/>
                            <Viewbox Height="140" Width="140">
                                <Grid>
                                    <!-- Background -->
                                    <Ellipse Width="100" Height="100" Stroke="#334155" StrokeThickness="12"/>
                                    <Ellipse Width="72" Height="72" Stroke="#334155" StrokeThickness="12"/>
                                    
                                    <!-- Completed Ring (Green) -->
                                    <Arc Width="100" Height="100" Stroke="#10B981" StrokeThickness="12" 
                                         StartAngle="-90" SweepAngle="{Binding DailyProgressAngle}" 
                                         StrokeJoin="Round" StrokeLineCap="Round"/>
                                    
                                    <!-- Pending Ring (Blue) -->
                                    <Arc Width="72" Height="72" Stroke="#3B82F6" StrokeThickness="12" 
                                         StartAngle="-90" SweepAngle="{Binding DailyPendingProgressAngle}" 
                                         StrokeJoin="Round" StrokeLineCap="Round"/>

                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding DailyProgress, StringFormat='{}{0:0}%'}" Foreground="White" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center"/>
                                        <TextBlock Text="DONE" Foreground="#94A3B8" FontSize="8" HorizontalAlignment="Center" FontWeight="Bold"/>
                                    </StackPanel>
                                </Grid>
                            </Viewbox>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="4">
                                <TextBlock Text="{Binding DailyCompletedTasks}" Foreground="#10B981" FontSize="14" FontWeight="Bold"/>
                                <TextBlock Text="{Binding DailyTotalTasks, StringFormat='/ {0}'}" Foreground="#94A3B8" FontSize="12" VerticalAlignment="Bottom" Margin="0,0,0,1"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Overall Chart -->
                        <StackPanel Spacing="12" HorizontalAlignment="Center">
                            <TextBlock Text="OVERALL STATUS" Foreground="#94A3B8" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" LetterSpacing="1"/>
                            <Viewbox Height="140" Width="140">
                                <Grid>
                                    <Ellipse Width="100" Height="100" Stroke="#334155" StrokeThickness="12"/>
                                    <Ellipse Width="72" Height="72" Stroke="#334155" StrokeThickness="12"/>
                                    
                                    <!-- Completed Ring (Green) -->
                                    <Arc Width="100" Height="100" Stroke="#10B981" StrokeThickness="12" 
                                         StartAngle="-90" SweepAngle="{Binding OverallProgressAngle}" 
                                         StrokeJoin="Round" StrokeLineCap="Round"/>
                                    
                                    <!-- Pending Ring (Blue) -->
                                    <Arc Width="72" Height="72" Stroke="#3B82F6" StrokeThickness="12" 
                                         StartAngle="-90" SweepAngle="{Binding OverallPendingProgressAngle}" 
                                         StrokeJoin="Round" StrokeLineCap="Round"/>

                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding OverallProgress, StringFormat='{}{0:0}%'}" Foreground="White" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center"/>
                                        <TextBlock Text="TOTAL" Foreground="#94A3B8" FontSize="8" HorizontalAlignment="Center" FontWeight="Bold"/>
                                    </StackPanel>
                                </Grid>
                            </Viewbox>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="4">
                                <TextBlock Text="{Binding OverallCompletedTasks}" Foreground="#10B981" FontSize="14" FontWeight="Bold"/>
                                <TextBlock Text="{Binding OverallTotalTasks, StringFormat='/ {0}'}" Foreground="#94A3B8" FontSize="12" VerticalAlignment="Bottom" Margin="0,0,0,1"/>
                            </StackPanel>
                        </StackPanel>
                    </UniformGrid>
                    
                    <Separator Background="#334155" Height="1" Margin="0,5"/>
                    
                    <!-- Legend / Details -->
                    <UniformGrid Columns="3">
                        <StackPanel Spacing="4" HorizontalAlignment="Center">
                            <TextBlock Text="COMPLETED" Foreground="#10B981" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" LetterSpacing="0.5"/>
                            <TextBlock Text="{Binding DailyCompletedTasks}" Foreground="White" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>
                        
                        <StackPanel Spacing="4" HorizontalAlignment="Center">
                            <TextBlock Text="PENDING" Foreground="#3B82F6" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" LetterSpacing="0.5"/>
                            <TextBlock Text="{Binding PendingTasksCount}" Foreground="White" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>
                        
                        <StackPanel Spacing="4" HorizontalAlignment="Center">
                            <TextBlock Text="OVERDUE" Foreground="#EF4444" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" LetterSpacing="0.5"/>
                            <TextBlock Text="{Binding OverdueTasksCount}" Foreground="White" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <!-- Quick Access Stats -->
            <UniformGrid Columns="2">
                <Border Background="#1E293B" CornerRadius="16" Padding="20" Margin="0,0,8,0">
                    <StackPanel Spacing="8">
                        <TextBlock Text="ACTIVE SITES" Foreground="#94A3B8" FontSize="10" FontWeight="Bold" LetterSpacing="1"/>
                        <TextBlock Text="{Binding ActiveSitesCount}" Foreground="White" FontSize="24" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
                <Border Background="#1E293B" CornerRadius="16" Padding="20" Margin="8,0,0,0">
                    <StackPanel Spacing="8">
                        <TextBlock Text="TOTAL TASKS" Foreground="#94A3B8" FontSize="10" FontWeight="Bold" LetterSpacing="1"/>
                        <TextBlock Text="{Binding DailyTotalTasks}" Foreground="White" FontSize="24" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Project Health & Predicted Completion -->
            <UniformGrid Columns="2">
                <Border Background="#1E293B" CornerRadius="16" Padding="20" Margin="0,0,8,0">
                    <StackPanel Spacing="10">
                        <TextBlock Text="PROJECT HEALTH" Foreground="#94A3B8" FontSize="10" FontWeight="Bold" LetterSpacing="1"/>
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Ellipse Width="10" Height="10" Fill="{Binding ProjectHealthColor}"/>
                            <TextBlock Text="{Binding ProjectHealth}" Foreground="White" FontSize="18" FontWeight="Bold"/>
                        </StackPanel>
                        <TextBlock Text="Based on overdue tasks" Foreground="#64748B" FontSize="10"/>
                    </StackPanel>
                </Border>
                <Border Background="#1E293B" CornerRadius="16" Padding="20" Margin="8,0,0,0">
                    <StackPanel Spacing="10">
                        <TextBlock Text="PREDICTED COMPLETION" Foreground="#94A3B8" FontSize="10" FontWeight="Bold" LetterSpacing="1"/>
                        <TextBlock Text="{Binding EtaDateString}" Foreground="#F59E0B" FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="{Binding EtaStatus}" Foreground="#64748B" FontSize="10" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Recent Activity List -->
            <StackPanel Spacing="15">
                <Grid ColumnDefinitions="*, Auto">
                    <TextBlock Text="Recent Activity" 
                               Foreground="White" 
                               FontSize="20" 
                               FontWeight="Bold"/>
                    <Button Grid.Column="1" Content="View All" Foreground="{DynamicResource BrandOrangeBrush}" Background="Transparent" FontSize="12"/>
                </Grid>
                
                <ItemsControl ItemsSource="{Binding RecentActivity}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Spacing="12"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#1E293B" CornerRadius="12" Padding="16">
                                <Grid ColumnDefinitions="Auto, *">
                                    <Border Background="{Binding StatusColor}" Width="4" Height="32" CornerRadius="2" VerticalAlignment="Center" Margin="0,0,16,0"/>
                                    <StackPanel Grid.Column="1" Spacing="4">
                                        <TextBlock Text="{Binding Message}" Foreground="White" FontSize="14" TextWrapping="Wrap" LineHeight="20"/>
                                        <TextBlock Text="{Binding Timestamp, StringFormat='{}{0:HH:mm} • {0:MMM dd}'}" Foreground="#64748B" FontSize="11" FontWeight="Medium"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
            
            <Border IsVisible="{Binding !RecentActivity.Count}" Background="#1E293B" CornerRadius="12" Padding="20">
                <TextBlock Text="No recent activity reported." Foreground="#64748B" HorizontalAlignment="Center" FontSize="14"/>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
