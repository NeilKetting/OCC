<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:OCC.Mobile.Features.AdminDashboard"
             x:DataType="vm:AdminDashboardViewModel"
             x:Class="OCC.Mobile.Features.AdminDashboard.AdminDashboardView">

    <ScrollViewer Background="{DynamicResource BrandDarkBrush}">
        <StackPanel Spacing="25" Margin="20">
            
            <!-- Header -->
            <StackPanel Spacing="5">
                <TextBlock Text="Projects Dashboard" 
                           Foreground="White" 
                           FontSize="28" 
                           FontWeight="Bold"/>
                <TextBlock Text="Monitor construction progress, budgets and timelines across your portfolio." 
                           Foreground="{DynamicResource BrandSubTextBrush}" 
                           FontSize="14"/>
            </StackPanel>

            <!-- Metrics Row -->
            <UniformGrid Columns="3" Height="140">
                <!-- Active Projects -->
                <Button Classes="feature-card" 
                        Command="{Binding NavigateToActiveProjectsCommand}"
                        Margin="0,0,10,0" Padding="20">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Active Projects" Foreground="#94A3B8" FontSize="12" Margin="0,0,0,10"/>
                        <TextBlock Text="{Binding ActiveProjectsCount}" Foreground="White" FontSize="32" FontWeight="Bold"/>
                        <ProgressBar Value="{Binding CompletionProgress}" 
                                     Maximum="1" 
                                     Height="4" 
                                     Margin="0,15,0,0" 
                                     Foreground="{DynamicResource BrandOrangeBrush}"/>
                    </StackPanel>
                </Button>

                <!-- Overdue Tasks -->
                <Button Classes="feature-card"
                        Command="{Binding NavigateToOverdueTasksCommand}"
                        Margin="5,0,5,0" Padding="20">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Overdue Tasks" Foreground="#94A3B8" FontSize="12" Margin="0,0,0,10"/>
                        <TextBlock Text="{Binding OverdueTasksCount}" Foreground="#EF4444" FontSize="32" FontWeight="Bold"/>
                        <TextBlock Text="Requires immediate attention" Foreground="#64748B" FontSize="11" Margin="0,5,0,0"/>
                    </StackPanel>
                </Button>

                <!-- Avg. Completion -->
                <Border Background="#1E293B" CornerRadius="12" Margin="10,0,0,0" Padding="20">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Avg. Completion" Foreground="#94A3B8" FontSize="12" Margin="0,0,0,10"/>
                        <TextBlock Text="{Binding AvgCompletion}" Foreground="#10B981" FontSize="32" FontWeight="Bold"/>
                        <TextBlock Text="Overall portfolio health" Foreground="#64748B" FontSize="11" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Grid ColumnDefinitions="*, 20, 350">
                <!-- Left Column: Explore Portfolio -->
                <StackPanel Grid.Column="0" Spacing="20">
                    <TextBlock Text="Explore Portfolio" Foreground="White" FontSize="20" FontWeight="SemiBold"/>
                    
                    <StackPanel Spacing="15">
                        <Button Classes="feature-card" Height="80" HorizontalAlignment="Stretch">
                            <Grid ColumnDefinitions="60, *">
                                <Path Fill="#3B82F6" Data="M3,5H21V7H3V5M3,11H21V13H3V11M3,17H21V19H3V17Z" Stretch="Uniform" Margin="15" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Projects" Foreground="White" FontSize="16" FontWeight="SemiBold"/>
                                    <TextBlock Text="View and search the complete database of construction projects." TextWrapping="Wrap" Margin="0,0,10,0" Foreground="#94A3B8" FontSize="12"/>
                                </StackPanel>
                            </Grid>
                        </Button>

                        <Button Classes="feature-card" Height="80" HorizontalAlignment="Stretch">
                            <Grid ColumnDefinitions="60, *">
                                <Path Fill="#10B981" Data="M19,19H5V8H19M16,1V3H8V1H6V3H5C3.89,3 3,3.89 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V5C21,3.89 20.1,3 19,3H18V1M17,12H12V17H17V12Z" Stretch="Uniform" Margin="15"  VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Gantt Timeline" Foreground="White" FontSize="16" FontWeight="SemiBold"/>
                                    <TextBlock Text="Visualize project schedules and task dependencies." Foreground="#94A3B8" FontSize="12"/>
                                </StackPanel>
                            </Grid>
                        </Button>
                    </StackPanel>
                </StackPanel>

                <!-- Right Column: Recent Updates -->
                <Border Grid.Column="2" Background="#111827" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="12" Padding="20">
                    <StackPanel Spacing="15">
                        <TextBlock Text="Recent Updates" Foreground="White" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        
                        <ItemsControl ItemsSource="{Binding RecentUpdates}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,15">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="{Binding Title}" Foreground="{Binding Color}" FontSize="13" TextWrapping="Wrap"/>
                                            <StackPanel Orientation="Horizontal" Spacing="5">
                                                <TextBlock Text="{Binding Subtitle}" Foreground="#64748B" FontSize="11"/>
                                                <TextBlock Text="{Binding Timestamp}" Foreground="#475569" FontSize="11"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
