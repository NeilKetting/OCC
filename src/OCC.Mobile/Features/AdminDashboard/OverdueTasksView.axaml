<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:OCC.Mobile.Features.AdminDashboard"
             xmlns:models="clr-namespace:OCC.Shared.Models;assembly=OCC.Shared"
             x:DataType="vm:OverdueTasksViewModel"
             x:Class="OCC.Mobile.Features.AdminDashboard.OverdueTasksView">

    <Grid RowDefinitions="Auto, *">
        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource BrandDarkerBrush}" Padding="20">
            <Grid ColumnDefinitions="Auto, *, Auto">
                <Button Grid.Column="0" Command="{Binding GoBackCommand}" Background="Transparent" Padding="5">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Path Fill="White" Data="M20,11V13H8L13.5,18.5L12.08,19.92L4.16,12L12.08,4.08L13.5,5.5L8,11H20Z" Stretch="Uniform" Width="20" Height="20"/>
                        <TextBlock Text="Back" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                
                <TextBlock Grid.Column="1" Text="Overdue Tasks" 
                           Foreground="White" 
                           FontSize="22" 
                           FontWeight="Bold" 
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Task Groups -->
        <ScrollViewer Grid.Row="1" Background="{DynamicResource BrandDarkBrush}">
            <ItemsControl ItemsSource="{Binding GroupedTasks}" Margin="20">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:ProjectTaskGroup">
                        <StackPanel Spacing="10" Margin="0,0,0,25">
                            <!-- Project Header -->
                            <Border Background="#1E293B" CornerRadius="8" Padding="15,10">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Border Background="{DynamicResource BrandOrangeBrush}" Width="4" Height="20" CornerRadius="2"/>
                                    <TextBlock Text="{Binding ProjectName}" Foreground="White" FontSize="18" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>

                            <!-- Tasks in this Project -->
                            <ItemsControl ItemsSource="{Binding Tasks}" Margin="10,0,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:ProjectTask">
                                        <Border BorderBrush="#334155" BorderThickness="0,0,0,1" Padding="10,15">
                                            <Grid ColumnDefinitions="*, Auto">
                                                <StackPanel Spacing="5">
                                                    <TextBlock Text="{Binding Name}" Foreground="White" FontSize="16" FontWeight="SemiBold"/>
                                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                                        <TextBlock Text="{Binding FinishDate, StringFormat='Due: {0:MMM dd}'}" Foreground="#EF4444" FontSize="13" FontWeight="SemiBold"/>
                                                        <TextBlock Text="•" Foreground="#475569" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding AssignedTo}" Foreground="#94A3B8" FontSize="13"/>
                                                    </StackPanel>
                                                </StackPanel>
                                                
                                                <Border Grid.Column="1" Background="#451A1A" BorderBrush="#EF4444" BorderThickness="1" CornerRadius="12" Padding="8,4" VerticalAlignment="Center">
                                                    <TextBlock Text="Overdue" Foreground="#EF4444" FontSize="11" FontWeight="Bold"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
