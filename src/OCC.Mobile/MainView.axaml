<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="OCC.Mobile.MainView">
    <Grid Background="#1E293B">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20">
            <TextBlock Text="FRESH MOBILE START" 
                       Foreground="White" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       HorizontalAlignment="Center"/>
            <TextBlock Text="If you can see this, the shell is working!" 
                       Foreground="#94A3B8" 
                       HorizontalAlignment="Center"/>
            <Border Background="#F97316" CornerRadius="8" Padding="20,10" Margin="0,20">
                <TextBlock Text="SYSTEM GO" Foreground="White" FontWeight="SemiBold"/>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
